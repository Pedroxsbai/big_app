{
  "metadata": {
    "sura_no": 92,
    "sura_name_en": "Al-Lail",
    "sura_name_ar": "اللَّيل",
    "total_verses": 21,
    "created_at": "2025-10-11T18:45:17.986Z"
  },
  "verses": [
    {
      "id": 6059,
      "jozz": 30,
      "page": 595,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 1,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "والليل إذا يغشى"
    },
    {
      "id": 6060,
      "jozz": 30,
      "page": 595,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "والنهار إذا تجلى"
    },
    {
      "id": 6061,
      "jozz": 30,
      "page": 595,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما خلق الذكر والأنثى"
    },
    {
      "id": 6062,
      "jozz": 30,
      "page": 595,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 4,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إن سعيكم لشتى"
    },
    {
      "id": 6063,
      "jozz": 30,
      "page": 595,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأما من أعطى واتقى"
    },
    {
      "id": 6064,
      "jozz": 30,
      "page": 595,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وصدق بالحسنى"
    },
    {
      "id": 6065,
      "jozz": 30,
      "page": 595,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فسنيسره لليسرى"
    },
    {
      "id": 6066,
      "jozz": 30,
      "page": 595,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 8,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما من بخل واستغنى"
    },
    {
      "id": 6067,
      "jozz": 30,
      "page": 595,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 9,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكذب بالحسنى"
    },
    {
      "id": 6068,
      "jozz": 30,
      "page": 596,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فسنيسره للعسرى"
    },
    {
      "id": 6069,
      "jozz": 30,
      "page": 596,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 11,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وما يغني عنه ماله إذا تردى"
    },
    {
      "id": 6070,
      "jozz": 30,
      "page": 596,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 12,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن علينا للهدى"
    },
    {
      "id": 6071,
      "jozz": 30,
      "page": 596,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 13,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن لنا للآخرة والأولى"
    },
    {
      "id": 6072,
      "jozz": 30,
      "page": 596,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فأنذرتكم نارا تلظى"
    },
    {
      "id": 6073,
      "jozz": 30,
      "page": 596,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 15,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يصلاها إلا الأشقى"
    },
    {
      "id": 6074,
      "jozz": 30,
      "page": 596,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 16,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "الذي كذب وتولى"
    },
    {
      "id": 6075,
      "jozz": 30,
      "page": 596,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وسيجنبها الأتقى"
    },
    {
      "id": 6076,
      "jozz": 30,
      "page": 596,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 18,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "الذي يؤتي ماله يتزكى"
    },
    {
      "id": 6077,
      "jozz": 30,
      "page": 596,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وما لأحد عنده من نعمة تجزى"
    },
    {
      "id": 6078,
      "jozz": 30,
      "page": 596,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 20,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إلا ابتغاء وجه ربه الأعلى"
    },
    {
      "id": 6079,
      "jozz": 30,
      "page": 596,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 21,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ولسوف يرضى"
    }
  ]
}