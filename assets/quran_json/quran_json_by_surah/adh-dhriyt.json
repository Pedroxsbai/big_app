{
  "metadata": {
    "sura_no": 51,
    "sura_name_en": "Adh-Dhāriyāt",
    "sura_name_ar": "الذَّاريَات",
    "total_verses": 60,
    "created_at": "2025-10-11T18:45:17.941Z"
  },
  "verses": [
    {
      "id": 4676,
      "jozz": 26,
      "page": 520,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والذاريات ذروا"
    },
    {
      "id": 4677,
      "jozz": 26,
      "page": 520,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالحاملات وقرا"
    },
    {
      "id": 4678,
      "jozz": 26,
      "page": 520,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالجاريات يسرا"
    },
    {
      "id": 4679,
      "jozz": 26,
      "page": 520,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 4,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالمقسمات أمرا"
    },
    {
      "id": 4680,
      "jozz": 26,
      "page": 520,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنما توعدون لصادق"
    },
    {
      "id": 4681,
      "jozz": 26,
      "page": 520,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 6,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن الدين لواقع"
    },
    {
      "id": 4682,
      "jozz": 26,
      "page": 521,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والسماء ذات الحبك"
    },
    {
      "id": 4683,
      "jozz": 26,
      "page": 521,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 8,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنكم لفي قول مختلف"
    },
    {
      "id": 4684,
      "jozz": 26,
      "page": 521,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 9,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "يؤفك عنه من أفك"
    },
    {
      "id": 4685,
      "jozz": 26,
      "page": 521,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 10,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قتل الخراصون"
    },
    {
      "id": 4686,
      "jozz": 26,
      "page": 521,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين هم في غمرة ساهون"
    },
    {
      "id": 4687,
      "jozz": 26,
      "page": 521,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يسألون أيان يوم الدين"
    },
    {
      "id": 4688,
      "jozz": 26,
      "page": 521,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 13,
      "aya_text": "‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم هم على النار يفتنون"
    },
    {
      "id": 4689,
      "jozz": 26,
      "page": 521,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذوقوا فتنتكم هذا الذي كنتم به تستعجلون"
    },
    {
      "id": 4690,
      "jozz": 26,
      "page": 521,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 15,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن المتقين في جنات وعيون"
    },
    {
      "id": 4691,
      "jozz": 26,
      "page": 521,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "آخذين ما آتاهم ربهم إنهم كانوا قبل ذلك محسنين"
    },
    {
      "id": 4692,
      "jozz": 26,
      "page": 521,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 17,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كانوا قليلا من الليل ما يهجعون"
    },
    {
      "id": 4693,
      "jozz": 26,
      "page": 521,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 18,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وبالأسحار هم يستغفرون"
    },
    {
      "id": 4694,
      "jozz": 26,
      "page": 521,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 19,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وفي أموالهم حق للسائل والمحروم"
    },
    {
      "id": 4695,
      "jozz": 26,
      "page": 521,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 20,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وفي الأرض آيات للموقنين"
    },
    {
      "id": 4696,
      "jozz": 26,
      "page": 521,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 21,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وفي أنفسكم أفلا تبصرون"
    },
    {
      "id": 4697,
      "jozz": 26,
      "page": 521,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 22,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وفي السماء رزقكم وما توعدون"
    },
    {
      "id": 4698,
      "jozz": 26,
      "page": 521,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 23,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فورب السماء والأرض إنه لحق مثل ما أنكم تنطقون"
    },
    {
      "id": 4699,
      "jozz": 26,
      "page": 521,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 24,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هل أتاك حديث ضيف إبراهيم المكرمين"
    },
    {
      "id": 4700,
      "jozz": 26,
      "page": 521,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 25,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ دخلوا عليه فقالوا سلاما قال سلام قوم منكرون"
    },
    {
      "id": 4701,
      "jozz": 26,
      "page": 521,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 26,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فراغ إلى أهله فجاء بعجل سمين"
    },
    {
      "id": 4702,
      "jozz": 26,
      "page": 521,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 27,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فقربه إليهم قال ألا تأكلون"
    },
    {
      "id": 4703,
      "jozz": 26,
      "page": 521,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 28,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأوجس منهم خيفة قالوا لا تخف وبشروه بغلام عليم"
    },
    {
      "id": 4704,
      "jozz": 26,
      "page": 521,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 29,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأقبلت امرأته في صرة فصكت وجهها وقالت عجوز عقيم"
    },
    {
      "id": 4705,
      "jozz": 26,
      "page": 521,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 30,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا كذلك قال ربك إنه هو الحكيم العليم"
    },
    {
      "id": 4706,
      "jozz": 27,
      "page": 522,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 31,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال فما خطبكم أيها المرسلون"
    },
    {
      "id": 4707,
      "jozz": 27,
      "page": 522,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 32,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا إنا أرسلنا إلى قوم مجرمين"
    },
    {
      "id": 4708,
      "jozz": 27,
      "page": 522,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 33,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏",
      "aya_text_emlaey": "لنرسل عليهم حجارة من طين"
    },
    {
      "id": 4709,
      "jozz": 27,
      "page": 522,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 34,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "مسومة عند ربك للمسرفين"
    },
    {
      "id": 4710,
      "jozz": 27,
      "page": 522,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 35,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأخرجنا من كان فيها من المؤمنين"
    },
    {
      "id": 4711,
      "jozz": 27,
      "page": 522,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 36,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما وجدنا فيها غير بيت من المسلمين"
    },
    {
      "id": 4712,
      "jozz": 27,
      "page": 522,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 37,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وتركنا فيها آية للذين يخافون العذاب الأليم"
    },
    {
      "id": 4713,
      "jozz": 27,
      "page": 522,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 38,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وفي موسى إذ أرسلناه إلى فرعون بسلطان مبين"
    },
    {
      "id": 4714,
      "jozz": 27,
      "page": 522,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 39,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فتولى بركنه وقال ساحر أو مجنون"
    },
    {
      "id": 4715,
      "jozz": 27,
      "page": 522,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 40,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأخذناه وجنوده فنبذناهم في اليم وهو مليم"
    },
    {
      "id": 4716,
      "jozz": 27,
      "page": 522,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 41,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وفي عاد إذ أرسلنا عليهم الريح العقيم"
    },
    {
      "id": 4717,
      "jozz": 27,
      "page": 522,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 42,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما تذر من شيء أتت عليه إلا جعلته كالرميم"
    },
    {
      "id": 4718,
      "jozz": 27,
      "page": 522,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 43,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏",
      "aya_text_emlaey": "وفي ثمود إذ قيل لهم تمتعوا حتى حين"
    },
    {
      "id": 4719,
      "jozz": 27,
      "page": 522,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 44,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فعتوا عن أمر ربهم فأخذتهم الصاعقة وهم ينظرون"
    },
    {
      "id": 4720,
      "jozz": 27,
      "page": 522,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 45,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما استطاعوا من قيام وما كانوا منتصرين"
    },
    {
      "id": 4721,
      "jozz": 27,
      "page": 522,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 46,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وقوم نوح من قبل إنهم كانوا قوما فاسقين"
    },
    {
      "id": 4722,
      "jozz": 27,
      "page": 522,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 47,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والسماء بنيناها بأيد وإنا لموسعون"
    },
    {
      "id": 4723,
      "jozz": 27,
      "page": 522,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 48,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والأرض فرشناها فنعم الماهدون"
    },
    {
      "id": 4724,
      "jozz": 27,
      "page": 522,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 49,
      "aya_text": "‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن كل شيء خلقنا زوجين لعلكم تذكرون"
    },
    {
      "id": 4725,
      "jozz": 27,
      "page": 522,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 50,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ففروا إلى الله إني لكم منه نذير مبين"
    },
    {
      "id": 4726,
      "jozz": 27,
      "page": 522,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 51,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ولا تجعلوا مع الله إلها آخر إني لكم منه نذير مبين"
    },
    {
      "id": 4727,
      "jozz": 27,
      "page": 523,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 52,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "كذلك ما أتى الذين من قبلهم من رسول إلا قالوا ساحر أو مجنون"
    },
    {
      "id": 4728,
      "jozz": 27,
      "page": 523,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 53,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أتواصوا به بل هم قوم طاغون"
    },
    {
      "id": 4729,
      "jozz": 27,
      "page": 523,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 54,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فتول عنهم فما أنت بملوم"
    },
    {
      "id": 4730,
      "jozz": 27,
      "page": 523,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 55,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وذكر فإن الذكرى تنفع المؤمنين"
    },
    {
      "id": 4731,
      "jozz": 27,
      "page": 523,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 56,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما خلقت الجن والإنس إلا ليعبدون"
    },
    {
      "id": 4732,
      "jozz": 27,
      "page": 523,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 57,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما أريد منهم من رزق وما أريد أن يطعمون"
    },
    {
      "id": 4733,
      "jozz": 27,
      "page": 523,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 58,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الله هو الرزاق ذو القوة المتين"
    },
    {
      "id": 4734,
      "jozz": 27,
      "page": 523,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 59,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإن للذين ظلموا ذنوبا مثل ذنوب أصحابهم فلا يستعجلون"
    },
    {
      "id": 4735,
      "jozz": 27,
      "page": 523,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 60,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فويل للذين كفروا من يومهم الذي يوعدون"
    }
  ]
}