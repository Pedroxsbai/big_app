      "jozz": 30,
      "page": 604,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن شر النفاثات في العقد"
    },
    {
      "id": 6230,
      "jozz": 30,
      "page": 604,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 5,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ومن شر حاسد إذا حسد"
