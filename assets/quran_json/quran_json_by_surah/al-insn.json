      "line_end": 4,
      "aya_no": 29,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هذه تذكرة فمن شاء اتخذ إلى ربه سبيلا"
    },
