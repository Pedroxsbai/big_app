{
  "metadata": {
    "sura_no": 82,
    "sura_name_en": "Al-Infiṭār",
    "sura_name_ar": "الانفِطَار",
    "total_verses": 19,
    "created_at": "2025-10-11T18:45:17.973Z"
  },
  "verses": [
    {
      "id": 5830,
      "jozz": 30,
      "page": 587,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذا السماء انفطرت"
    },
    {
      "id": 5831,
      "jozz": 30,
      "page": 587,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا الكواكب انتثرت"
    },
    {
      "id": 5832,
      "jozz": 30,
      "page": 587,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا البحار فجرت"
    },
    {
      "id": 5833,
      "jozz": 30,
      "page": 587,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا القبور بعثرت"
    },
    {
      "id": 5834,
      "jozz": 30,
      "page": 587,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "علمت نفس ما قدمت وأخرت"
    },
    {
      "id": 5835,
      "jozz": 30,
      "page": 587,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأيها الإنسان ما غرك بربك الكريم"
    },
    {
      "id": 5836,
      "jozz": 30,
      "page": 587,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذي خلقك فسواك فعدلك"
    },
    {
      "id": 5837,
      "jozz": 30,
      "page": 587,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 8,
      "aya_text": "‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "في أي صورة ما شاء ركبك"
    },
    {
      "id": 5838,
      "jozz": 30,
      "page": 587,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 9,
      "aya_text": "‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا بل تكذبون بالدين"
    },
    {
      "id": 5839,
      "jozz": 30,
      "page": 587,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 10,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن عليكم لحافظين"
    },
    {
      "id": 5840,
      "jozz": 30,
      "page": 587,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "كراما كاتبين"
    },
    {
      "id": 5841,
      "jozz": 30,
      "page": 587,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يعلمون ما تفعلون"
    },
    {
      "id": 5842,
      "jozz": 30,
      "page": 587,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 13,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الأبرار لفي نعيم"
    },
    {
      "id": 5843,
      "jozz": 30,
      "page": 587,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 14,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن الفجار لفي جحيم"
    },
    {
      "id": 5844,
      "jozz": 30,
      "page": 587,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يصلونها يوم الدين"
    },
    {
      "id": 5845,
      "jozz": 30,
      "page": 587,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 16,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما هم عنها بغائبين"
    },
    {
      "id": 5846,
      "jozz": 30,
      "page": 587,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 17,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أدراك ما يوم الدين"
    },
    {
      "id": 5847,
      "jozz": 30,
      "page": 587,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 18,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم ما أدراك ما يوم الدين"
    },
    {
      "id": 5848,
      "jozz": 30,
      "page": 587,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏",
      "aya_text_emlaey": "يوم لا تملك نفس لنفس شيئا والأمر يومئذ لله"
    }
  ]
}