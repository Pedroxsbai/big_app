    "sura_name_en": "Al-Kahf",
    "sura_name_ar": "الكَهف",
    "total_verses": 110,
    "created_at": "2025-10-11T18:45:17.895Z"
  },
  "verses": [
    {
      "id": 2141,
      "jozz": 15,
      "page": 293,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 1,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "الحمد لله الذي أنزل على عبده الكتاب ولم يجعل له عوجا"
    },
    {
      "id": 2142,
      "jozz": 15,
      "page": 293,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 2,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قيما لينذر بأسا شديدا من لدنه ويبشر المؤمنين الذين يعملون الصالحات أن لهم أجرا حسنا"
    },
    {
      "id": 2143,
      "jozz": 15,
      "page": 293,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 3,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ماكثين فيه أبدا"
    },
    {
      "id": 2144,
      "jozz": 15,
      "page": 293,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 4,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وينذر الذين قالوا اتخذ الله ولدا"
    },
    {
      "id": 2145,
      "jozz": 15,
      "page": 294,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 5,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ما لهم به من علم ولا لآبائهم كبرت كلمة تخرج من أفواههم إن يقولون إلا كذبا"
    },
    {
      "id": 2146,
      "jozz": 15,
      "page": 294,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فلعلك باخع نفسك على آثارهم إن لم يؤمنوا بهذا الحديث أسفا"
    },
    {
      "id": 2147,
      "jozz": 15,
      "page": 294,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إنا جعلنا ما على الأرض زينة لها لنبلوهم أيهم أحسن عملا"
    },
    {
      "id": 2148,
      "jozz": 15,
      "page": 294,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنا لجاعلون ما عليها صعيدا جرزا"
    },
    {
      "id": 2149,
      "jozz": 15,
      "page": 294,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 9,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أم حسبت أن أصحاب الكهف والرقيم كانوا من آياتنا عجبا"
    },
    {
      "id": 2150,
      "jozz": 15,
      "page": 294,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 10,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ أوى الفتية إلى الكهف فقالوا ربنا آتنا من لدنك رحمة وهيئ لنا من أمرنا رشدا"
    },
    {
      "id": 2151,
      "jozz": 15,
      "page": 294,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فضربنا على آذانهم في الكهف سنين عددا"
    },
    {
      "id": 2152,
      "jozz": 15,
      "page": 294,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 12,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم بعثناهم لنعلم أي الحزبين أحصى لما لبثوا أمدا"
    },
    {
      "id": 2153,
      "jozz": 15,
      "page": 294,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 13,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "نحن نقص عليك نبأهم بالحق إنهم فتية آمنوا بربهم وزدناهم هدى"
    },
    {
      "id": 2154,
      "jozz": 15,
      "page": 294,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وربطنا على قلوبهم إذ قاموا فقالوا ربنا رب السموات والأرض لن ندعوا من دونه إلها لقد قلنا إذا شططا"
    },
    {
      "id": 2155,
      "jozz": 15,
      "page": 294,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 15,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "هؤلاء قومنا اتخذوا من دونه آلهة لولا يأتون عليهم بسلطان بين فمن أظلم ممن افترى على الله كذبا"
    },
    {
      "id": 2156,
      "jozz": 15,
      "page": 295,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 16,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذ اعتزلتموهم وما يعبدون إلا الله فأووا إلى الكهف ينشر لكم ربكم من رحمته ويهيئ لكم من أمركم مرفقا"
    },
    {
      "id": 2157,
      "jozz": 15,
      "page": 295,
      "line_start": 3,
      "line_end": 6,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وترى الشمس إذا طلعت تزاور عن كهفهم ذات اليمين وإذا غربت تقرضهم ذات الشمال وهم في فجوة منه ذلك من آيات الله من يهد الله فهو المهتد ومن يضلل فلن تجد له وليا مرشدا"
    },
    {
      "id": 2158,
      "jozz": 15,
      "page": 295,
      "line_start": 6,
      "line_end": 9,
      "aya_no": 18,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وتحسبهم أيقاظا وهم رقود ونقلبهم ذات اليمين وذات الشمال وكلبهم باسط ذراعيه بالوصيد لو اطلعت عليهم لوليت منهم فرارا ولملئت منهم رعبا"
    },
    {
      "id": 2159,
      "jozz": 15,
      "page": 295,
      "line_start": 9,
      "line_end": 14,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وكذلك بعثناهم ليتساءلوا بينهم قال قائل منهم كم لبثتم قالوا لبثنا يوما أو بعض يوم قالوا ربكم أعلم بما لبثتم فابعثوا أحدكم بورقكم هذه إلى المدينة فلينظر أيها أزكى طعاما فليأتكم برزق منه وليتلطف ولا يشعرن بكم أحدا"
    },
    {
      "id": 2160,
      "jozz": 15,
      "page": 295,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 20,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنهم إن يظهروا عليكم يرجموكم أو يعيدوكم في ملتهم ولن تفلحوا إذا أبدا"
    },
    {
      "id": 2161,
      "jozz": 15,
      "page": 296,
      "line_start": 1,
      "line_end": 4,
      "aya_no": 21,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكذلك أعثرنا عليهم ليعلموا أن وعد الله حق وأن الساعة لا ريب فيها إذ يتنازعون بينهم أمرهم فقالوا ابنوا عليهم بنيانا ربهم أعلم بهم قال الذين غلبوا على أمرهم لنتخذن عليهم مسجدا"
    },
    {
      "id": 2162,
      "jozz": 15,
      "page": 296,
      "line_start": 4,
      "line_end": 8,
      "aya_no": 22,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "سيقولون ثلاثة رابعهم كلبهم ويقولون خمسة سادسهم كلبهم رجما بالغيب ويقولون سبعة وثامنهم كلبهم قل ربي أعلم بعدتهم ما يعلمهم إلا قليل فلا تمار فيهم إلا مراء ظاهرا ولا تستفت فيهم منهم أحدا"
    },
    {
      "id": 2163,
      "jozz": 15,
      "page": 296,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 23,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ولا تقولن لشيء إني فاعل ذلك غدا"
    },
    {
      "id": 2164,
      "jozz": 15,
      "page": 296,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 24,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا أن يشاء الله واذكر ربك إذا نسيت وقل عسى أن يهدين ربي لأقرب من هذا رشدا"
    },
    {
      "id": 2165,
      "jozz": 15,
      "page": 296,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 25,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولبثوا في كهفهم ثلاث مائة سنين وازدادوا تسعا"
    },
    {
      "id": 2166,
      "jozz": 15,
      "page": 296,
      "line_start": 12,
      "line_end": 14,
      "aya_no": 26,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قل الله أعلم بما لبثوا له غيب السموات والأرض أبصر به وأسمع ما لهم من دونه من ولي ولا يشرك في حكمه أحدا"
    },
    {
      "id": 2167,
      "jozz": 15,
      "page": 296,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 27,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "واتل ما أوحي إليك من كتاب ربك لا مبدل لكلماته ولن تجد من دونه ملتحدا"
    },
    {
      "id": 2168,
      "jozz": 15,
      "page": 297,
      "line_start": 1,
      "line_end": 4,
      "aya_no": 28,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "واصبر نفسك مع الذين يدعون ربهم بالغداة والعشي يريدون وجهه ولا تعد عيناك عنهم تريد زينة الحياة الدنيا ولا تطع من أغفلنا قلبه عن ذكرنا واتبع هواه وكان أمره فرطا"
    },
    {
      "id": 2169,
      "jozz": 15,
      "page": 297,
      "line_start": 4,
      "line_end": 7,
      "aya_no": 29,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقل الحق من ربكم فمن شاء فليؤمن ومن شاء فليكفر إنا أعتدنا للظالمين نارا أحاط بهم سرادقها وإن يستغيثوا يغاثوا بماء كالمهل يشوي الوجوه بئس الشراب وساءت مرتفقا"
    },
    {
      "id": 2170,
      "jozz": 15,
      "page": 297,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 30,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين آمنوا وعملوا الصالحات إنا لا نضيع أجر من أحسن عملا"
    },
    {
      "id": 2171,
      "jozz": 15,
      "page": 297,
      "line_start": 8,
      "line_end": 11,
      "aya_no": 31,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أولئك لهم جنات عدن تجري من تحتهم الأنهار يحلون فيها من أساور من ذهب ويلبسون ثيابا خضرا من سندس وإستبرق متكئين فيها على الأرائك نعم الثواب وحسنت مرتفقا"
    },
    {
      "id": 2172,
      "jozz": 15,
      "page": 297,
      "line_start": 11,
      "line_end": 13,
      "aya_no": 32,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "واضرب لهم مثلا رجلين جعلنا لأحدهما جنتين من أعناب وحففناهما بنخل وجعلنا بينهما زرعا"
    },
    {
      "id": 2173,
      "jozz": 15,
      "page": 297,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 33,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "كلتا الجنتين آتت أكلها ولم تظلم منه شيئا وفجرنا خلالهما نهرا"
    },
    {
      "id": 2174,
      "jozz": 15,
      "page": 297,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 34,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وكان له ثمر فقال لصاحبه وهو يحاوره أنا أكثر منك مالا وأعز نفرا"
    },
    {
      "id": 2175,
      "jozz": 15,
      "page": 298,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 35,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ودخل جنته وهو ظالم لنفسه قال ما أظن أن تبيد هذه أبدا"
    },
    {
      "id": 2176,
      "jozz": 15,
      "page": 298,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 36,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أظن الساعة قائمة ولئن رددت إلى ربي لأجدن خيرا منها منقلبا"
    },
    {
      "id": 2177,
      "jozz": 15,
      "page": 298,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 37,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "قال له صاحبه وهو يحاوره أكفرت بالذي خلقك من تراب ثم من نطفة ثم سواك رجلا"
    },
    {
      "id": 2178,
      "jozz": 15,
      "page": 298,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 38,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لكنا هو الله ربي ولا أشرك بربي أحدا"
    },
    {
      "id": 2179,
      "jozz": 15,
      "page": 298,
      "line_start": 5,
      "line_end": 7,
      "aya_no": 39,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولولا إذ دخلت جنتك قلت ما شاء الله لا قوة إلا بالله إن ترن أنا أقل منك مالا وولدا"
    },
    {
      "id": 2180,
      "jozz": 15,
      "page": 298,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 40,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فعسى ربي أن يؤتين خيرا من جنتك ويرسل عليها حسبانا من السماء فتصبح صعيدا زلقا"
    },
    {
      "id": 2181,
      "jozz": 15,
      "page": 298,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 41,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أو يصبح ماؤها غورا فلن تستطيع له طلبا"
    },
    {
      "id": 2182,
      "jozz": 15,
      "page": 298,
      "line_start": 9,
      "line_end": 11,
      "aya_no": 42,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأحيط بثمره فأصبح يقلب كفيه على ما أنفق فيها وهي خاوية على عروشها ويقول ياليتني لم أشرك بربي أحدا"
    },
    {
      "id": 2183,
      "jozz": 15,
      "page": 298,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 43,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولم تكن له فئة ينصرونه من دون الله وما كان منتصرا"
    },
    {
      "id": 2184,
      "jozz": 15,
      "page": 298,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 44,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "هنالك الولاية لله الحق هو خير ثوابا وخير عقبا"
    },
    {
      "id": 2185,
      "jozz": 15,
      "page": 298,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 45,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "واضرب لهم مثل الحياة الدنيا كماء أنزلناه من السماء فاختلط به نبات الأرض فأصبح هشيما تذروه الرياح وكان الله على كل شيء مقتدرا"
    },
    {
      "id": 2186,
      "jozz": 15,
      "page": 299,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 46,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "المال والبنون زينة الحياة الدنيا والباقيات الصالحات خير عند ربك ثوابا وخير أملا"
    },
    {
      "id": 2187,
      "jozz": 15,
      "page": 299,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 47,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ويوم نسير الجبال وترى الأرض بارزة وحشرناهم فلم نغادر منهم أحدا"
    },
    {
      "id": 2188,
      "jozz": 15,
      "page": 299,
      "line_start": 3,
      "line_end": 5,
      "aya_no": 48,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وعرضوا على ربك صفا لقد جئتمونا كما خلقناكم أول مرة بل زعمتم ألن نجعل لكم موعدا"
    },
    {
      "id": 2189,
      "jozz": 15,
      "page": 299,
      "line_start": 5,
      "line_end": 8,
      "aya_no": 49,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ووضع الكتاب فترى المجرمين مشفقين مما فيه ويقولون ياويلتنا مال هذا الكتاب لا يغادر صغيرة ولا كبيرة إلا أحصاها ووجدوا ما عملوا حاضرا ولا يظلم ربك أحدا"
    },
    {
      "id": 2190,
      "jozz": 15,
      "page": 299,
      "line_start": 8,
      "line_end": 11,
      "aya_no": 50,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وإذ قلنا للملائكة اسجدوا لآدم فسجدوا إلا إبليس كان من الجن ففسق عن أمر ربه أفتتخذونه وذريته أولياء من دوني وهم لكم عدو بئس للظالمين بدلا"
    },
    {
      "id": 2191,
      "jozz": 15,
      "page": 299,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 51,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ما أشهدتهم خلق السموات والأرض ولا خلق أنفسهم وما كنت متخذ المضلين عضدا"
    },
    {
      "id": 2192,
      "jozz": 15,
      "page": 299,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 52,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويوم يقول نادوا شركائي الذين زعمتم فدعوهم فلم يستجيبوا لهم وجعلنا بينهم موبقا"
    },
    {
      "id": 2193,
      "jozz": 15,
      "page": 299,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 53,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ورأى المجرمون النار فظنوا أنهم مواقعوها ولم يجدوا عنها مصرفا"
    },
    {
      "id": 2194,
      "jozz": 15,
      "page": 300,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 54,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ولقد صرفنا في هذا القرآن للناس من كل مثل وكان الإنسان أكثر شيء جدلا"
    },
    {
      "id": 2195,
      "jozz": 15,
      "page": 300,
      "line_start": 2,
      "line_end": 4,
      "aya_no": 55,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وما منع الناس أن يؤمنوا إذ جاءهم الهدى ويستغفروا ربهم إلا أن تأتيهم سنة الأولين أو يأتيهم العذاب قبلا"
    },
    {
      "id": 2196,
      "jozz": 15,
      "page": 300,
      "line_start": 4,
      "line_end": 6,
      "aya_no": 56,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما نرسل المرسلين إلا مبشرين ومنذرين ويجادل الذين كفروا بالباطل ليدحضوا به الحق واتخذوا آياتي وما أنذروا هزوا"
    },
    {
      "id": 2197,
      "jozz": 15,
      "page": 300,
      "line_start": 7,
      "line_end": 10,
      "aya_no": 57,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن أظلم ممن ذكر بآيات ربه فأعرض عنها ونسي ما قدمت يداه إنا جعلنا على قلوبهم أكنة أن يفقهوه وفي آذانهم وقرا وإن تدعهم إلى الهدى فلن يهتدوا إذا أبدا"
    },
    {
      "id": 2198,
      "jozz": 15,
      "page": 300,
      "line_start": 10,
      "line_end": 12,
      "aya_no": 58,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وربك الغفور ذو الرحمة لو يؤاخذهم بما كسبوا لعجل لهم العذاب بل لهم موعد لن يجدوا من دونه موئلا"
    },
    {
      "id": 2199,
      "jozz": 15,
      "page": 300,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 59,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وتلك القرى أهلكناهم لما ظلموا وجعلنا لمهلكهم موعدا"
    },
    {
      "id": 2200,
      "jozz": 15,
      "page": 300,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 60,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذ قال موسى لفتاه لا أبرح حتى أبلغ مجمع البحرين أو أمضي حقبا"
    },
    {
      "id": 2201,
      "jozz": 15,
      "page": 300,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 61,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فلما بلغا مجمع بينهما نسيا حوتهما فاتخذ سبيله في البحر سربا"
    },
    {
      "id": 2202,
      "jozz": 15,
      "page": 301,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 62,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فلما جاوزا قال لفتاه آتنا غداءنا لقد لقينا من سفرنا هذا نصبا"
    },
    {
      "id": 2203,
      "jozz": 15,
      "page": 301,
      "line_start": 2,
      "line_end": 4,
      "aya_no": 63,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال أرأيت إذ أوينا إلى الصخرة فإني نسيت الحوت وما أنسانيه إلا الشيطان أن أذكره واتخذ سبيله في البحر عجبا"
    },
    {
      "id": 2204,
      "jozz": 15,
      "page": 301,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 64,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال ذلك ما كنا نبغ فارتدا على آثارهما قصصا"
    },
    {
      "id": 2205,
      "jozz": 15,
      "page": 301,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 65,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فوجدا عبدا من عبادنا آتيناه رحمة من عندنا وعلمناه من لدنا علما"
    },
    {
      "id": 2206,
      "jozz": 15,
      "page": 301,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 66,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال له موسى هل أتبعك على أن تعلمن مما علمت رشدا"
    },
    {
      "id": 2207,
      "jozz": 15,
      "page": 301,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 67,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال إنك لن تستطيع معي صبرا"
    },
    {
      "id": 2208,
      "jozz": 15,
      "page": 301,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 68,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وكيف تصبر على ما لم تحط به خبرا"
    },
    {
      "id": 2209,
      "jozz": 15,
      "page": 301,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 69,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال ستجدني إن شاء الله صابرا ولا أعصي لك أمرا"
    },
    {
      "id": 2210,
      "jozz": 15,
      "page": 301,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 70,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال فإن اتبعتني فلا تسألني عن شيء حتى أحدث لك منه ذكرا"
    },
    {
      "id": 2211,
      "jozz": 15,
      "page": 301,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 71,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فانطلقا حتى إذا ركبا في السفينة خرقها قال أخرقتها لتغرق أهلها لقد جئت شيئا إمرا"
    },
    {
      "id": 2212,
      "jozz": 15,
      "page": 301,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 72,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال ألم أقل إنك لن تستطيع معي صبرا"
    },
    {
      "id": 2213,
      "jozz": 15,
      "page": 301,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 73,
      "aya_text": "‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال لا تؤاخذني بما نسيت ولا ترهقني من أمري عسرا"
    },
    {
      "id": 2214,
      "jozz": 15,
      "page": 301,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 74,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فانطلقا حتى إذا لقيا غلاما فقتله قال أقتلت نفسا زكية بغير نفس لقد جئت شيئا نكرا"
    },
    {
      "id": 2215,
      "jozz": 16,
      "page": 302,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 75,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال ألم أقل لك إنك لن تستطيع معي صبرا"
    },
    {
      "id": 2216,
      "jozz": 16,
      "page": 302,
      "line_start": 1,
      "line_end": 3,
      "aya_no": 76,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال إن سألتك عن شيء بعدها فلا تصاحبني قد بلغت من لدني عذرا"
    },
    {
      "id": 2217,
      "jozz": 16,
      "page": 302,
      "line_start": 3,
      "line_end": 5,
      "aya_no": 77,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فانطلقا حتى إذا أتيا أهل قرية استطعما أهلها فأبوا أن يضيفوهما فوجدا فيها جدارا يريد أن ينقض فأقامه قال لو شئت لتخذت عليه أجرا"
    },
    {
      "id": 2218,
      "jozz": 16,
      "page": 302,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 78,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال هذا فراق بيني وبينك سأنبئك بتأويل ما لم تستطع عليه صبرا"
    },
    {
      "id": 2219,
      "jozz": 16,
      "page": 302,
      "line_start": 6,
      "line_end": 8,
      "aya_no": 79,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أما السفينة فكانت لمساكين يعملون في البحر فأردت أن أعيبها وكان وراءهم ملك يأخذ كل سفينة غصبا"
    },
    {
      "id": 2220,
      "jozz": 16,
      "page": 302,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 80,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما الغلام فكان أبواه مؤمنين فخشينا أن يرهقهما طغيانا وكفرا"
    },
    {
      "id": 2221,
      "jozz": 16,
      "page": 302,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 81,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فأردنا أن يبدلهما ربهما خيرا منه زكاة وأقرب رحما"
    },
    {
      "id": 2222,
      "jozz": 16,
      "page": 302,
      "line_start": 11,
      "line_end": 14,
      "aya_no": 82,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما الجدار فكان لغلامين يتيمين في المدينة وكان تحته كنز لهما وكان أبوهما صالحا فأراد ربك أن يبلغا أشدهما ويستخرجا كنزهما رحمة من ربك وما فعلته عن أمري ذلك تأويل ما لم تسطع عليه صبرا"
    },
    {
      "id": 2223,
      "jozz": 16,
      "page": 302,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 83,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ويسألونك عن ذي القرنين قل سأتلو عليكم منه ذكرا"
    },
    {
      "id": 2224,
      "jozz": 16,
      "page": 303,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 84,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا مكنا له في الأرض وآتيناه من كل شيء سببا"
    },
    {
      "id": 2225,
      "jozz": 16,
      "page": 303,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 85,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأتبع سببا"
    },
    {
      "id": 2226,
      "jozz": 16,
      "page": 303,
      "line_start": 2,
      "line_end": 4,
      "aya_no": 86,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "حتى إذا بلغ مغرب الشمس وجدها تغرب في عين حمئة ووجد عندها قوما قلنا ياذا القرنين إما أن تعذب وإما أن تتخذ فيهم حسنا"
    },
    {
      "id": 2227,
      "jozz": 16,
      "page": 303,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 87,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال أما من ظلم فسوف نعذبه ثم يرد إلى ربه فيعذبه عذابا نكرا"
    },
    {
      "id": 2228,
      "jozz": 16,
      "page": 303,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 88,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما من آمن وعمل صالحا فله جزاء الحسنى وسنقول له من أمرنا يسرا"
    },
    {
      "id": 2229,
      "jozz": 16,
      "page": 303,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 89,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم أتبع سببا"
    },
    {
      "id": 2230,
      "jozz": 16,
      "page": 303,
      "line_start": 6,
      "line_end": 8,
      "aya_no": 90,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "حتى إذا بلغ مطلع الشمس وجدها تطلع على قوم لم نجعل لهم من دونها سترا"
    },
    {
      "id": 2231,
      "jozz": 16,
      "page": 303,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 91,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "كذلك وقد أحطنا بما لديه خبرا"
    },
    {
      "id": 2232,
      "jozz": 16,
      "page": 303,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 92,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم أتبع سببا"
    },
    {
      "id": 2233,
      "jozz": 16,
      "page": 303,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 93,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "حتى إذا بلغ بين السدين وجد من دونهما قوما لا يكادون يفقهون قولا"
    },
    {
      "id": 2234,
      "jozz": 16,
      "page": 303,
      "line_start": 10,
      "line_end": 12,
      "aya_no": 94,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "قالوا ياذا القرنين إن يأجوج ومأجوج مفسدون في الأرض فهل نجعل لك خرجا على أن تجعل بيننا وبينهم سدا"
    },
    {
      "id": 2235,
      "jozz": 16,
      "page": 303,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 95,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال ما مكني فيه ربي خير فأعينوني بقوة أجعل بينكم وبينهم ردما"
    },
    {
      "id": 2236,
      "jozz": 16,
      "page": 303,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 96,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "آتوني زبر الحديد حتى إذا ساوى بين الصدفين قال انفخوا حتى إذا جعله نارا قال آتوني أفرغ عليه قطرا"
    },
    {
      "id": 2237,
      "jozz": 16,
      "page": 303,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 97,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فما اسطاعوا أن يظهروه وما استطاعوا له نقبا"
    },
    {
      "id": 2238,
      "jozz": 16,
      "page": 304,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 98,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "قال هذا رحمة من ربي فإذا جاء وعد ربي جعله دكاء وكان وعد ربي حقا"
    },
    {
      "id": 2239,
      "jozz": 16,
      "page": 304,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 99,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وتركنا بعضهم يومئذ يموج في بعض ونفخ في الصور فجمعناهم جمعا"
    },
    {
      "id": 2240,
      "jozz": 16,
      "page": 304,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 100,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وعرضنا جهنم يومئذ للكافرين عرضا"
    },
    {
      "id": 2241,
      "jozz": 16,
      "page": 304,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 101,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين كانت أعينهم في غطاء عن ذكري وكانوا لا يستطيعون سمعا"
    },
    {
      "id": 2242,
      "jozz": 16,
      "page": 304,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 102,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أفحسب الذين كفروا أن يتخذوا عبادي من دوني أولياء إنا أعتدنا جهنم للكافرين نزلا"
    },
    {
      "id": 2243,
      "jozz": 16,
      "page": 304,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 103,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قل هل ننبئكم بالأخسرين أعمالا"
    },
    {
      "id": 2244,
      "jozz": 16,
      "page": 304,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 104,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين ضل سعيهم في الحياة الدنيا وهم يحسبون أنهم يحسنون صنعا"
    },
    {
      "id": 2245,
      "jozz": 16,
      "page": 304,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 105,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أولئك الذين كفروا بآيات ربهم ولقائه فحبطت أعمالهم فلا نقيم لهم يوم القيامة وزنا"
    },
    {
      "id": 2246,
      "jozz": 16,
      "page": 304,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 106,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذلك جزاؤهم جهنم بما كفروا واتخذوا آياتي ورسلي هزوا"
    },
    {
      "id": 2247,
      "jozz": 16,
      "page": 304,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 107,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين آمنوا وعملوا الصالحات كانت لهم جنات الفردوس نزلا"
    },
    {
      "id": 2248,
      "jozz": 16,
      "page": 304,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 108,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "خالدين فيها لا يبغون عنها حولا"
    },
    {
      "id": 2249,
      "jozz": 16,
      "page": 304,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 109,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قل لو كان البحر مدادا لكلمات ربي لنفد البحر قبل أن تنفد كلمات ربي ولو جئنا بمثله مددا"
    },
    {
      "id": 2250,
      "jozz": 16,
      "page": 304,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 110,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قل إنما أنا بشر مثلكم يوحى إلي أنما إلهكم إله واحد فمن كان يرجو لقاء ربه فليعمل عملا صالحا ولا يشرك بعبادة ربه أحدا"
    }
  ]
}