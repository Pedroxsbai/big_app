{
  "metadata": {
    "sura_no": 44,
    "sura_name_en": "Ad-Dukhān",
    "sura_name_ar": "الدُّخان",
    "total_verses": 59,
    "created_at": "2025-10-11T18:45:17.933Z"
  },
  "verses": [
    {
      "id": 4415,
      "jozz": 25,
      "page": 496,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏ ‏",
      "aya_text_emlaey": "حم"
    },
    {
      "id": 4416,
      "jozz": 25,
      "page": 496,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والكتاب المبين"
    },
    {
      "id": 4417,
      "jozz": 25,
      "page": 496,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا أنزلناه في ليلة مباركة إنا كنا منذرين"
    },
    {
      "id": 4418,
      "jozz": 25,
      "page": 496,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 4,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فيها يفرق كل أمر حكيم"
    },
    {
      "id": 4419,
      "jozz": 25,
      "page": 496,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أمرا من عندنا إنا كنا مرسلين"
    },
    {
      "id": 4420,
      "jozz": 25,
      "page": 496,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 6,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "رحمة من ربك إنه هو السميع العليم"
    },
    {
      "id": 4421,
      "jozz": 25,
      "page": 496,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 7,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "رب السموات والأرض وما بينهما إن كنتم موقنين"
    },
    {
      "id": 4422,
      "jozz": 25,
      "page": 496,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 8,
      "aya_text": "‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا إله إلا هو يحيي ويميت ربكم ورب آبائكم الأولين"
    },
    {
      "id": 4423,
      "jozz": 25,
      "page": 496,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 9,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل هم في شك يلعبون"
    },
    {
      "id": 4424,
      "jozz": 25,
      "page": 496,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فارتقب يوم تأتي السماء بدخان مبين"
    },
    {
      "id": 4425,
      "jozz": 25,
      "page": 496,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 11,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "يغشى الناس هذا عذاب أليم"
    },
    {
      "id": 4426,
      "jozz": 25,
      "page": 496,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 12,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ربنا اكشف عنا العذاب إنا مؤمنون"
    },
    {
      "id": 4427,
      "jozz": 25,
      "page": 496,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 13,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أنى لهم الذكرى وقد جاءهم رسول مبين"
    },
    {
      "id": 4428,
      "jozz": 25,
      "page": 496,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 14,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم تولوا عنه وقالوا معلم مجنون"
    },
    {
      "id": 4429,
      "jozz": 25,
      "page": 496,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 15,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا كاشفوا العذاب قليلا إنكم عائدون"
    },
    {
      "id": 4430,
      "jozz": 25,
      "page": 496,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 16,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم نبطش البطشة الكبرى إنا منتقمون"
    },
    {
      "id": 4431,
      "jozz": 25,
      "page": 496,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد فتنا قبلهم قوم فرعون وجاءهم رسول كريم"
    },
    {
      "id": 4432,
      "jozz": 25,
      "page": 496,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 18,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أن أدوا إلي عباد الله إني لكم رسول أمين"
    },
    {
      "id": 4433,
      "jozz": 25,
      "page": 497,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وأن لا تعلوا على الله إني آتيكم بسلطان مبين"
    },
    {
      "id": 4434,
      "jozz": 25,
      "page": 497,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 20,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإني عذت بربي وربكم أن ترجمون"
    },
    {
      "id": 4435,
      "jozz": 25,
      "page": 497,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 21,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن لم تؤمنوا لي فاعتزلون"
    },
    {
      "id": 4436,
      "jozz": 25,
      "page": 497,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 22,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فدعا ربه أن هؤلاء قوم مجرمون"
    },
    {
      "id": 4437,
      "jozz": 25,
      "page": 497,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 23,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأسر بعبادي ليلا إنكم متبعون"
    },
    {
      "id": 4438,
      "jozz": 25,
      "page": 497,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 24,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "واترك البحر رهوا إنهم جند مغرقون"
    },
    {
      "id": 4439,
      "jozz": 25,
      "page": 497,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 25,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كم تركوا من جنات وعيون"
    },
    {
      "id": 4440,
      "jozz": 25,
      "page": 497,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 26,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وزروع ومقام كريم"
    },
    {
      "id": 4441,
      "jozz": 25,
      "page": 497,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 27,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ونعمة كانوا فيها فاكهين"
    },
    {
      "id": 4442,
      "jozz": 25,
      "page": 497,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 28,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذلك وأورثناها قوما آخرين"
    },
    {
      "id": 4443,
      "jozz": 25,
      "page": 497,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 29,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما بكت عليهم السماء والأرض وما كانوا منظرين"
    },
    {
      "id": 4444,
      "jozz": 25,
      "page": 497,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 30,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد نجينا بني إسرائيل من العذاب المهين"
    },
    {
      "id": 4445,
      "jozz": 25,
      "page": 497,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 31,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "من فرعون إنه كان عاليا من المسرفين"
    },
    {
      "id": 4446,
      "jozz": 25,
      "page": 497,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 32,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد اخترناهم على علم على العالمين"
    },
    {
      "id": 4447,
      "jozz": 25,
      "page": 497,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 33,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وآتيناهم من الآيات ما فيه بلاء مبين"
    },
    {
      "id": 4448,
      "jozz": 25,
      "page": 497,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 34,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هؤلاء ليقولون"
    },
    {
      "id": 4449,
      "jozz": 25,
      "page": 497,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 35,
      "aya_text": "‏‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هي إلا موتتنا الأولى وما نحن بمنشرين"
    },
    {
      "id": 4450,
      "jozz": 25,
      "page": 497,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 36,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأتوا بآبائنا إن كنتم صادقين"
    },
    {
      "id": 4451,
      "jozz": 25,
      "page": 497,
      "line_start": 12,
      "line_end": 14,
      "aya_no": 37,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أهم خير أم قوم تبع والذين من قبلهم أهلكناهم إنهم كانوا مجرمين"
    },
    {
      "id": 4452,
      "jozz": 25,
      "page": 497,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 38,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وما خلقنا السموات والأرض وما بينهما لاعبين"
    },
    {
      "id": 4453,
      "jozz": 25,
      "page": 497,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 39,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما خلقناهما إلا بالحق ولكن أكثرهم لا يعلمون"
    },
    {
      "id": 4454,
      "jozz": 25,
      "page": 498,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 40,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن يوم الفصل ميقاتهم أجمعين"
    },
    {
      "id": 4455,
      "jozz": 25,
      "page": 498,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 41,
      "aya_text": "‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم لا يغني مولى عن مولى شيئا ولا هم ينصرون"
    },
    {
      "id": 4456,
      "jozz": 25,
      "page": 498,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 42,
      "aya_text": "‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا من رحم الله إنه هو العزيز الرحيم"
    },
    {
      "id": 4457,
      "jozz": 25,
      "page": 498,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 43,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن شجرة الزقوم"
    },
    {
      "id": 4458,
      "jozz": 25,
      "page": 498,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 44,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "طعام الأثيم"
    },
    {
      "id": 4459,
      "jozz": 25,
      "page": 498,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 45,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كالمهل يغلي في البطون"
    },
    {
      "id": 4460,
      "jozz": 25,
      "page": 498,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 46,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كغلي الحميم"
    },
    {
      "id": 4461,
      "jozz": 25,
      "page": 498,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 47,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "خذوه فاعتلوه إلى سواء الجحيم"
    },
    {
      "id": 4462,
      "jozz": 25,
      "page": 498,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 48,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم صبوا فوق رأسه من عذاب الحميم"
    },
    {
      "id": 4463,
      "jozz": 25,
      "page": 498,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 49,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذق إنك أنت العزيز الكريم"
    },
    {
      "id": 4464,
      "jozz": 25,
      "page": 498,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 50,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هذا ما كنتم به تمترون"
    },
    {
      "id": 4465,
      "jozz": 25,
      "page": 498,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 51,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إن المتقين في مقام أمين"
    },
    {
      "id": 4466,
      "jozz": 25,
      "page": 498,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 52,
      "aya_text": "‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "في جنات وعيون"
    },
    {
      "id": 4467,
      "jozz": 25,
      "page": 498,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 53,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يلبسون من سندس وإستبرق متقابلين"
    },
    {
      "id": 4468,
      "jozz": 25,
      "page": 498,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 54,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "كذلك وزوجناهم بحور عين"
    },
    {
      "id": 4469,
      "jozz": 25,
      "page": 498,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 55,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يدعون فيها بكل فاكهة آمنين"
    },
    {
      "id": 4470,
      "jozz": 25,
      "page": 498,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 56,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يذوقون فيها الموت إلا الموتة الأولى ووقاهم عذاب الجحيم"
    },
    {
      "id": 4471,
      "jozz": 25,
      "page": 498,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 57,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فضلا من ربك ذلك هو الفوز العظيم"
    },
    {
      "id": 4472,
      "jozz": 25,
      "page": 498,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 58,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإنما يسرناه بلسانك لعلهم يتذكرون"
    },
    {
      "id": 4473,
      "jozz": 25,
      "page": 498,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 59,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فارتقب إنهم مرتقبون"
    }
  ]
}