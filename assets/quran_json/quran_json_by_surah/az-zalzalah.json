{
  "metadata": {
    "sura_no": 99,
    "sura_name_en": "Az-Zalzalah",
    "sura_name_ar": "الزَّلزَلة",
    "total_verses": 8,
    "created_at": "2025-10-11T18:45:17.992Z"
  },
  "verses": [
    {
      "id": 6139,
      "jozz": 30,
      "page": 599,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 1,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذا زلزلت الأرض زلزالها"
    },
    {
      "id": 6140,
      "jozz": 30,
      "page": 599,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأخرجت الأرض أثقالها"
    },
    {
      "id": 6141,
      "jozz": 30,
      "page": 599,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 3,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وقال الإنسان ما لها"
    },
    {
      "id": 6142,
      "jozz": 30,
      "page": 599,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 4,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يومئذ تحدث أخبارها"
    },
    {
      "id": 6143,
      "jozz": 30,
      "page": 599,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 5,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "بأن ربك أوحى لها"
    },
    {
      "id": 6144,
      "jozz": 30,
      "page": 599,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يومئذ يصدر الناس أشتاتا ليروا أعمالهم"
    },
    {
      "id": 6145,
      "jozz": 30,
      "page": 599,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فمن يعمل مثقال ذرة خيرا يره"
    },
    {
      "id": 6146,
      "jozz": 30,
      "page": 599,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن يعمل مثقال ذرة شرا يره"
    }
  ]
}