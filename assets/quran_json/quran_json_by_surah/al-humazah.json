  },
  "verses": [
    {
      "id": 6180,
      "jozz": 30,
      "page": 601,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 1,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ويل لكل همزة لمزة"
    },
    {
      "id": 6181,
      "jozz": 30,
      "page": 601,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذي جمع مالا وعدده"
    },
    {
      "id": 6182,
      "jozz": 30,
      "page": 601,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يحسب أن ماله أخلده"
    },
    {
      "id": 6183,
      "jozz": 30,
      "page": 601,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 4,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا لينبذن في الحطمة"
    },
    {
      "id": 6184,
      "jozz": 30,
      "page": 601,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 5,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أدراك ما الحطمة"
    },
    {
      "id": 6185,
      "jozz": 30,
      "page": 601,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 6,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "نار الله الموقدة"
    },
    {
      "id": 6186,
      "jozz": 30,
      "page": 601,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "التي تطلع على الأفئدة"
    },
    {
      "id": 6187,
      "jozz": 30,
      "page": 601,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 8,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنها عليهم مؤصدة"
    },
    {
      "id": 6188,
      "jozz": 30,
      "page": 601,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 9,
      "aya_text": "‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "في عمد ممددة"
    }
  ]
}