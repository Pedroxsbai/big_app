{
  "metadata": {
    "sura_no": 52,
    "sura_name_en": "Aṭ-Ṭūr",
    "sura_name_ar": "الطُّور",
    "total_verses": 49,
    "created_at": "2025-10-11T18:45:17.942Z"
  },
  "verses": [
    {
      "id": 4736,
      "jozz": 27,
      "page": 523,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والطور"
    },
    {
      "id": 4737,
      "jozz": 27,
      "page": 523,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 2,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكتاب مسطور"
    },
    {
      "id": 4738,
      "jozz": 27,
      "page": 523,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 3,
      "aya_text": "‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "في رق منشور"
    },
    {
      "id": 4739,
      "jozz": 27,
      "page": 523,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 4,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والبيت المعمور"
    },
    {
      "id": 4740,
      "jozz": 27,
      "page": 523,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والسقف المرفوع"
    },
    {
      "id": 4741,
      "jozz": 27,
      "page": 523,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والبحر المسجور"
    },
    {
      "id": 4742,
      "jozz": 27,
      "page": 523,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 7,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن عذاب ربك لواقع"
    },
    {
      "id": 4743,
      "jozz": 27,
      "page": 523,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 8,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ما له من دافع"
    },
    {
      "id": 4744,
      "jozz": 27,
      "page": 523,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 9,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم تمور السماء مورا"
    },
    {
      "id": 4745,
      "jozz": 27,
      "page": 523,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وتسير الجبال سيرا"
    },
    {
      "id": 4746,
      "jozz": 27,
      "page": 523,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فويل يومئذ للمكذبين"
    },
    {
      "id": 4747,
      "jozz": 27,
      "page": 523,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 12,
      "aya_text": "‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين هم في خوض يلعبون"
    },
    {
      "id": 4748,
      "jozz": 27,
      "page": 523,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 13,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "يوم يدعون إلى نار جهنم دعا"
    },
    {
      "id": 4749,
      "jozz": 27,
      "page": 523,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هذه النار التي كنتم بها تكذبون"
    },
    {
      "id": 4750,
      "jozz": 27,
      "page": 524,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفسحر هذا أم أنتم لا تبصرون"
    },
    {
      "id": 4751,
      "jozz": 27,
      "page": 524,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "اصلوها فاصبروا أو لا تصبروا سواء عليكم إنما تجزون ما كنتم تعملون"
    },
    {
      "id": 4752,
      "jozz": 27,
      "page": 524,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن المتقين في جنات ونعيم"
    },
    {
      "id": 4753,
      "jozz": 27,
      "page": 524,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 18,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاكهين بما آتاهم ربهم ووقاهم ربهم عذاب الجحيم"
    },
    {
      "id": 4754,
      "jozz": 27,
      "page": 524,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلوا واشربوا هنيئا بما كنتم تعملون"
    },
    {
      "id": 4755,
      "jozz": 27,
      "page": 524,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 20,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "متكئين على سرر مصفوفة وزوجناهم بحور عين"
    },
    {
      "id": 4756,
      "jozz": 27,
      "page": 524,
      "line_start": 6,
      "line_end": 8,
      "aya_no": 21,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "والذين آمنوا واتبعتهم ذريتهم بإيمان ألحقنا بهم ذريتهم وما ألتناهم من عملهم من شيء كل امرئ بما كسب رهين"
    },
    {
      "id": 4757,
      "jozz": 27,
      "page": 524,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 22,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأمددناهم بفاكهة ولحم مما يشتهون"
    },
    {
      "id": 4758,
      "jozz": 27,
      "page": 524,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 23,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يتنازعون فيها كأسا لا لغو فيها ولا تأثيم"
    },
    {
      "id": 4759,
      "jozz": 27,
      "page": 524,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 24,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويطوف عليهم غلمان لهم كأنهم لؤلؤ مكنون"
    },
    {
      "id": 4760,
      "jozz": 27,
      "page": 524,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 25,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأقبل بعضهم على بعض يتساءلون"
    },
    {
      "id": 4761,
      "jozz": 27,
      "page": 524,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 26,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا إنا كنا قبل في أهلنا مشفقين"
    },
    {
      "id": 4762,
      "jozz": 27,
      "page": 524,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 27,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فمن الله علينا ووقانا عذاب السموم"
    },
    {
      "id": 4763,
      "jozz": 27,
      "page": 524,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 28,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا كنا من قبل ندعوه إنه هو البر الرحيم"
    },
    {
      "id": 4764,
      "jozz": 27,
      "page": 524,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 29,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فذكر فما أنت بنعمة ربك بكاهن ولا مجنون"
    },
    {
      "id": 4765,
      "jozz": 27,
      "page": 524,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 30,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم يقولون شاعر نتربص به ريب المنون"
    },
    {
      "id": 4766,
      "jozz": 27,
      "page": 524,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 31,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل تربصوا فإني معكم من المتربصين"
    },
    {
      "id": 4767,
      "jozz": 27,
      "page": 525,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 32,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم تأمرهم أحلامهم بهذا أم هم قوم طاغون"
    },
    {
      "id": 4768,
      "jozz": 27,
      "page": 525,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 33,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم يقولون تقوله بل لا يؤمنون"
    },
    {
      "id": 4769,
      "jozz": 27,
      "page": 525,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 34,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فليأتوا بحديث مثله إن كانوا صادقين"
    },
    {
      "id": 4770,
      "jozz": 27,
      "page": 525,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 35,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم خلقوا من غير شيء أم هم الخالقون"
    },
    {
      "id": 4771,
      "jozz": 27,
      "page": 525,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 36,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم خلقوا السموات والأرض بل لا يوقنون"
    },
    {
      "id": 4772,
      "jozz": 27,
      "page": 525,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 37,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم عندهم خزائن ربك أم هم المصيطرون"
    },
    {
      "id": 4773,
      "jozz": 27,
      "page": 525,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 38,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أم لهم سلم يستمعون فيه فليأت مستمعهم بسلطان مبين"
    },
    {
      "id": 4774,
      "jozz": 27,
      "page": 525,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 39,
      "aya_text": "‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم له البنات ولكم البنون"
    },
    {
      "id": 4775,
      "jozz": 27,
      "page": 525,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 40,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم تسألهم أجرا فهم من مغرم مثقلون"
    },
    {
      "id": 4776,
      "jozz": 27,
      "page": 525,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 41,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم عندهم الغيب فهم يكتبون"
    },
    {
      "id": 4777,
      "jozz": 27,
      "page": 525,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 42,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم يريدون كيدا فالذين كفروا هم المكيدون"
    },
    {
      "id": 4778,
      "jozz": 27,
      "page": 525,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 43,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم لهم إله غير الله سبحان الله عما يشركون"
    },
    {
      "id": 4779,
      "jozz": 27,
      "page": 525,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 44,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن يروا كسفا من السماء ساقطا يقولوا سحاب مركوم"
    },
    {
      "id": 4780,
      "jozz": 27,
      "page": 525,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 45,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فذرهم حتى يلاقوا يومهم الذي فيه يصعقون"
    },
    {
      "id": 4781,
      "jozz": 27,
      "page": 525,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 46,
      "aya_text": "‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم لا يغني عنهم كيدهم شيئا ولا هم ينصرون"
    },
    {
      "id": 4782,
      "jozz": 27,
      "page": 525,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 47,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن للذين ظلموا عذابا دون ذلك ولكن أكثرهم لا يعلمون"
    },
    {
      "id": 4783,
      "jozz": 27,
      "page": 525,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 48,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "واصبر لحكم ربك فإنك بأعيننا وسبح بحمد ربك حين تقوم"
    },
    {
      "id": 4784,
      "jozz": 27,
      "page": 525,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 49,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن الليل فسبحه وإدبار النجوم"
    }
  ]
}