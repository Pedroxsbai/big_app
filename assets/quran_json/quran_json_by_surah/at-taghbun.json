{
  "metadata": {
    "sura_no": 64,
    "sura_name_en": "At-Taghābun",
    "sura_name_ar": "التغَابُن",
    "total_verses": 18,
    "created_at": "2025-10-11T18:45:17.954Z"
  },
  "verses": [
    {
      "id": 5200,
      "jozz": 28,
      "page": 556,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 1,
      "aya_text": "‏‏‏‏ ‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يسبح لله ما في السموات وما في الأرض له الملك وله الحمد وهو على كل شيء قدير"
    },
    {
      "id": 5201,
      "jozz": 28,
      "page": 556,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "هو الذي خلقكم فمنكم كافر ومنكم مؤمن والله بما تعملون بصير"
    },
    {
      "id": 5202,
      "jozz": 28,
      "page": 556,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "خلق السموات والأرض بالحق وصوركم فأحسن صوركم وإليه المصير"
    },
    {
      "id": 5203,
      "jozz": 28,
      "page": 556,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 4,
      "aya_text": "‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يعلم ما في السموات والأرض ويعلم ما تسرون وما تعلنون والله عليم بذات الصدور"
    },
    {
      "id": 5204,
      "jozz": 28,
      "page": 556,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 5,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ألم يأتكم نبأ الذين كفروا من قبل فذاقوا وبال أمرهم ولهم عذاب أليم"
    },
    {
      "id": 5205,
      "jozz": 28,
      "page": 556,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 6,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ذلك بأنه كانت تأتيهم رسلهم بالبينات فقالوا أبشر يهدوننا فكفروا وتولوا واستغنى الله والله غني حميد"
    },
    {
      "id": 5206,
      "jozz": 28,
      "page": 556,
      "line_start": 10,
      "line_end": 12,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "زعم الذين كفروا أن لن يبعثوا قل بلى وربي لتبعثن ثم لتنبؤن بما عملتم وذلك على الله يسير"
    },
    {
      "id": 5207,
      "jozz": 28,
      "page": 556,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 8,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فآمنوا بالله ورسوله والنور الذي أنزلنا والله بما تعملون خبير"
    },
    {
      "id": 5208,
      "jozz": 28,
      "page": 556,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 9,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم يجمعكم ليوم الجمع ذلك يوم التغابن ومن يؤمن بالله ويعمل صالحا يكفر عنه سيئاته ويدخله جنات تجري من تحتها الأنهار خالدين فيها أبدا ذلك الفوز العظيم"
    },
    {
      "id": 5209,
      "jozz": 28,
      "page": 557,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين كفروا وكذبوا بآياتنا أولئك أصحاب النار خالدين فيها وبئس المصير"
    },
    {
      "id": 5210,
      "jozz": 28,
      "page": 557,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 11,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ما أصاب من مصيبة إلا بإذن الله ومن يؤمن بالله يهد قلبه والله بكل شيء عليم"
    },
    {
      "id": 5211,
      "jozz": 28,
      "page": 557,
      "line_start": 4,
      "line_end": 6,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأطيعوا الله وأطيعوا الرسول فإن توليتم فإنما على رسولنا البلاغ المبين"
    },
    {
      "id": 5212,
      "jozz": 28,
      "page": 557,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 13,
      "aya_text": "‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الله لا إله إلا هو وعلى الله فليتوكل المؤمنون"
    },
    {
      "id": 5213,
      "jozz": 28,
      "page": 557,
      "line_start": 7,
      "line_end": 9,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأيها الذين آمنوا إن من أزواجكم وأولادكم عدوا لكم فاحذروهم وإن تعفوا وتصفحوا وتغفروا فإن الله غفور رحيم"
    },
    {
      "id": 5214,
      "jozz": 28,
      "page": 557,
      "line_start": 9,
      "line_end": 11,
      "aya_no": 15,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنما أموالكم وأولادكم فتنة والله عنده أجر عظيم"
    },
    {
      "id": 5215,
      "jozz": 28,
      "page": 557,
      "line_start": 11,
      "line_end": 13,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاتقوا الله ما استطعتم واسمعوا وأطيعوا وأنفقوا خيرا لأنفسكم ومن يوق شح نفسه فأولئك هم المفلحون"
    },
    {
      "id": 5216,
      "jozz": 28,
      "page": 557,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن تقرضوا الله قرضا حسنا يضاعفه لكم ويغفر لكم والله شكور حليم"
    },
    {
      "id": 5217,
      "jozz": 28,
      "page": 557,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 18,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عالم الغيب والشهادة العزيز الحكيم"
    }
  ]
}