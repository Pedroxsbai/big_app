{
  "metadata": {
    "sura_no": 54,
    "sura_name_en": "Al-Qamar",
    "sura_name_ar": "القَمَر",
    "total_verses": 55,
    "created_at": "2025-10-11T18:45:17.944Z"
  },
  "verses": [
    {
      "id": 4847,
      "jozz": 27,
      "page": 528,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "اقتربت الساعة وانشق القمر"
    },
    {
      "id": 4848,
      "jozz": 27,
      "page": 528,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن يروا آية يعرضوا ويقولوا سحر مستمر"
    },
    {
      "id": 4849,
      "jozz": 27,
      "page": 528,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكذبوا واتبعوا أهواءهم وكل أمر مستقر"
    },
    {
      "id": 4850,
      "jozz": 27,
      "page": 528,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 4,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد جاءهم من الأنباء ما فيه مزدجر"
    },
    {
      "id": 4851,
      "jozz": 27,
      "page": 528,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "حكمة بالغة فما تغن النذر"
    },
    {
      "id": 4852,
      "jozz": 27,
      "page": 528,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فتول عنهم يوم يدع الداع إلى شيء نكر"
    },
    {
      "id": 4853,
      "jozz": 27,
      "page": 529,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 7,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "خشعا أبصارهم يخرجون من الأجداث كأنهم جراد منتشر"
    },
    {
      "id": 4854,
      "jozz": 27,
      "page": 529,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 8,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "مهطعين إلى الداع يقول الكافرون هذا يوم عسر"
    },
    {
      "id": 4855,
      "jozz": 27,
      "page": 529,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذبت قبلهم قوم نوح فكذبوا عبدنا وقالوا مجنون وازدجر"
    },
    {
      "id": 4856,
      "jozz": 27,
      "page": 529,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 10,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فدعا ربه أني مغلوب فانتصر"
    },
    {
      "id": 4857,
      "jozz": 27,
      "page": 529,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ففتحنا أبواب السماء بماء منهمر"
    },
    {
      "id": 4858,
      "jozz": 27,
      "page": 529,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وفجرنا الأرض عيونا فالتقى الماء على أمر قد قدر"
    },
    {
      "id": 4859,
      "jozz": 27,
      "page": 529,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 13,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وحملناه على ذات ألواح ودسر"
    },
    {
      "id": 4860,
      "jozz": 27,
      "page": 529,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "تجري بأعيننا جزاء لمن كان كفر"
    },
    {
      "id": 4861,
      "jozz": 27,
      "page": 529,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 15,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد تركناها آية فهل من مدكر"
    },
    {
      "id": 4862,
      "jozz": 27,
      "page": 529,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 16,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فكيف كان عذابي ونذر"
    },
    {
      "id": 4863,
      "jozz": 27,
      "page": 529,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 17,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد يسرنا القرآن للذكر فهل من مدكر"
    },
    {
      "id": 4864,
      "jozz": 27,
      "page": 529,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 18,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "كذبت عاد فكيف كان عذابي ونذر"
    },
    {
      "id": 4865,
      "jozz": 27,
      "page": 529,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا أرسلنا عليهم ريحا صرصرا في يوم نحس مستمر"
    },
    {
      "id": 4866,
      "jozz": 27,
      "page": 529,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 20,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "تنزع الناس كأنهم أعجاز نخل منقعر"
    },
    {
      "id": 4867,
      "jozz": 27,
      "page": 529,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 21,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فكيف كان عذابي ونذر"
    },
    {
      "id": 4868,
      "jozz": 27,
      "page": 529,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 22,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد يسرنا القرآن للذكر فهل من مدكر"
    },
    {
      "id": 4869,
      "jozz": 27,
      "page": 529,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 23,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذبت ثمود بالنذر"
    },
    {
      "id": 4870,
      "jozz": 27,
      "page": 529,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 24,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فقالوا أبشرا منا واحدا نتبعه إنا إذا لفي ضلال وسعر"
    },
    {
      "id": 4871,
      "jozz": 27,
      "page": 529,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 25,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أؤلقي الذكر عليه من بيننا بل هو كذاب أشر"
    },
    {
      "id": 4872,
      "jozz": 27,
      "page": 529,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 26,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "سيعلمون غدا من الكذاب الأشر"
    },
    {
      "id": 4873,
      "jozz": 27,
      "page": 529,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 27,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا مرسلوا الناقة فتنة لهم فارتقبهم واصطبر"
    },
    {
      "id": 4874,
      "jozz": 27,
      "page": 530,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 28,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ونبئهم أن الماء قسمة بينهم كل شرب محتضر"
    },
    {
      "id": 4875,
      "jozz": 27,
      "page": 530,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 29,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فنادوا صاحبهم فتعاطى فعقر"
    },
    {
      "id": 4876,
      "jozz": 27,
      "page": 530,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 30,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فكيف كان عذابي ونذر"
    },
    {
      "id": 4877,
      "jozz": 27,
      "page": 530,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 31,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا أرسلنا عليهم صيحة واحدة فكانوا كهشيم المحتظر"
    },
    {
      "id": 4878,
      "jozz": 27,
      "page": 530,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 32,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد يسرنا القرآن للذكر فهل من مدكر"
    },
    {
      "id": 4879,
      "jozz": 27,
      "page": 530,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 33,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذبت قوم لوط بالنذر"
    },
    {
      "id": 4880,
      "jozz": 27,
      "page": 530,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 34,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا أرسلنا عليهم حاصبا إلا آل لوط نجيناهم بسحر"
    },
    {
      "id": 4881,
      "jozz": 27,
      "page": 530,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 35,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "نعمة من عندنا كذلك نجزي من شكر"
    },
    {
      "id": 4882,
      "jozz": 27,
      "page": 530,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 36,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد أنذرهم بطشتنا فتماروا بالنذر"
    },
    {
      "id": 4883,
      "jozz": 27,
      "page": 530,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 37,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد راودوه عن ضيفه فطمسنا أعينهم فذوقوا عذابي ونذر"
    },
    {
      "id": 4884,
      "jozz": 27,
      "page": 530,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 38,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد صبحهم بكرة عذاب مستقر"
    },
    {
      "id": 4885,
      "jozz": 27,
      "page": 530,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 39,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فذوقوا عذابي ونذر"
    },
    {
      "id": 4886,
      "jozz": 27,
      "page": 530,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 40,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد يسرنا القرآن للذكر فهل من مدكر"
    },
    {
      "id": 4887,
      "jozz": 27,
      "page": 530,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 41,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد جاء آل فرعون النذر"
    },
    {
      "id": 4888,
      "jozz": 27,
      "page": 530,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 42,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذبوا بآياتنا كلها فأخذناهم أخذ عزيز مقتدر"
    },
    {
      "id": 4889,
      "jozz": 27,
      "page": 530,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 43,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أكفاركم خير من أولئكم أم لكم براءة في الزبر"
    },
    {
      "id": 4890,
      "jozz": 27,
      "page": 530,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 44,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم يقولون نحن جميع منتصر"
    },
    {
      "id": 4891,
      "jozz": 27,
      "page": 530,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 45,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "سيهزم الجمع ويولون الدبر"
    },
    {
      "id": 4892,
      "jozz": 27,
      "page": 530,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 46,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "بل الساعة موعدهم والساعة أدهى وأمر"
    },
    {
      "id": 4893,
      "jozz": 27,
      "page": 530,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 47,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن المجرمين في ضلال وسعر"
    },
    {
      "id": 4894,
      "jozz": 27,
      "page": 530,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 48,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "يوم يسحبون في النار على وجوههم ذوقوا مس سقر"
    },
    {
      "id": 4895,
      "jozz": 27,
      "page": 530,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 49,
      "aya_text": "‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا كل شيء خلقناه بقدر"
    },
    {
      "id": 4896,
      "jozz": 27,
      "page": 531,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 50,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أمرنا إلا واحدة كلمح بالبصر"
    },
    {
      "id": 4897,
      "jozz": 27,
      "page": 531,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 51,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد أهلكنا أشياعكم فهل من مدكر"
    },
    {
      "id": 4898,
      "jozz": 27,
      "page": 531,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 52,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكل شيء فعلوه في الزبر"
    },
    {
      "id": 4899,
      "jozz": 27,
      "page": 531,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 53,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكل صغير وكبير مستطر"
    },
    {
      "id": 4900,
      "jozz": 27,
      "page": 531,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 54,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن المتقين في جنات ونهر"
    },
    {
      "id": 4901,
      "jozz": 27,
      "page": 531,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 55,
      "aya_text": "‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "في مقعد صدق عند مليك مقتدر"
    }
  ]
}