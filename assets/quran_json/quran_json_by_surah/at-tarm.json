      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وضرب الله مثلا للذين آمنوا امرأة فرعون إذ قالت رب ابن لي عندك بيتا في الجنة ونجني من فرعون وعمله ونجني من القوم الظالمين"
    },
