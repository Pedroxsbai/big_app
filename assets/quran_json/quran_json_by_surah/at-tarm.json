      "line_end": 15,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأيها الذين كفروا لا تعتذروا اليوم إنما تجزون ما كنتم تعملون"
    },
