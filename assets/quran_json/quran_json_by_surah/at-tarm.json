      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأيها النبي لم تحرم ما أحل الله لك تبتغي مرضات أزواجك والله غفور رحيم"
    },
    {
      "id": 5231,
      "jozz": 28,
      "page": 560,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قد فرض الله لكم تحلة أيمانكم والله مولاكم وهو العليم الحكيم"
    },
    {
      "id": 5232,
      "jozz": 28,
      "page": 560,
      "line_start": 5,
      "line_end": 7,
      "aya_no": 3,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذ أسر النبي إلى بعض أزواجه حديثا فلما نبأت به وأظهره الله عليه عرف بعضه وأعرض عن بعض فلما نبأها به قالت من أنبأك هذا قال نبأني العليم الخبير"
    },
    {
      "id": 5233,
      "jozz": 28,
      "page": 560,
      "line_start": 7,
      "line_end": 10,
      "aya_no": 4,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن تتوبا إلى الله فقد صغت قلوبكما وإن تظاهرا عليه فإن الله هو مولاه وجبريل وصالح المؤمنين والملائكة بعد ذلك ظهير"
    },
