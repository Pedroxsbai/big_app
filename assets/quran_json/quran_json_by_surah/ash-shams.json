{
  "metadata": {
    "sura_no": 91,
    "sura_name_en": "Ash-Shams",
    "sura_name_ar": "الشَّمس",
    "total_verses": 15,
    "created_at": "2025-10-11T18:45:17.984Z"
  },
  "verses": [
    {
      "id": 6044,
      "jozz": 30,
      "page": 595,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والشمس وضحاها"
    },
    {
      "id": 6045,
      "jozz": 30,
      "page": 595,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والقمر إذا تلاها"
    },
    {
      "id": 6046,
      "jozz": 30,
      "page": 595,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والنهار إذا جلاها"
    },
    {
      "id": 6047,
      "jozz": 30,
      "page": 595,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 4,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والليل إذا يغشاها"
    },
    {
      "id": 6048,
      "jozz": 30,
      "page": 595,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والسماء وما بناها"
    },
    {
      "id": 6049,
      "jozz": 30,
      "page": 595,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والأرض وما طحاها"
    },
    {
      "id": 6050,
      "jozz": 30,
      "page": 595,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 7,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونفس وما سواها"
    },
    {
      "id": 6051,
      "jozz": 30,
      "page": 595,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 8,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فألهمها فجورها وتقواها"
    },
    {
      "id": 6052,
      "jozz": 30,
      "page": 595,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 9,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قد أفلح من زكاها"
    },
    {
      "id": 6053,
      "jozz": 30,
      "page": 595,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 10,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقد خاب من دساها"
    },
    {
      "id": 6054,
      "jozz": 30,
      "page": 595,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذبت ثمود بطغواها"
    },
    {
      "id": 6055,
      "jozz": 30,
      "page": 595,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 12,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ انبعث أشقاها"
    },
    {
      "id": 6056,
      "jozz": 30,
      "page": 595,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فقال لهم رسول الله ناقة الله وسقياها"
    },
    {
      "id": 6057,
      "jozz": 30,
      "page": 595,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فكذبوه فعقروها فدمدم عليهم ربهم بذنبهم فسواها"
    },
    {
      "id": 6058,
      "jozz": 30,
      "page": 595,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 15,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا يخاف عقباها"
    }
  ]
}