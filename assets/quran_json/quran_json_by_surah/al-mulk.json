      "aya_text": "‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل هو الذي ذرأكم في الأرض وإليه تحشرون"
    },
