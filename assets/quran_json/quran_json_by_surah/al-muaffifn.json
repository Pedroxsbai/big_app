{
  "metadata": {
    "sura_no": 83,
    "sura_name_en": "Al-Muṭaffifīn",
    "sura_name_ar": "المُطَففين",
    "total_verses": 36,
    "created_at": "2025-10-11T18:45:17.974Z"
  },
  "verses": [
    {
      "id": 5849,
      "jozz": 30,
      "page": 587,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 1,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويل للمطففين"
    },
    {
      "id": 5850,
      "jozz": 30,
      "page": 587,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 2,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين إذا اكتالوا على الناس يستوفون"
    },
    {
      "id": 5851,
      "jozz": 30,
      "page": 587,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا كالوهم أو وزنوهم يخسرون"
    },
    {
      "id": 5852,
      "jozz": 30,
      "page": 587,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 4,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألا يظن أولئك أنهم مبعوثون"
    },
    {
      "id": 5853,
      "jozz": 30,
      "page": 588,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 5,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ليوم عظيم"
    },
    {
      "id": 5854,
      "jozz": 30,
      "page": 588,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 6,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم يقوم الناس لرب العالمين"
    },
    {
      "id": 5855,
      "jozz": 30,
      "page": 588,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 7,
      "aya_text": "‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "كلا إن كتاب الفجار لفي سجين"
    },
    {
      "id": 5856,
      "jozz": 30,
      "page": 588,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وما أدراك ما سجين"
    },
    {
      "id": 5857,
      "jozz": 30,
      "page": 588,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 9,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كتاب مرقوم"
    },
    {
      "id": 5858,
      "jozz": 30,
      "page": 588,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 10,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويل يومئذ للمكذبين"
    },
    {
      "id": 5859,
      "jozz": 30,
      "page": 588,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين يكذبون بيوم الدين"
    },
    {
      "id": 5860,
      "jozz": 30,
      "page": 588,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 12,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وما يكذب به إلا كل معتد أثيم"
    },
    {
      "id": 5861,
      "jozz": 30,
      "page": 588,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 13,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذا تتلى عليه آياتنا قال أساطير الأولين"
    },
    {
      "id": 5862,
      "jozz": 30,
      "page": 588,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 14,
      "aya_text": "‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا بل ران على قلوبهم ما كانوا يكسبون"
    },
    {
      "id": 5863,
      "jozz": 30,
      "page": 588,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 15,
      "aya_text": "‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا إنهم عن ربهم يومئذ لمحجوبون"
    },
    {
      "id": 5864,
      "jozz": 30,
      "page": 588,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 16,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم إنهم لصالوا الجحيم"
    },
    {
      "id": 5865,
      "jozz": 30,
      "page": 588,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم يقال هذا الذي كنتم به تكذبون"
    },
    {
      "id": 5866,
      "jozz": 30,
      "page": 588,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 18,
      "aya_text": "‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا إن كتاب الأبرار لفي عليين"
    },
    {
      "id": 5867,
      "jozz": 30,
      "page": 588,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أدراك ما عليون"
    },
    {
      "id": 5868,
      "jozz": 30,
      "page": 588,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 20,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كتاب مرقوم"
    },
    {
      "id": 5869,
      "jozz": 30,
      "page": 588,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 21,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يشهده المقربون"
    },
    {
      "id": 5870,
      "jozz": 30,
      "page": 588,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 22,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الأبرار لفي نعيم"
    },
    {
      "id": 5871,
      "jozz": 30,
      "page": 588,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 23,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "على الأرائك ينظرون"
    },
    {
      "id": 5872,
      "jozz": 30,
      "page": 588,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 24,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "تعرف في وجوههم نضرة النعيم"
    },
    {
      "id": 5873,
      "jozz": 30,
      "page": 588,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 25,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يسقون من رحيق مختوم"
    },
    {
      "id": 5874,
      "jozz": 30,
      "page": 588,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 26,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ختامه مسك وفي ذلك فليتنافس المتنافسون"
    },
    {
      "id": 5875,
      "jozz": 30,
      "page": 588,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 27,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومزاجه من تسنيم"
    },
    {
      "id": 5876,
      "jozz": 30,
      "page": 588,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 28,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عينا يشرب بها المقربون"
    },
    {
      "id": 5877,
      "jozz": 30,
      "page": 588,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 29,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين أجرموا كانوا من الذين آمنوا يضحكون"
    },
    {
      "id": 5878,
      "jozz": 30,
      "page": 588,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 30,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا مروا بهم يتغامزون"
    },
    {
      "id": 5879,
      "jozz": 30,
      "page": 588,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 31,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا انقلبوا إلى أهلهم انقلبوا فكهين"
    },
    {
      "id": 5880,
      "jozz": 30,
      "page": 588,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 32,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا رأوهم قالوا إن هؤلاء لضالون"
    },
    {
      "id": 5881,
      "jozz": 30,
      "page": 588,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 33,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أرسلوا عليهم حافظين"
    },
    {
      "id": 5882,
      "jozz": 30,
      "page": 589,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 34,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاليوم الذين آمنوا من الكفار يضحكون"
    },
    {
      "id": 5883,
      "jozz": 30,
      "page": 589,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 35,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "على الأرائك ينظرون"
    },
    {
      "id": 5884,
      "jozz": 30,
      "page": 589,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 36,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هل ثوب الكفار ما كانوا يفعلون"
    }
  ]
}