{
  "metadata": {
    "sura_no": 93,
    "sura_name_en": "Aḍ-Ḍuḥā",
    "sura_name_ar": "الضُّحى",
    "total_verses": 11,
    "created_at": "2025-10-11T18:45:17.986Z"
  },
  "verses": [
    {
      "id": 6080,
      "jozz": 30,
      "page": 596,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والضحى"
    },
    {
      "id": 6081,
      "jozz": 30,
      "page": 596,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 2,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "والليل إذا سجى"
    },
    {
      "id": 6082,
      "jozz": 30,
      "page": 596,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 3,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "ما ودعك ربك وما قلى"
    },
    {
      "id": 6083,
      "jozz": 30,
      "page": 596,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 4,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وللآخرة خير لك من الأولى"
    },
    {
      "id": 6084,
      "jozz": 30,
      "page": 596,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولسوف يعطيك ربك فترضى"
    },
    {
      "id": 6085,
      "jozz": 30,
      "page": 596,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 6,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم يجدك يتيما فآوى"
    },
    {
      "id": 6086,
      "jozz": 30,
      "page": 596,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ووجدك ضالا فهدى"
    },
    {
      "id": 6087,
      "jozz": 30,
      "page": 596,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 8,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ووجدك عائلا فأغنى"
    },
    {
      "id": 6088,
      "jozz": 30,
      "page": 596,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 9,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأما اليتيم فلا تقهر"
    },
    {
      "id": 6089,
      "jozz": 30,
      "page": 596,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 10,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما السائل فلا تنهر"
    },
    {
      "id": 6090,
      "jozz": 30,
      "page": 596,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما بنعمة ربك فحدث"
    }
  ]
}