      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأيها الناس اتقوا ربكم إن زلزلة الساعة شيء عظيم"
    },
    {
      "id": 2597,
      "jozz": 17,
      "page": 332,
      "line_start": 4,
      "line_end": 6,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم ترونها تذهل كل مرضعة عما أرضعت وتضع كل ذات حمل حملها وترى الناس سكارى وما هم بسكارى ولكن عذاب الله شديد"
    },
    {
      "id": 2598,
      "jozz": 17,
      "page": 332,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن الناس من يجادل في الله بغير علم ويتبع كل شيطان مريد"
    },
    {
      "id": 2599,
      "jozz": 17,
      "page": 332,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كتب عليه أنه من تولاه فأنه يضله ويهديه إلى عذاب السعير"
    },
    {
      "id": 2600,
      "jozz": 17,
      "page": 332,
      "line_start": 9,
      "line_end": 15,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأيها الناس إن كنتم في ريب من البعث فإنا خلقناكم من تراب ثم من نطفة ثم من علقة ثم من مضغة مخلقة وغير مخلقة لنبين لكم ونقر في الأرحام ما نشاء إلى أجل مسمى ثم نخرجكم طفلا ثم لتبلغوا أشدكم ومنكم من يتوفى ومنكم من يرد إلى أرذل العمر لكيلا يعلم من بعد علم شيئا وترى الأرض هامدة فإذا أنزلنا عليها الماء اهتزت وربت وأنبتت من كل زوج بهيج"
    },
    {
      "id": 2601,
      "jozz": 17,
      "page": 333,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 6,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ذلك بأن الله هو الحق وأنه يحى الموتى وأنه على كل شيء قدير"
    },
    {
      "id": 2602,
      "jozz": 17,
      "page": 333,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأن الساعة آتية لا ريب فيها وأن الله يبعث من في القبور"
    },
    {
      "id": 2603,
      "jozz": 17,
      "page": 333,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن الناس من يجادل في الله بغير علم ولا هدى ولا كتاب منير"
    },
    {
      "id": 2604,
      "jozz": 17,
      "page": 333,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 9,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثاني عطفه ليضل عن سبيل الله له في الدنيا خزي ونذيقه يوم القيامة عذاب الحريق"
    },
    {
      "id": 2605,
      "jozz": 17,
      "page": 333,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 10,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذلك بما قدمت يداك وأن الله ليس بظلام للعبيد"
    },
    {
      "id": 2606,
      "jozz": 17,
      "page": 333,
      "line_start": 6,
      "line_end": 9,
      "aya_no": 11,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن الناس من يعبد الله على حرف فإن أصابه خير اطمأن به وإن أصابته فتنة انقلب على وجهه خسر الدنيا والآخرة ذلك هو الخسران المبين"
    },
    {
      "id": 2607,
      "jozz": 17,
      "page": 333,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يدعو من دون الله ما لا يضره وما لا ينفعه ذلك هو الضلال البعيد"
    },
    {
      "id": 2608,
      "jozz": 17,
      "page": 333,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 13,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يدعو لمن ضره أقرب من نفعه لبئس المولى ولبئس العشير"
    },
    {
      "id": 2609,
      "jozz": 17,
      "page": 333,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 14,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الله يدخل الذين آمنوا وعملوا الصالحات جنات تجري من تحتها الأنهار إن الله يفعل ما يريد"
    },
    {
      "id": 2610,
      "jozz": 17,
      "page": 333,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 15,
      "aya_text": "‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "من كان يظن أن لن ينصره الله في الدنيا والآخرة فليمدد بسبب إلى السماء ثم ليقطع فلينظر هل يذهبن كيده ما يغيظ"
    },
    {
      "id": 2611,
      "jozz": 17,
      "page": 334,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وكذلك أنزلناه آيات بينات وأن الله يهدي من يريد"
    },
    {
      "id": 2612,
      "jozz": 17,
      "page": 334,
      "line_start": 2,
      "line_end": 4,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين آمنوا والذين هادوا والصابئين والنصارى والمجوس والذين أشركوا إن الله يفصل بينهم يوم القيامة إن الله على كل شيء شهيد"
    },
    {
      "id": 2613,
      "jozz": 17,
      "page": 334,
      "line_start": 4,
      "line_end": 8,
      "aya_no": 18,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏ ‏ ‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم تر أن الله يسجد له من في السموات ومن في الأرض والشمس والقمر والنجوم والجبال والشجر والدواب وكثير من الناس وكثير حق عليه العذاب ومن يهن الله فما له من مكرم إن الله يفعل ما يشاء"
    },
    {
      "id": 2614,
      "jozz": 17,
      "page": 334,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هذان خصمان اختصموا في ربهم فالذين كفروا قطعت لهم ثياب من نار يصب من فوق رءوسهم الحميم"
    },
    {
      "id": 2615,
      "jozz": 17,
      "page": 334,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 20,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يصهر به ما في بطونهم والجلود"
    },
    {
      "id": 2616,
      "jozz": 17,
      "page": 334,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 21,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولهم مقامع من حديد"
    },
    {
      "id": 2617,
      "jozz": 17,
      "page": 334,
      "line_start": 11,
      "line_end": 13,
      "aya_no": 22,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلما أرادوا أن يخرجوا منها من غم أعيدوا فيها وذوقوا عذاب الحريق"
    },
    {
      "id": 2618,
      "jozz": 17,
      "page": 334,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 23,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الله يدخل الذين آمنوا وعملوا الصالحات جنات تجري من تحتها الأنهار يحلون فيها من أساور من ذهب ولؤلؤا ولباسهم فيها حرير"
    },
    {
      "id": 2619,
      "jozz": 17,
      "page": 335,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 24,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وهدوا إلى الطيب من القول وهدوا إلى صراط الحميد"
    },
    {
      "id": 2620,
      "jozz": 17,
      "page": 335,
      "line_start": 2,
      "line_end": 4,
      "aya_no": 25,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين كفروا ويصدون عن سبيل الله والمسجد الحرام الذي جعلناه للناس سواء العاكف فيه والباد ومن يرد فيه بإلحاد بظلم نذقه من عذاب أليم"
    },
    {
      "id": 2621,
      "jozz": 17,
      "page": 335,
      "line_start": 5,
      "line_end": 7,
      "aya_no": 26,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذ بوأنا لإبراهيم مكان البيت أن لا تشرك بي شيئا وطهر بيتي للطائفين والقائمين والركع السجود"
    },
    {
      "id": 2622,
      "jozz": 17,
      "page": 335,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 27,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأذن في الناس بالحج يأتوك رجالا وعلى كل ضامر يأتين من كل فج عميق"
    },
    {
      "id": 2623,
      "jozz": 17,
      "page": 335,
      "line_start": 8,
      "line_end": 11,
      "aya_no": 28,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ليشهدوا منافع لهم ويذكروا اسم الله في أيام معلومات على ما رزقهم من بهيمة الأنعام فكلوا منها وأطعموا البائس الفقير"
    },
    {
      "id": 2624,
      "jozz": 17,
      "page": 335,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 29,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم ليقضوا تفثهم وليوفوا نذورهم وليطوفوا بالبيت العتيق"
    },
    {
      "id": 2625,
      "jozz": 17,
      "page": 335,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 30,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذلك ومن يعظم حرمات الله فهو خير له عند ربه وأحلت لكم الأنعام إلا ما يتلى عليكم فاجتنبوا الرجس من الأوثان واجتنبوا قول الزور"
    },
    {
      "id": 2626,
      "jozz": 17,
      "page": 336,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 31,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "حنفاء لله غير مشركين به ومن يشرك بالله فكأنما خر من السماء فتخطفه الطير أو تهوي به الريح في مكان سحيق"
    },
    {
      "id": 2627,
      "jozz": 17,
      "page": 336,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 32,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذلك ومن يعظم شعائر الله فإنها من تقوى القلوب"
    },
    {
      "id": 2628,
      "jozz": 17,
      "page": 336,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 33,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لكم فيها منافع إلى أجل مسمى ثم محلها إلى البيت العتيق"
    },
    {
      "id": 2629,
      "jozz": 17,
      "page": 336,
      "line_start": 5,
      "line_end": 7,
      "aya_no": 34,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولكل أمة جعلنا منسكا ليذكروا اسم الله على ما رزقهم من بهيمة الأنعام فإلهكم إله واحد فله أسلموا وبشر المخبتين"
    },
    {
      "id": 2630,
      "jozz": 17,
      "page": 336,
      "line_start": 7,
      "line_end": 9,
      "aya_no": 35,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين إذا ذكر الله وجلت قلوبهم والصابرين على ما أصابهم والمقيمي الصلاة ومما رزقناهم ينفقون"
    },
    {
      "id": 2631,
      "jozz": 17,
      "page": 336,
      "line_start": 9,
      "line_end": 12,
      "aya_no": 36,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والبدن جعلناها لكم من شعائر الله لكم فيها خير فاذكروا اسم الله عليها صواف فإذا وجبت جنوبها فكلوا منها وأطعموا القانع والمعتر كذلك سخرناها لكم لعلكم تشكرون"
    },
    {
      "id": 2632,
      "jozz": 17,
      "page": 336,
      "line_start": 12,
      "line_end": 14,
      "aya_no": 37,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لن ينال الله لحومها ولا دماؤها ولكن يناله التقوى منكم كذلك سخرها لكم لتكبروا الله على ما هداكم وبشر المحسنين"
    },
    {
      "id": 2633,
      "jozz": 17,
      "page": 336,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 38,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الله يدافع عن الذين آمنوا إن الله لا يحب كل خوان كفور"
    },
    {
      "id": 2634,
      "jozz": 17,
      "page": 337,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 39,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أذن للذين يقاتلون بأنهم ظلموا وإن الله على نصرهم لقدير"
    },
    {
      "id": 2635,
      "jozz": 17,
      "page": 337,
      "line_start": 2,
      "line_end": 6,
      "aya_no": 40,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين أخرجوا من ديارهم بغير حق إلا أن يقولوا ربنا الله ولولا دفع الله الناس بعضهم ببعض لهدمت صوامع وبيع وصلوات ومساجد يذكر فيها اسم الله كثيرا ولينصرن الله من ينصره إن الله لقوي عزيز"
    },
    {
      "id": 2636,
      "jozz": 17,
      "page": 337,
      "line_start": 6,
      "line_end": 8,
      "aya_no": 41,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين إن مكناهم في الأرض أقاموا الصلاة وآتوا الزكاة وأمروا بالمعروف ونهوا عن المنكر ولله عاقبة الأمور"
    },
    {
      "id": 2637,
      "jozz": 17,
      "page": 337,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 42,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن يكذبوك فقد كذبت قبلهم قوم نوح وعاد وثمود"
    },
    {
      "id": 2638,
      "jozz": 17,
      "page": 337,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 43,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وقوم إبراهيم وقوم لوط"
    },
    {
      "id": 2639,
      "jozz": 17,
      "page": 337,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 44,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأصحاب مدين وكذب موسى فأمليت للكافرين ثم أخذتهم فكيف كان نكير"
    },
    {
      "id": 2640,
      "jozz": 17,
      "page": 337,
      "line_start": 11,
      "line_end": 13,
      "aya_no": 45,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فكأين من قرية أهلكناها وهي ظالمة فهي خاوية على عروشها وبئر معطلة وقصر مشيد"
    },
    {
      "id": 2641,
      "jozz": 17,
      "page": 337,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 46,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفلم يسيروا في الأرض فتكون لهم قلوب يعقلون بها أو آذان يسمعون بها فإنها لا تعمى الأبصار ولكن تعمى القلوب التي في الصدور"
    },
    {
      "id": 2642,
      "jozz": 17,
      "page": 338,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 47,
      "aya_text": "‏‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويستعجلونك بالعذاب ولن يخلف الله وعده وإن يوما عند ربك كألف سنة مما تعدون"
    },
    {
      "id": 2643,
      "jozz": 17,
      "page": 338,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 48,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكأين من قرية أمليت لها وهي ظالمة ثم أخذتها وإلي المصير"
    },
    {
      "id": 2644,
      "jozz": 17,
      "page": 338,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 49,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "قل ياأيها الناس إنما أنا لكم نذير مبين"
    },
    {
      "id": 2645,
      "jozz": 17,
      "page": 338,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 50,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالذين آمنوا وعملوا الصالحات لهم مغفرة ورزق كريم"
    },
    {
      "id": 2646,
      "jozz": 17,
      "page": 338,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 51,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين سعوا في آياتنا معاجزين أولئك أصحاب الجحيم"
    },
    {
      "id": 2647,
      "jozz": 17,
      "page": 338,
      "line_start": 7,
      "line_end": 9,
      "aya_no": 52,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أرسلنا من قبلك من رسول ولا نبي إلا إذا تمنى ألقى الشيطان في أمنيته فينسخ الله ما يلقي الشيطان ثم يحكم الله آياته والله عليم حكيم"
    },
    {
      "id": 2648,
      "jozz": 17,
      "page": 338,
      "line_start": 9,
      "line_end": 11,
      "aya_no": 53,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ليجعل ما يلقي الشيطان فتنة للذين في قلوبهم مرض والقاسية قلوبهم وإن الظالمين لفي شقاق بعيد"
    },
    {
      "id": 2649,
      "jozz": 17,
      "page": 338,
      "line_start": 11,
      "line_end": 14,
      "aya_no": 54,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وليعلم الذين أوتوا العلم أنه الحق من ربك فيؤمنوا به فتخبت له قلوبهم وإن الله لهاد الذين آمنوا إلى صراط مستقيم"
    },
    {
      "id": 2650,
      "jozz": 17,
      "page": 338,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 55,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا يزال الذين كفروا في مرية منه حتى تأتيهم الساعة بغتة أو يأتيهم عذاب يوم عقيم"
    },
    {
      "id": 2651,
      "jozz": 17,
      "page": 339,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 56,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الملك يومئذ لله يحكم بينهم فالذين آمنوا وعملوا الصالحات في جنات النعيم"
    },
    {
      "id": 2652,
      "jozz": 17,
      "page": 339,
      "line_start": 2,
      "line_end": 4,
      "aya_no": 57,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "والذين كفروا وكذبوا بآياتنا فأولئك لهم عذاب مهين"
    },
    {
      "id": 2653,
      "jozz": 17,
      "page": 339,
      "line_start": 4,
      "line_end": 6,
      "aya_no": 58,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين هاجروا في سبيل الله ثم قتلوا أو ماتوا ليرزقنهم الله رزقا حسنا وإن الله لهو خير الرازقين"
    },
    {
      "id": 2654,
      "jozz": 17,
      "page": 339,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 59,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ليدخلنهم مدخلا يرضونه وإن الله لعليم حليم"
    },
    {
      "id": 2655,
      "jozz": 17,
      "page": 339,
      "line_start": 7,
      "line_end": 9,
      "aya_no": 60,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذلك ومن عاقب بمثل ما عوقب به ثم بغي عليه لينصرنه الله إن الله لعفو غفور"
    },
    {
      "id": 2656,
      "jozz": 17,
      "page": 339,
      "line_start": 9,
      "line_end": 11,
      "aya_no": 61,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ذلك بأن الله يولج الليل في النهار ويولج النهار في الليل وأن الله سميع بصير"
    },
    {
      "id": 2657,
      "jozz": 17,
      "page": 339,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 62,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذلك بأن الله هو الحق وأن ما يدعون من دونه هو الباطل وأن الله هو العلي الكبير"
    },
    {
      "id": 2658,
      "jozz": 17,
      "page": 339,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 63,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم تر أن الله أنزل من السماء ماء فتصبح الأرض مخضرة إن الله لطيف خبير"
    },
    {
      "id": 2659,
      "jozz": 17,
      "page": 339,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 64,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "له ما في السموات وما في الأرض وإن الله لهو الغني الحميد"
    },
    {
      "id": 2660,
      "jozz": 17,
      "page": 340,
      "line_start": 1,
      "line_end": 3,
      "aya_no": 65,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم تر أن الله سخر لكم ما في الأرض والفلك تجري في البحر بأمره ويمسك السماء أن تقع على الأرض إلا بإذنه إن الله بالناس لرءوف رحيم"
    },
    {
      "id": 2661,
      "jozz": 17,
      "page": 340,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 66,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وهو الذي أحياكم ثم يميتكم ثم يحييكم إن الإنسان لكفور"
    },
    {
      "id": 2662,
      "jozz": 17,
      "page": 340,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 67,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لكل أمة جعلنا منسكا هم ناسكوه فلا ينازعنك في الأمر وادع إلى ربك إنك لعلى هدى مستقيم"
    },
    {
      "id": 2663,
      "jozz": 17,
      "page": 340,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 68,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن جادلوك فقل الله أعلم بما تعملون"
    },
    {
      "id": 2664,
      "jozz": 17,
      "page": 340,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 69,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الله يحكم بينكم يوم القيامة فيما كنتم فيه تختلفون"
    },
    {
      "id": 2665,
      "jozz": 17,
      "page": 340,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 70,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم تعلم أن الله يعلم ما في السماء والأرض إن ذلك في كتاب إن ذلك على الله يسير"
    },
    {
      "id": 2666,
      "jozz": 17,
      "page": 340,
      "line_start": 10,
      "line_end": 12,
      "aya_no": 71,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ويعبدون من دون الله ما لم ينزل به سلطانا وما ليس لهم به علم وما للظالمين من نصير"
    },
