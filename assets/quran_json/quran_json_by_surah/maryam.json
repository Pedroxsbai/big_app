{
  "metadata": {
    "sura_no": 19,
    "sura_name_en": "Maryam",
    "sura_name_ar": "مَريَم",
    "total_verses": 98,
    "created_at": "2025-10-11T18:45:17.897Z"
  },
  "verses": [
    {
      "id": 2251,
      "jozz": 16,
      "page": 305,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كهيعص"
    },
    {
      "id": 2252,
      "jozz": 16,
      "page": 305,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذكر رحمة ربك عبده زكريا"
    },
    {
      "id": 2253,
      "jozz": 16,
      "page": 305,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 3,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ نادى ربه نداء خفيا"
    },
    {
      "id": 2254,
      "jozz": 16,
      "page": 305,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال رب إني وهن العظم مني واشتعل الرأس شيبا ولم أكن بدعائك رب شقيا"
    },
    {
      "id": 2255,
      "jozz": 16,
      "page": 305,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 5,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏ ‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وإني خفت الموالي من ورائي وكانت امرأتي عاقرا فهب لي من لدنك وليا"
    },
    {
      "id": 2256,
      "jozz": 16,
      "page": 305,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يرثني ويرث من آل يعقوب واجعله رب رضيا"
    },
    {
      "id": 2257,
      "jozz": 16,
      "page": 305,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يازكريا إنا نبشرك بغلام اسمه يحيى لم نجعل له من قبل سميا"
    },
    {
      "id": 2258,
      "jozz": 16,
      "page": 305,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال رب أنى يكون لي غلام وكانت امرأتي عاقرا وقد بلغت من الكبر عتيا"
    },
    {
      "id": 2259,
      "jozz": 16,
      "page": 305,
      "line_start": 11,
      "line_end": 13,
      "aya_no": 9,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "قال كذلك قال ربك هو علي هين وقد خلقتك من قبل ولم تك شيئا"
    },
    {
      "id": 2260,
      "jozz": 16,
      "page": 305,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 10,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال رب اجعل لي آية قال آيتك ألا تكلم الناس ثلاث ليال سويا"
    },
    {
      "id": 2261,
      "jozz": 16,
      "page": 305,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فخرج على قومه من المحراب فأوحى إليهم أن سبحوا بكرة وعشيا"
    },
    {
      "id": 2262,
      "jozz": 16,
      "page": 306,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 12,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يايحيى خذ الكتاب بقوة وآتيناه الحكم صبيا"
    },
    {
      "id": 2263,
      "jozz": 16,
      "page": 306,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 13,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وحنانا من لدنا وزكاة وكان تقيا"
    },
    {
      "id": 2264,
      "jozz": 16,
      "page": 306,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 14,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وبرا بوالديه ولم يكن جبارا عصيا"
    },
    {
      "id": 2265,
      "jozz": 16,
      "page": 306,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 15,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وسلام عليه يوم ولد ويوم يموت ويوم يبعث حيا"
    },
    {
      "id": 2266,
      "jozz": 16,
      "page": 306,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "واذكر في الكتاب مريم إذ انتبذت من أهلها مكانا شرقيا"
    },
    {
      "id": 2267,
      "jozz": 16,
      "page": 306,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فاتخذت من دونهم حجابا فأرسلنا إليها روحنا فتمثل لها بشرا سويا"
    },
    {
      "id": 2268,
      "jozz": 16,
      "page": 306,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 18,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قالت إني أعوذ بالرحمن منك إن كنت تقيا"
    },
    {
      "id": 2269,
      "jozz": 16,
      "page": 306,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال إنما أنا رسول ربك لأهب لك غلاما زكيا"
    },
    {
      "id": 2270,
      "jozz": 16,
      "page": 306,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 20,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قالت أنى يكون لي غلام ولم يمسسني بشر ولم أك بغيا"
    },
    {
      "id": 2271,
      "jozz": 16,
      "page": 306,
      "line_start": 9,
      "line_end": 11,
      "aya_no": 21,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال كذلك قال ربك هو علي هين ولنجعله آية للناس ورحمة منا وكان أمرا مقضيا"
    },
    {
      "id": 2272,
      "jozz": 16,
      "page": 306,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 22,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فحملته فانتبذت به مكانا قصيا"
    },
    {
      "id": 2273,
      "jozz": 16,
      "page": 306,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 23,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأجاءها المخاض إلى جذع النخلة قالت ياليتني مت قبل هذا وكنت نسيا منسيا"
    },
    {
      "id": 2274,
      "jozz": 16,
      "page": 306,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 24,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فناداها من تحتها ألا تحزني قد جعل ربك تحتك سريا"
    },
    {
      "id": 2275,
      "jozz": 16,
      "page": 306,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 25,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وهزي إليك بجذع النخلة تساقط عليك رطبا جنيا"
    },
    {
      "id": 2276,
      "jozz": 16,
      "page": 307,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 26,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فكلي واشربي وقري عينا فإما ترين من البشر أحدا فقولي إني نذرت للرحمن صوما فلن أكلم اليوم إنسيا"
    },
    {
      "id": 2277,
      "jozz": 16,
      "page": 307,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 27,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأتت به قومها تحمله قالوا يامريم لقد جئت شيئا فريا"
    },
    {
      "id": 2278,
      "jozz": 16,
      "page": 307,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 28,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأخت هارون ما كان أبوك امرأ سوء وما كانت أمك بغيا"
    },
    {
      "id": 2279,
      "jozz": 16,
      "page": 307,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 29,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأشارت إليه قالوا كيف نكلم من كان في المهد صبيا"
    },
    {
      "id": 2280,
      "jozz": 16,
      "page": 307,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 30,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال إني عبد الله آتاني الكتاب وجعلني نبيا"
    },
    {
      "id": 2281,
      "jozz": 16,
      "page": 307,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 31,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وجعلني مباركا أين ما كنت ‎وأوصاني بالصلاة والزكاة ما دمت حيا"
    },
    {
      "id": 2282,
      "jozz": 16,
      "page": 307,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 32,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وبرا بوالدتي ولم يجعلني جبارا شقيا"
    },
    {
      "id": 2283,
      "jozz": 16,
      "page": 307,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 33,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "والسلام علي يوم ولدت ويوم أموت ويوم أبعث حيا"
    },
    {
      "id": 2284,
      "jozz": 16,
      "page": 307,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 34,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذلك عيسى ابن مريم قول الحق الذي فيه يمترون"
    },
    {
      "id": 2285,
      "jozz": 16,
      "page": 307,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 35,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما كان لله أن يتخذ من ولد سبحانه إذا قضى أمرا فإنما يقول له كن فيكون"
    },
    {
      "id": 2286,
      "jozz": 16,
      "page": 307,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 36,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن الله ربي وربكم فاعبدوه هذا صراط مستقيم"
    },
    {
      "id": 2287,
      "jozz": 16,
      "page": 307,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 37,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فاختلف الأحزاب من بينهم فويل للذين كفروا من مشهد يوم عظيم"
    },
    {
      "id": 2288,
      "jozz": 16,
      "page": 307,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 38,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أسمع بهم وأبصر يوم يأتوننا لكن الظالمون اليوم في ضلال مبين"
    },
    {
      "id": 2289,
      "jozz": 16,
      "page": 308,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 39,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنذرهم يوم الحسرة إذ قضي الأمر وهم في غفلة وهم لا يؤمنون"
    },
    {
      "id": 2290,
      "jozz": 16,
      "page": 308,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 40,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا نحن نرث الأرض ومن عليها وإلينا يرجعون"
    },
    {
      "id": 2291,
      "jozz": 16,
      "page": 308,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 41,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "واذكر في الكتاب إبراهيم إنه كان صديقا نبيا"
    },
    {
      "id": 2292,
      "jozz": 16,
      "page": 308,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 42,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إذ قال لأبيه ياأبت لم تعبد ما لا يسمع ولا يبصر ولا يغني عنك شيئا"
    },
    {
      "id": 2293,
      "jozz": 16,
      "page": 308,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 43,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأبت إني قد جاءني من العلم ما لم يأتك فاتبعني أهدك صراطا سويا"
    },
    {
      "id": 2294,
      "jozz": 16,
      "page": 308,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 44,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأبت لا تعبد الشيطان إن الشيطان كان للرحمن عصيا"
    },
    {
      "id": 2295,
      "jozz": 16,
      "page": 308,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 45,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ياأبت إني أخاف أن يمسك عذاب من الرحمن فتكون للشيطان وليا"
    },
    {
      "id": 2296,
      "jozz": 16,
      "page": 308,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 46,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال أراغب أنت عن آلهتي ياإبراهيم لئن لم تنته لأرجمنك واهجرني مليا"
    },
    {
      "id": 2297,
      "jozz": 16,
      "page": 308,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 47,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال سلام عليك سأستغفر لك ربي إنه كان بي حفيا"
    },
    {
      "id": 2298,
      "jozz": 16,
      "page": 308,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 48,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأعتزلكم وما تدعون من دون الله وأدعو ربي عسى ألا أكون بدعاء ربي شقيا"
    },
    {
      "id": 2299,
      "jozz": 16,
      "page": 308,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 49,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فلما اعتزلهم وما يعبدون من دون الله وهبنا له إسحاق ويعقوب وكلا جعلنا نبيا"
    },
    {
      "id": 2300,
      "jozz": 16,
      "page": 308,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 50,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ووهبنا لهم من رحمتنا وجعلنا لهم لسان صدق عليا"
    },
    {
      "id": 2301,
      "jozz": 16,
      "page": 308,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 51,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "واذكر في الكتاب موسى إنه كان مخلصا وكان رسولا نبيا"
    },
    {
      "id": 2302,
      "jozz": 16,
      "page": 309,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 52,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وناديناه من جانب الطور الأيمن وقربناه نجيا"
    },
    {
      "id": 2303,
      "jozz": 16,
      "page": 309,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 53,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ووهبنا له من رحمتنا أخاه هارون نبيا"
    },
    {
      "id": 2304,
      "jozz": 16,
      "page": 309,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 54,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "واذكر في الكتاب إسماعيل إنه كان صادق الوعد وكان رسولا نبيا"
    },
    {
      "id": 2305,
      "jozz": 16,
      "page": 309,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 55,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكان يأمر أهله بالصلاة والزكاة وكان عند ربه مرضيا"
    },
    {
      "id": 2306,
      "jozz": 16,
      "page": 309,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 56,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "واذكر في الكتاب إدريس إنه كان صديقا نبيا"
    },
    {
      "id": 2307,
      "jozz": 16,
      "page": 309,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 57,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ورفعناه مكانا عليا"
    },
    {
      "id": 2308,
      "jozz": 16,
      "page": 309,
      "line_start": 5,
      "line_end": 8,
      "aya_no": 58,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أولئك الذين أنعم الله عليهم من النبيين من ذرية آدم وممن حملنا مع نوح ومن ذرية إبراهيم وإسرائيل وممن هدينا واجتبينا إذا تتلى عليهم آيات الرحمن خروا سجدا وبكيا"
    },
    {
      "id": 2309,
      "jozz": 16,
      "page": 309,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 59,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فخلف من بعدهم خلف أضاعوا الصلاة واتبعوا الشهوات فسوف يلقون غيا"
    },
    {
      "id": 2310,
      "jozz": 16,
      "page": 309,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 60,
      "aya_text": "‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إلا من تاب وآمن وعمل صالحا فأولئك يدخلون الجنة ولا يظلمون شيئا"
    },
    {
      "id": 2311,
      "jozz": 16,
      "page": 309,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 61,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "جنات عدن التي وعد الرحمن عباده بالغيب إنه كان وعده مأتيا"
    },
    {
      "id": 2312,
      "jozz": 16,
      "page": 309,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 62,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يسمعون فيها لغوا إلا سلاما ولهم رزقهم فيها بكرة وعشيا"
    },
    {
      "id": 2313,
      "jozz": 16,
      "page": 309,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 63,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "تلك الجنة التي نورث من عبادنا من كان تقيا"
    },
    {
      "id": 2314,
      "jozz": 16,
      "page": 309,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 64,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وما نتنزل إلا بأمر ربك له ما بين أيدينا وما خلفنا وما بين ذلك وما كان ربك نسيا"
    },
    {
      "id": 2315,
      "jozz": 16,
      "page": 310,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 65,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "رب السموات والأرض وما بينهما فاعبده واصطبر لعبادته هل تعلم له سميا"
    },
    {
      "id": 2316,
      "jozz": 16,
      "page": 310,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 66,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ويقول الإنسان أئذا ما مت لسوف أخرج حيا"
    },
    {
      "id": 2317,
      "jozz": 16,
      "page": 310,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 67,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أو لا يذكر الإنسان أنا خلقناه من قبل ولم يك شيئا"
    },
    {
      "id": 2318,
      "jozz": 16,
      "page": 310,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 68,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فوربك لنحشرنهم والشياطين ثم لنحضرنهم حول جهنم جثيا"
    },
    {
      "id": 2319,
      "jozz": 16,
      "page": 310,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 69,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم لننزعن من كل شيعة أيهم أشد على الرحمن عتيا"
    },
    {
      "id": 2320,
      "jozz": 16,
      "page": 310,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 70,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم لنحن أعلم بالذين هم أولى بها صليا"
    },
    {
      "id": 2321,
      "jozz": 16,
      "page": 310,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 71,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن منكم إلا واردها كان على ربك حتما مقضيا"
    },
    {
      "id": 2322,
      "jozz": 16,
      "page": 310,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 72,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم ننجي الذين اتقوا ونذر الظالمين فيها جثيا"
    },
    {
      "id": 2323,
      "jozz": 16,
      "page": 310,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 73,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا تتلى عليهم آياتنا بينات قال الذين كفروا للذين آمنوا أي الفريقين خير مقاما وأحسن نديا"
    },
    {
      "id": 2324,
      "jozz": 16,
      "page": 310,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 74,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكم أهلكنا قبلهم من قرن هم أحسن أثاثا ورئيا"
    },
    {
      "id": 2325,
      "jozz": 16,
      "page": 310,
      "line_start": 12,
      "line_end": 14,
      "aya_no": 75,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قل من كان في الضلالة فليمدد له الرحمن مدا حتى إذا رأوا ما يوعدون إما العذاب وإما الساعة فسيعلمون من هو شر مكانا وأضعف جندا"
    },
    {
      "id": 2326,
      "jozz": 16,
      "page": 310,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 76,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ويزيد الله الذين اهتدوا هدى والباقيات الصالحات خير عند ربك ثوابا وخير مردا"
    },
    {
      "id": 2327,
      "jozz": 16,
      "page": 311,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 77,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفرأيت الذي كفر بآياتنا وقال لأوتين مالا وولدا"
    },
    {
      "id": 2328,
      "jozz": 16,
      "page": 311,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 78,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أطلع الغيب أم اتخذ عند الرحمن عهدا"
    },
    {
      "id": 2329,
      "jozz": 16,
      "page": 311,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 79,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "كلا سنكتب ما يقول ونمد له من العذاب مدا"
    },
    {
      "id": 2330,
      "jozz": 16,
      "page": 311,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 80,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ونرثه ما يقول ويأتينا فردا"
    },
    {
      "id": 2331,
      "jozz": 16,
      "page": 311,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 81,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "واتخذوا من دون الله آلهة ليكونوا لهم عزا"
    },
    {
      "id": 2332,
      "jozz": 16,
      "page": 311,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 82,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "كلا سيكفرون بعبادتهم ويكونون عليهم ضدا"
    },
    {
      "id": 2333,
      "jozz": 16,
      "page": 311,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 83,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ألم تر أنا أرسلنا الشياطين على الكافرين تؤزهم أزا"
    },
    {
      "id": 2334,
      "jozz": 16,
      "page": 311,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 84,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فلا تعجل عليهم إنما نعد لهم عدا"
    },
    {
      "id": 2335,
      "jozz": 16,
      "page": 311,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 85,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم نحشر المتقين إلى الرحمن وفدا"
    },
    {
      "id": 2336,
      "jozz": 16,
      "page": 311,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 86,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونسوق المجرمين إلى جهنم وردا"
    },
    {
      "id": 2337,
      "jozz": 16,
      "page": 311,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 87,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يملكون الشفاعة إلا من اتخذ عند الرحمن عهدا"
    },
    {
      "id": 2338,
      "jozz": 16,
      "page": 311,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 88,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وقالوا اتخذ الرحمن ولدا"
    },
    {
      "id": 2339,
      "jozz": 16,
      "page": 311,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 89,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "لقد جئتم شيئا إدا"
    },
    {
      "id": 2340,
      "jozz": 16,
      "page": 311,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 90,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "تكاد السموات يتفطرن منه وتنشق الأرض وتخر الجبال هدا"
    },
    {
      "id": 2341,
      "jozz": 16,
      "page": 311,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 91,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أن دعوا للرحمن ولدا"
    },
    {
      "id": 2342,
      "jozz": 16,
      "page": 311,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 92,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وما ينبغي للرحمن أن يتخذ ولدا"
    },
    {
      "id": 2343,
      "jozz": 16,
      "page": 311,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 93,
      "aya_text": "‏‏ ‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن كل من في السموات والأرض إلا آتي الرحمن عبدا"
    },
    {
      "id": 2344,
      "jozz": 16,
      "page": 311,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 94,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "لقد أحصاهم وعدهم عدا"
    },
    {
      "id": 2345,
      "jozz": 16,
      "page": 311,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 95,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وكلهم آتيه يوم القيامة فردا"
    },
    {
      "id": 2346,
      "jozz": 16,
      "page": 312,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 96,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين آمنوا وعملوا الصالحات سيجعل لهم الرحمن ودا"
    },
    {
      "id": 2347,
      "jozz": 16,
      "page": 312,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 97,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "فإنما يسرناه بلسانك لتبشر به المتقين وتنذر به قوما لدا"
    },
    {
      "id": 2348,
      "jozz": 16,
      "page": 312,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 98,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وكم أهلكنا قبلهم من قرن هل تحس منهم من أحد أو تسمع لهم ركزا"
    }
  ]
}