{
  "metadata": {
    "sura_no": 74,
    "sura_name_en": "Al-Muddaththir",
    "sura_name_ar": "المُدثر",
    "total_verses": 56,
    "created_at": "2025-10-11T18:45:17.965Z"
  },
  "verses": [
    {
      "id": 5496,
      "jozz": 29,
      "page": 575,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأيها المدثر"
    },
    {
      "id": 5497,
      "jozz": 29,
      "page": 575,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قم فأنذر"
    },
    {
      "id": 5498,
      "jozz": 29,
      "page": 575,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وربك فكبر"
    },
    {
      "id": 5499,
      "jozz": 29,
      "page": 575,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 4,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وثيابك فطهر"
    },
    {
      "id": 5500,
      "jozz": 29,
      "page": 575,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والرجز فاهجر"
    },
    {
      "id": 5501,
      "jozz": 29,
      "page": 575,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 6,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا تمنن تستكثر"
    },
    {
      "id": 5502,
      "jozz": 29,
      "page": 575,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولربك فاصبر"
    },
    {
      "id": 5503,
      "jozz": 29,
      "page": 575,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 8,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإذا نقر في الناقور"
    },
    {
      "id": 5504,
      "jozz": 29,
      "page": 575,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 9,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فذلك يومئذ يوم عسير"
    },
    {
      "id": 5505,
      "jozz": 29,
      "page": 575,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 10,
      "aya_text": "‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "على الكافرين غير يسير"
    },
    {
      "id": 5506,
      "jozz": 29,
      "page": 575,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 11,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذرني ومن خلقت وحيدا"
    },
    {
      "id": 5507,
      "jozz": 29,
      "page": 575,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلت له مالا ممدودا"
    },
    {
      "id": 5508,
      "jozz": 29,
      "page": 575,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وبنين شهودا"
    },
    {
      "id": 5509,
      "jozz": 29,
      "page": 575,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومهدت له تمهيدا"
    },
    {
      "id": 5510,
      "jozz": 29,
      "page": 575,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 15,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم يطمع أن أزيد"
    },
    {
      "id": 5511,
      "jozz": 29,
      "page": 575,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 16,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا إنه كان لآياتنا عنيدا"
    },
    {
      "id": 5512,
      "jozz": 29,
      "page": 575,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سأرهقه صعودا"
    },
    {
      "id": 5513,
      "jozz": 29,
      "page": 575,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 18,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه فكر وقدر"
    },
    {
      "id": 5514,
      "jozz": 29,
      "page": 576,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 19,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فقتل كيف قدر"
    },
    {
      "id": 5515,
      "jozz": 29,
      "page": 576,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 20,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ثم قتل كيف قدر"
    },
    {
      "id": 5516,
      "jozz": 29,
      "page": 576,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 21,
      "aya_text": "‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ثم نظر"
    },
    {
      "id": 5517,
      "jozz": 29,
      "page": 576,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 22,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم عبس وبسر"
    },
    {
      "id": 5518,
      "jozz": 29,
      "page": 576,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 23,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم أدبر واستكبر"
    },
    {
      "id": 5519,
      "jozz": 29,
      "page": 576,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 24,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فقال إن هذا إلا سحر يؤثر"
    },
    {
      "id": 5520,
      "jozz": 29,
      "page": 576,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 25,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هذا إلا قول البشر"
    },
    {
      "id": 5521,
      "jozz": 29,
      "page": 576,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 26,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "سأصليه سقر"
    },
    {
      "id": 5522,
      "jozz": 29,
      "page": 576,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 27,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وما أدراك ما سقر"
    },
    {
      "id": 5523,
      "jozz": 29,
      "page": 576,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 28,
      "aya_text": "‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "لا تبقي ولا تذر"
    },
    {
      "id": 5524,
      "jozz": 29,
      "page": 576,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 29,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لواحة للبشر"
    },
    {
      "id": 5525,
      "jozz": 29,
      "page": 576,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 30,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "عليها تسعة عشر"
    },
    {
      "id": 5526,
      "jozz": 29,
      "page": 576,
      "line_start": 4,
      "line_end": 10,
      "aya_no": 31,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما جعلنا أصحاب النار إلا ملائكة وما جعلنا عدتهم إلا فتنة للذين كفروا ليستيقن الذين أوتوا الكتاب ويزداد الذين آمنوا إيمانا ولا يرتاب الذين أوتوا الكتاب والمؤمنون وليقول الذين في قلوبهم مرض والكافرون ماذا أراد الله بهذا مثلا كذلك يضل الله من يشاء ويهدي من يشاء وما يعلم جنود ربك إلا هو وما هي إلا ذكرى للبشر"
    },
    {
      "id": 5527,
      "jozz": 29,
      "page": 576,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 32,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا والقمر"
    },
    {
      "id": 5528,
      "jozz": 29,
      "page": 576,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 33,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والليل إذ أدبر"
    },
    {
      "id": 5529,
      "jozz": 29,
      "page": 576,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 34,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والصبح إذا أسفر"
    },
    {
      "id": 5530,
      "jozz": 29,
      "page": 576,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 35,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنها لإحدى الكبر"
    },
    {
      "id": 5531,
      "jozz": 29,
      "page": 576,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 36,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "نذيرا للبشر"
    },
    {
      "id": 5532,
      "jozz": 29,
      "page": 576,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 37,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لمن شاء منكم أن يتقدم أو يتأخر"
    },
    {
      "id": 5533,
      "jozz": 29,
      "page": 576,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 38,
      "aya_text": "‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كل نفس بما كسبت رهينة"
    },
    {
      "id": 5534,
      "jozz": 29,
      "page": 576,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 39,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا أصحاب اليمين"
    },
    {
      "id": 5535,
      "jozz": 29,
      "page": 576,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 40,
      "aya_text": "‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "في جنات يتساءلون"
    },
    {
      "id": 5536,
      "jozz": 29,
      "page": 576,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 41,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عن المجرمين"
    },
    {
      "id": 5537,
      "jozz": 29,
      "page": 576,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 42,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ما سلككم في سقر"
    },
    {
      "id": 5538,
      "jozz": 29,
      "page": 576,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 43,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا لم نك من المصلين"
    },
    {
      "id": 5539,
      "jozz": 29,
      "page": 576,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 44,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولم نك نطعم المسكين"
    },
    {
      "id": 5540,
      "jozz": 29,
      "page": 576,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 45,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكنا نخوض مع الخائضين"
    },
    {
      "id": 5541,
      "jozz": 29,
      "page": 576,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 46,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وكنا نكذب بيوم الدين"
    },
    {
      "id": 5542,
      "jozz": 29,
      "page": 576,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 47,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "حتى أتانا اليقين"
    },
    {
      "id": 5543,
      "jozz": 29,
      "page": 577,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 48,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما تنفعهم شفاعة الشافعين"
    },
    {
      "id": 5544,
      "jozz": 29,
      "page": 577,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 49,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما لهم عن التذكرة معرضين"
    },
    {
      "id": 5545,
      "jozz": 29,
      "page": 577,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 50,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كأنهم حمر مستنفرة"
    },
    {
      "id": 5546,
      "jozz": 29,
      "page": 577,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 51,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فرت من قسورة"
    },
    {
      "id": 5547,
      "jozz": 29,
      "page": 577,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 52,
      "aya_text": "‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل يريد كل امرئ منهم أن يؤتى صحفا منشرة"
    },
    {
      "id": 5548,
      "jozz": 29,
      "page": 577,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 53,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا بل لا يخافون الآخرة"
    },
    {
      "id": 5549,
      "jozz": 29,
      "page": 577,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 54,
      "aya_text": "‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا إنه تذكرة"
    },
    {
      "id": 5550,
      "jozz": 29,
      "page": 577,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 55,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فمن شاء ذكره"
    },
    {
      "id": 5551,
      "jozz": 29,
      "page": 577,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 56,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما يذكرون إلا أن يشاء الله هو أهل التقوى وأهل المغفرة"
    }
  ]
}