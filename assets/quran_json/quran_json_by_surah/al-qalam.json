{
  "metadata": {
    "sura_no": 68,
    "sura_name_en": "Al-Qalam",
    "sura_name_ar": "القَلَم",
    "total_verses": 52,
    "created_at": "2025-10-11T18:45:17.958Z"
  },
  "verses": [
    {
      "id": 5272,
      "jozz": 29,
      "page": 564,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 1,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ن والقلم وما يسطرون"
    },
    {
      "id": 5273,
      "jozz": 29,
      "page": 564,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما أنت بنعمة ربك بمجنون"
    },
    {
      "id": 5274,
      "jozz": 29,
      "page": 564,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 3,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن لك لأجرا غير ممنون"
    },
    {
      "id": 5275,
      "jozz": 29,
      "page": 564,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنك لعلى خلق عظيم"
    },
    {
      "id": 5276,
      "jozz": 29,
      "page": 564,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فستبصر ويبصرون"
    },
    {
      "id": 5277,
      "jozz": 29,
      "page": 564,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بأيكم المفتون"
    },
    {
      "id": 5278,
      "jozz": 29,
      "page": 564,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 7,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن ربك هو أعلم بمن ضل عن سبيله وهو أعلم بالمهتدين"
    },
    {
      "id": 5279,
      "jozz": 29,
      "page": 564,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 8,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلا تطع المكذبين"
    },
    {
      "id": 5280,
      "jozz": 29,
      "page": 564,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 9,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ودوا لو تدهن فيدهنون"
    },
    {
      "id": 5281,
      "jozz": 29,
      "page": 564,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 10,
      "aya_text": "‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ولا تطع كل حلاف مهين"
    },
    {
      "id": 5282,
      "jozz": 29,
      "page": 564,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هماز مشاء بنميم"
    },
    {
      "id": 5283,
      "jozz": 29,
      "page": 564,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 12,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "مناع للخير معتد أثيم"
    },
    {
      "id": 5284,
      "jozz": 29,
      "page": 564,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 13,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "عتل بعد ذلك زنيم"
    },
    {
      "id": 5285,
      "jozz": 29,
      "page": 564,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 14,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أن كان ذا مال وبنين"
    },
    {
      "id": 5286,
      "jozz": 29,
      "page": 564,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 15,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذا تتلى عليه آياتنا قال أساطير الأولين"
    },
    {
      "id": 5287,
      "jozz": 29,
      "page": 564,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سنسمه على الخرطوم"
    },
    {
      "id": 5288,
      "jozz": 29,
      "page": 565,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 17,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا بلوناهم كما بلونا أصحاب الجنة إذ أقسموا ليصرمنها مصبحين"
    },
    {
      "id": 5289,
      "jozz": 29,
      "page": 565,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 18,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا يستثنون"
    },
    {
      "id": 5290,
      "jozz": 29,
      "page": 565,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 19,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فطاف عليها طائف من ربك وهم نائمون"
    },
    {
      "id": 5291,
      "jozz": 29,
      "page": 565,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأصبحت كالصريم"
    },
    {
      "id": 5292,
      "jozz": 29,
      "page": 565,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 21,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فتنادوا مصبحين"
    },
    {
      "id": 5293,
      "jozz": 29,
      "page": 565,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 22,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أن اغدوا على حرثكم إن كنتم صارمين"
    },
    {
      "id": 5294,
      "jozz": 29,
      "page": 565,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 23,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فانطلقوا وهم يتخافتون"
    },
    {
      "id": 5295,
      "jozz": 29,
      "page": 565,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 24,
      "aya_text": "‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أن لا يدخلنها اليوم عليكم مسكين"
    },
    {
      "id": 5296,
      "jozz": 29,
      "page": 565,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 25,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وغدوا على حرد قادرين"
    },
    {
      "id": 5297,
      "jozz": 29,
      "page": 565,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 26,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلما رأوها قالوا إنا لضالون"
    },
    {
      "id": 5298,
      "jozz": 29,
      "page": 565,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 27,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل نحن محرومون"
    },
    {
      "id": 5299,
      "jozz": 29,
      "page": 565,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 28,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال أوسطهم ألم أقل لكم لولا تسبحون"
    },
    {
      "id": 5300,
      "jozz": 29,
      "page": 565,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 29,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا سبحان ربنا إنا كنا ظالمين"
    },
    {
      "id": 5301,
      "jozz": 29,
      "page": 565,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 30,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأقبل بعضهم على بعض يتلاومون"
    },
    {
      "id": 5302,
      "jozz": 29,
      "page": 565,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 31,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "قالوا ياويلنا إنا كنا طاغين"
    },
    {
      "id": 5303,
      "jozz": 29,
      "page": 565,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 32,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عسى ربنا أن يبدلنا خيرا منها إنا إلى ربنا راغبون"
    },
    {
      "id": 5304,
      "jozz": 29,
      "page": 565,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 33,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذلك العذاب ولعذاب الآخرة أكبر لو كانوا يعلمون"
    },
    {
      "id": 5305,
      "jozz": 29,
      "page": 565,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 34,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن للمتقين عند ربهم جنات النعيم"
    },
    {
      "id": 5306,
      "jozz": 29,
      "page": 565,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 35,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفنجعل المسلمين كالمجرمين"
    },
    {
      "id": 5307,
      "jozz": 29,
      "page": 565,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 36,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما لكم كيف تحكمون"
    },
    {
      "id": 5308,
      "jozz": 29,
      "page": 565,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 37,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم لكم كتاب فيه تدرسون"
    },
    {
      "id": 5309,
      "jozz": 29,
      "page": 565,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 38,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن لكم فيه لما تخيرون"
    },
    {
      "id": 5310,
      "jozz": 29,
      "page": 565,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 39,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم لكم أيمان علينا بالغة إلى يوم القيامة إن لكم لما تحكمون"
    },
    {
      "id": 5311,
      "jozz": 29,
      "page": 565,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 40,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "سلهم أيهم بذلك زعيم"
    },
    {
      "id": 5312,
      "jozz": 29,
      "page": 565,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 41,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أم لهم شركاء فليأتوا بشركائهم إن كانوا صادقين"
    },
    {
      "id": 5313,
      "jozz": 29,
      "page": 565,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 42,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم يكشف عن ساق ويدعون إلى السجود فلا يستطيعون"
    },
    {
      "id": 5314,
      "jozz": 29,
      "page": 566,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 43,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "خاشعة أبصارهم ترهقهم ذلة وقد كانوا يدعون إلى السجود وهم سالمون"
    },
    {
      "id": 5315,
      "jozz": 29,
      "page": 566,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 44,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فذرني ومن يكذب بهذا الحديث سنستدرجهم من حيث لا يعلمون"
    },
    {
      "id": 5316,
      "jozz": 29,
      "page": 566,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 45,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وأملي لهم إن كيدي متين"
    },
    {
      "id": 5317,
      "jozz": 29,
      "page": 566,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 46,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم تسألهم أجرا فهم من مغرم مثقلون"
    },
    {
      "id": 5318,
      "jozz": 29,
      "page": 566,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 47,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم عندهم الغيب فهم يكتبون"
    },
    {
      "id": 5319,
      "jozz": 29,
      "page": 566,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 48,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاصبر لحكم ربك ولا تكن كصاحب الحوت إذ نادى وهو مكظوم"
    },
    {
      "id": 5320,
      "jozz": 29,
      "page": 566,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 49,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لولا أن تداركه نعمة من ربه لنبذ بالعراء وهو مذموم"
    },
    {
      "id": 5321,
      "jozz": 29,
      "page": 566,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 50,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاجتباه ربه فجعله من الصالحين"
    },
    {
      "id": 5322,
      "jozz": 29,
      "page": 566,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 51,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن يكاد الذين كفروا ليزلقونك بأبصارهم لما سمعوا الذكر ويقولون إنه لمجنون"
    },
    {
      "id": 5323,
      "jozz": 29,
      "page": 566,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 52,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما هو إلا ذكر للعالمين"
    }
  ]
}