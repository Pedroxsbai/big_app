      "line_start": 7,
      "line_end": 7,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الرحمن"
    },
    {
      "id": 4903,
      "jozz": 27,
      "page": 531,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "علم القرآن"
    },
    {
      "id": 4904,
      "jozz": 27,
      "page": 531,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "خلق الإنسان"
    },
    {
      "id": 4905,
      "jozz": 27,
      "page": 531,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 4,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "علمه البيان"
    },
    {
      "id": 4906,
      "jozz": 27,
      "page": 531,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الشمس والقمر بحسبان"
    },
    {
      "id": 4907,
      "jozz": 27,
      "page": 531,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والنجم والشجر يسجدان"
    },
    {
      "id": 4908,
      "jozz": 27,
      "page": 531,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والسماء رفعها ووضع الميزان"
    },
    {
      "id": 4909,
      "jozz": 27,
      "page": 531,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 8,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألا تطغوا في الميزان"
    },
    {
      "id": 4910,
      "jozz": 27,
      "page": 531,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأقيموا الوزن بالقسط ولا تخسروا الميزان"
    },
    {
      "id": 4911,
      "jozz": 27,
      "page": 531,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والأرض وضعها للأنام"
    },
    {
      "id": 4912,
      "jozz": 27,
      "page": 531,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فيها فاكهة والنخل ذات الأكمام"
    },
    {
      "id": 4913,
      "jozz": 27,
      "page": 531,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 12,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والحب ذو العصف والريحان"
    },
    {
      "id": 4914,
      "jozz": 27,
      "page": 531,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربكما تكذبان"
    },
    {
      "id": 4915,
      "jozz": 27,
      "page": 531,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "خلق الإنسان من صلصال كالفخار"
    },
    {
      "id": 4916,
      "jozz": 27,
      "page": 531,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 15,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وخلق الجان من مارج من نار"
    },
    {
      "id": 4917,
      "jozz": 27,
      "page": 531,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 16,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربكما تكذبان"
    },
    {
      "id": 4918,
      "jozz": 27,
      "page": 531,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "رب المشرقين ورب المغربين"
    },
    {
      "id": 4919,
      "jozz": 27,
      "page": 531,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 18,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربكما تكذبان"
    },
    {
      "id": 4920,
      "jozz": 27,
      "page": 532,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "مرج البحرين يلتقيان"
    },
    {
      "id": 4921,
      "jozz": 27,
      "page": 532,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بينهما برزخ لا يبغيان"
    },
    {
      "id": 4922,
      "jozz": 27,
      "page": 532,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 21,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربكما تكذبان"
    },
    {
      "id": 4923,
      "jozz": 27,
      "page": 532,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 22,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يخرج منهما اللؤلؤ والمرجان"
    },
    {
      "id": 4924,
      "jozz": 27,
      "page": 532,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 23,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربكما تكذبان"
    },
    {
      "id": 4925,
      "jozz": 27,
      "page": 532,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 24,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وله الجوار المنشآت في البحر كالأعلام"
    },
    {
      "id": 4926,
      "jozz": 27,
      "page": 532,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 25,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربكما تكذبان"
    },
    {
      "id": 4927,
      "jozz": 27,
      "page": 532,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 26,
      "aya_text": "‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "كل من عليها فان"
    },
    {
      "id": 4928,
      "jozz": 27,
      "page": 532,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 27,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويبقى وجه ربك ذو الجلال والإكرام"
    },
    {
      "id": 4929,
      "jozz": 27,
      "page": 532,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 28,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربكما تكذبان"
    },
    {
      "id": 4930,
      "jozz": 27,
      "page": 532,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 29,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏ ‏‏‏ ‏",
      "aya_text_emlaey": "يسأله من في السموات والأرض كل يوم هو في شأن"
    },
    {
      "id": 4931,
      "jozz": 27,
      "page": 532,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 30,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربكما تكذبان"
    },
    {
      "id": 4932,
      "jozz": 27,
      "page": 532,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 31,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سنفرغ لكم أيها الثقلان"
    },
    {
      "id": 4933,
      "jozz": 27,
      "page": 532,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 32,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربكما تكذبان"
    },
    {
      "id": 4934,
      "jozz": 27,
      "page": 532,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 33,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يامعشر الجن والإنس إن استطعتم أن تنفذوا من أقطار السموات والأرض فانفذوا لا تنفذون إلا بسلطان"
    },
    {
      "id": 4935,
      "jozz": 27,
      "page": 532,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 34,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربكما تكذبان"
    },
    {
      "id": 4936,
      "jozz": 27,
      "page": 532,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 35,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يرسل عليكما شواظ من نار ونحاس فلا تنتصران"
    },
    {
      "id": 4937,
      "jozz": 27,
      "page": 532,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 36,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربكما تكذبان"
    },
    {
      "id": 4938,
      "jozz": 27,
      "page": 532,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 37,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإذا انشقت السماء فكانت وردة كالدهان"
    },
    {
      "id": 4939,
      "jozz": 27,
      "page": 532,
      "line_start": 13,
      "line_end": 13,
