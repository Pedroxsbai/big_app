{
  "metadata": {
    "sura_no": 67,
    "sura_name_en": "Al-Mulk",
    "sura_name_ar": "المُلك",
    "total_verses": 30,
    "created_at": "2025-10-11T18:45:17.957Z"
  },
  "verses": [
    {
      "id": 5242,
      "jozz": 29,
      "page": 562,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "تبارك الذي بيده الملك وهو على كل شيء قدير"
    },
    {
      "id": 5243,
      "jozz": 29,
      "page": 562,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذي خلق الموت والحياة ليبلوكم أيكم أحسن عملا وهو العزيز الغفور"
    },
    {
      "id": 5244,
      "jozz": 29,
      "page": 562,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذي خلق سبع سموات طباقا ما ترى في خلق الرحمن من تفاوت فارجع البصر هل ترى من فطور"
    },
    {
      "id": 5245,
      "jozz": 29,
      "page": 562,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 4,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم ارجع البصر كرتين ينقلب إليك البصر خاسئا وهو حسير"
    },
    {
      "id": 5246,
      "jozz": 29,
      "page": 562,
      "line_start": 7,
      "line_end": 9,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد زينا السماء الدنيا بمصابيح وجعلناها رجوما للشياطين وأعتدنا لهم عذاب السعير"
    },
    {
      "id": 5247,
      "jozz": 29,
      "page": 562,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وللذين كفروا بربهم عذاب جهنم وبئس المصير"
    },
    {
      "id": 5248,
      "jozz": 29,
      "page": 562,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذا ألقوا فيها سمعوا لها شهيقا وهي تفور"
    },
    {
      "id": 5249,
      "jozz": 29,
      "page": 562,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "تكاد تميز من الغيظ كلما ألقي فيها فوج سألهم خزنتها ألم يأتكم نذير"
    },
    {
      "id": 5250,
      "jozz": 29,
      "page": 562,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا بلى قد جاءنا نذير فكذبنا وقلنا ما نزل الله من شيء إن أنتم إلا في ضلال كبير"
    },
    {
      "id": 5251,
      "jozz": 29,
      "page": 562,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقالوا لو كنا نسمع أو نعقل ما كنا في أصحاب السعير"
    },
    {
      "id": 5252,
      "jozz": 29,
      "page": 562,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاعترفوا بذنبهم فسحقا لأصحاب السعير"
    },
    {
      "id": 5253,
      "jozz": 29,
      "page": 562,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 12,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين يخشون ربهم بالغيب لهم مغفرة وأجر كبير"
    },
    {
      "id": 5254,
      "jozz": 29,
      "page": 563,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 13,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأسروا قولكم أو اجهروا به إنه عليم بذات الصدور"
    },
    {
      "id": 5255,
      "jozz": 29,
      "page": 563,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 14,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألا يعلم من خلق وهو اللطيف الخبير"
    },
    {
      "id": 5256,
      "jozz": 29,
      "page": 563,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 15,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هو الذي جعل لكم الأرض ذلولا فامشوا في مناكبها وكلوا من رزقه وإليه النشور"
    },
    {
      "id": 5257,
      "jozz": 29,
      "page": 563,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أأمنتم من في السماء أن يخسف بكم الأرض فإذا هي تمور"
    },
    {
      "id": 5258,
      "jozz": 29,
      "page": 563,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أم أمنتم من في السماء أن يرسل عليكم حاصبا فستعلمون كيف نذير"
    },
    {
      "id": 5259,
      "jozz": 29,
      "page": 563,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 18,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد كذب الذين من قبلهم فكيف كان نكير"
    },
    {
      "id": 5260,
      "jozz": 29,
      "page": 563,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 19,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أو لم يروا إلى الطير فوقهم صافات ويقبضن ما يمسكهن إلا الرحمن إنه بكل شيء بصير"
    },
    {
      "id": 5261,
      "jozz": 29,
      "page": 563,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 20,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أمن هذا الذي هو جند لكم ينصركم من دون الرحمن إن الكافرون إلا في غرور"
    },
    {
      "id": 5262,
      "jozz": 29,
      "page": 563,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 21,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أمن هذا الذي يرزقكم إن أمسك رزقه بل لجوا في عتو ونفور"
    },
    {
      "id": 5263,
      "jozz": 29,
      "page": 563,
      "line_start": 10,
      "line_end": 12,
      "aya_no": 22,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفمن يمشي مكبا على وجهه أهدى أمن يمشي سويا على صراط مستقيم"
    },
    {
      "id": 5264,
      "jozz": 29,
      "page": 563,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 23,
      "aya_text": "‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل هو الذي أنشأكم وجعل لكم السمع والأبصار والأفئدة قليلا ما تشكرون"
    },
    {
      "id": 5265,
      "jozz": 29,
