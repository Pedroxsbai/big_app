{
  "metadata": {
    "sura_no": 88,
    "sura_name_en": "Al-Ghāshiyah",
    "sura_name_ar": "الغَاشِية",
    "total_verses": 26,
    "created_at": "2025-10-11T18:45:17.981Z"
  },
  "verses": [
    {
      "id": 5968,
      "jozz": 30,
      "page": 592,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 1,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هل أتاك حديث الغاشية"
    },
    {
      "id": 5969,
      "jozz": 30,
      "page": 592,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 2,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وجوه يومئذ خاشعة"
    },
    {
      "id": 5970,
      "jozz": 30,
      "page": 592,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 3,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عاملة ناصبة"
    },
    {
      "id": 5971,
      "jozz": 30,
      "page": 592,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "تصلى نارا حامية"
    },
    {
      "id": 5972,
      "jozz": 30,
      "page": 592,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 5,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "تسقى من عين آنية"
    },
    {
      "id": 5973,
      "jozz": 30,
      "page": 592,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 6,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ليس لهم طعام إلا من ضريع"
    },
    {
      "id": 5974,
      "jozz": 30,
      "page": 592,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 7,
      "aya_text": "‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "لا يسمن ولا يغني من جوع"
    },
    {
      "id": 5975,
      "jozz": 30,
      "page": 592,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 8,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجوه يومئذ ناعمة"
    },
    {
      "id": 5976,
      "jozz": 30,
      "page": 592,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لسعيها راضية"
    },
    {
      "id": 5977,
      "jozz": 30,
      "page": 592,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 10,
      "aya_text": "‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "في جنة عالية"
    },
    {
      "id": 5978,
      "jozz": 30,
      "page": 592,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 11,
      "aya_text": "‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لا تسمع فيها لاغية"
    },
    {
      "id": 5979,
      "jozz": 30,
      "page": 592,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 12,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فيها عين جارية"
    },
    {
      "id": 5980,
      "jozz": 30,
      "page": 592,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فيها سرر مرفوعة"
    },
    {
      "id": 5981,
      "jozz": 30,
      "page": 592,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأكواب موضوعة"
    },
    {
      "id": 5982,
      "jozz": 30,
      "page": 592,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونمارق مصفوفة"
    },
    {
      "id": 5983,
      "jozz": 30,
      "page": 592,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وزرابي مبثوثة"
    },
    {
      "id": 5984,
      "jozz": 30,
      "page": 592,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 17,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أفلا ينظرون إلى الإبل كيف خلقت"
    },
    {
      "id": 5985,
      "jozz": 30,
      "page": 592,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 18,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإلى السماء كيف رفعت"
    },
    {
      "id": 5986,
      "jozz": 30,
      "page": 592,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 19,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإلى الجبال كيف نصبت"
    },
    {
      "id": 5987,
      "jozz": 30,
      "page": 592,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 20,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإلى الأرض كيف سطحت"
    },
    {
      "id": 5988,
      "jozz": 30,
      "page": 592,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 21,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فذكر إنما أنت مذكر"
    },
    {
      "id": 5989,
      "jozz": 30,
      "page": 592,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 22,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لست عليهم بمصيطر"
    },
    {
      "id": 5990,
      "jozz": 30,
      "page": 593,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 23,
      "aya_text": "‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا من تولى وكفر"
    },
    {
      "id": 5991,
      "jozz": 30,
      "page": 593,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 24,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فيعذبه الله العذاب الأكبر"
    },
    {
      "id": 5992,
      "jozz": 30,
      "page": 593,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 25,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن إلينا إيابهم"
    },
    {
      "id": 5993,
      "jozz": 30,
      "page": 593,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 26,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم إن علينا حسابهم"
    }
  ]
}