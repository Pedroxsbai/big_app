{
  "metadata": {
    "sura_no": 36,
    "sura_name_en": "Yā-Sīn",
    "sura_name_ar": "يسٓ",
    "total_verses": 83,
    "created_at": "2025-10-11T18:45:17.921Z"
  },
  "verses": [
    {
      "id": 3706,
      "jozz": 22,
      "page": 440,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 1,
      "aya_text": "‏‏ ‏",
      "aya_text_emlaey": "يس"
    },
    {
      "id": 3707,
      "jozz": 22,
      "page": 440,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والقرآن الحكيم"
    },
    {
      "id": 3708,
      "jozz": 22,
      "page": 440,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنك لمن المرسلين"
    },
    {
      "id": 3709,
      "jozz": 22,
      "page": 440,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 4,
      "aya_text": "‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "على صراط مستقيم"
    },
    {
      "id": 3710,
      "jozz": 22,
      "page": 440,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "تنزيل العزيز الرحيم"
    },
    {
      "id": 3711,
      "jozz": 22,
      "page": 440,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لتنذر قوما ما أنذر آباؤهم فهم غافلون"
    },
    {
      "id": 3712,
      "jozz": 22,
      "page": 440,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لقد حق القول على أكثرهم فهم لا يؤمنون"
    },
    {
      "id": 3713,
      "jozz": 22,
      "page": 440,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا جعلنا في أعناقهم أغلالا فهي إلى الأذقان فهم مقمحون"
    },
    {
      "id": 3714,
      "jozz": 22,
      "page": 440,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلنا من بين أيديهم سدا ومن خلفهم سدا فأغشيناهم فهم لا يبصرون"
    },
    {
      "id": 3715,
      "jozz": 22,
      "page": 440,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وسواء عليهم أأنذرتهم أم لم تنذرهم لا يؤمنون"
    },
    {
      "id": 3716,
      "jozz": 22,
      "page": 440,
      "line_start": 12,
      "line_end": 14,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنما تنذر من اتبع الذكر وخشي الرحمن بالغيب فبشره بمغفرة وأجر كريم"
    },
    {
      "id": 3717,
      "jozz": 22,
      "page": 440,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 12,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إنا نحن نحيي الموتى ونكتب ما قدموا وآثارهم وكل شيء أحصيناه في إمام مبين"
    },
    {
      "id": 3718,
      "jozz": 22,
      "page": 441,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 13,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "واضرب لهم مثلا أصحاب القرية إذ جاءها المرسلون"
    },
    {
      "id": 3719,
      "jozz": 22,
      "page": 441,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 14,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ أرسلنا إليهم اثنين فكذبوهما فعززنا بثالث فقالوا إنا إليكم مرسلون"
    },
    {
      "id": 3720,
      "jozz": 22,
      "page": 441,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا ما أنتم إلا بشر مثلنا وما أنزل الرحمن من شيء إن أنتم إلا تكذبون"
    },
    {
      "id": 3721,
      "jozz": 22,
      "page": 441,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا ربنا يعلم إنا إليكم لمرسلون"
    },
    {
      "id": 3722,
      "jozz": 22,
      "page": 441,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 17,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما علينا إلا البلاغ المبين"
    },
    {
      "id": 3723,
      "jozz": 22,
      "page": 441,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 18,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "قالوا إنا تطيرنا بكم لئن لم تنتهوا لنرجمنكم وليمسنكم منا عذاب أليم"
    },
    {
      "id": 3724,
      "jozz": 22,
      "page": 441,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا طائركم معكم أإن ذكرتم بل أنتم قوم مسرفون"
    },
    {
      "id": 3725,
      "jozz": 22,
      "page": 441,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 20,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجاء من أقصى المدينة رجل يسعى قال ياقوم اتبعوا المرسلين"
    },
    {
      "id": 3726,
      "jozz": 22,
      "page": 441,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 21,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "اتبعوا من لا يسألكم أجرا وهم مهتدون"
    },
    {
      "id": 3727,
      "jozz": 22,
      "page": 441,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 22,
      "aya_text": "‏‏‏ ‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما لي لا أعبد الذي فطرني وإليه ترجعون"
    },
    {
      "id": 3728,
      "jozz": 22,
      "page": 441,
      "line_start": 11,
      "line_end": 13,
      "aya_no": 23,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أأتخذ من دونه آلهة إن يردن الرحمن بضر لا تغن عني شفاعتهم شيئا ولا ينقذون"
    },
    {
      "id": 3729,
      "jozz": 22,
      "page": 441,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 24,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إني إذا لفي ضلال مبين"
    },
    {
      "id": 3730,
      "jozz": 22,
      "page": 441,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 25,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إني آمنت بربكم فاسمعون"
    },
    {
      "id": 3731,
      "jozz": 22,
      "page": 441,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 26,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قيل ادخل الجنة قال ياليت قومي يعلمون"
    },
    {
      "id": 3732,
      "jozz": 22,
      "page": 441,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 27,
      "aya_text": "‏‏‏ ‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بما غفر لي ربي وجعلني من المكرمين"
    },
    {
      "id": 3733,
      "jozz": 23,
      "page": 442,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 28,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أنزلنا على قومه من بعده من جند من السماء وما كنا منزلين"
    },
    {
      "id": 3734,
      "jozz": 23,
      "page": 442,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 29,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن كانت إلا صيحة واحدة فإذا هم خامدون"
    },
    {
      "id": 3735,
      "jozz": 23,
      "page": 442,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 30,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ياحسرة على العباد ما يأتيهم من رسول إلا كانوا به يستهزئون"
    },
    {
      "id": 3736,
      "jozz": 23,
      "page": 442,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 31,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم يروا كم أهلكنا قبلهم من القرون أنهم إليهم لا يرجعون"
    },
    {
      "id": 3737,
      "jozz": 23,
      "page": 442,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 32,
      "aya_text": "‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن كل لما جميع لدينا محضرون"
    },
    {
      "id": 3738,
      "jozz": 23,
      "page": 442,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 33,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وآية لهم الأرض الميتة أحييناها وأخرجنا منها حبا فمنه يأكلون"
    },
    {
      "id": 3739,
      "jozz": 23,
      "page": 442,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 34,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلنا فيها جنات من نخيل وأعناب وفجرنا فيها من العيون"
    },
    {
      "id": 3740,
      "jozz": 23,
      "page": 442,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 35,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ليأكلوا من ثمره وما عملته أيديهم أفلا يشكرون"
    },
    {
      "id": 3741,
      "jozz": 23,
      "page": 442,
      "line_start": 9,
      "line_end": 11,
      "aya_no": 36,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سبحان الذي خلق الأزواج كلها مما تنبت الأرض ومن أنفسهم ومما لا يعلمون"
    },
    {
      "id": 3742,
      "jozz": 23,
      "page": 442,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 37,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وآية لهم الليل نسلخ منه النهار فإذا هم مظلمون"
    },
    {
      "id": 3743,
      "jozz": 23,
      "page": 442,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 38,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والشمس تجري لمستقر لها ذلك تقدير العزيز العليم"
    },
    {
      "id": 3744,
      "jozz": 23,
      "page": 442,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 39,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والقمر قدرناه منازل حتى عاد كالعرجون القديم"
    },
    {
      "id": 3745,
      "jozz": 23,
      "page": 442,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 40,
      "aya_text": "‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا الشمس ينبغي لها أن تدرك القمر ولا الليل سابق النهار وكل في فلك يسبحون"
    },
    {
      "id": 3746,
      "jozz": 23,
      "page": 443,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 41,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وآية لهم أنا حملنا ذريتهم في الفلك المشحون"
    },
    {
      "id": 3747,
      "jozz": 23,
      "page": 443,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 42,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وخلقنا لهم من مثله ما يركبون"
    },
    {
      "id": 3748,
      "jozz": 23,
      "page": 443,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 43,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن نشأ نغرقهم فلا صريخ لهم ولا هم ينقذون"
    },
    {
      "id": 3749,
      "jozz": 23,
      "page": 443,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 44,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏",
      "aya_text_emlaey": "إلا رحمة منا ومتاعا إلى حين"
    },
    {
      "id": 3750,
      "jozz": 23,
      "page": 443,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 45,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا قيل لهم اتقوا ما بين أيديكم وما خلفكم لعلكم ترحمون"
    },
    {
      "id": 3751,
      "jozz": 23,
      "page": 443,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 46,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما تأتيهم من آية من آيات ربهم إلا كانوا عنها معرضين"
    },
    {
      "id": 3752,
      "jozz": 23,
      "page": 443,
      "line_start": 6,
      "line_end": 8,
      "aya_no": 47,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وإذا قيل لهم أنفقوا مما رزقكم الله قال الذين كفروا للذين آمنوا أنطعم من لو يشاء الله أطعمه إن أنتم إلا في ضلال مبين"
    },
    {
      "id": 3753,
      "jozz": 23,
      "page": 443,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 48,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ويقولون متى هذا الوعد إن كنتم صادقين"
    },
    {
      "id": 3754,
      "jozz": 23,
      "page": 443,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 49,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما ينظرون إلا صيحة واحدة تأخذهم وهم يخصمون"
    },
    {
      "id": 3755,
      "jozz": 23,
      "page": 443,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 50,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلا يستطيعون توصية ولا إلى أهلهم يرجعون"
    },
    {
      "id": 3756,
      "jozz": 23,
      "page": 443,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 51,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونفخ في الصور فإذا هم من الأجداث إلى ربهم ينسلون"
    },
    {
      "id": 3757,
      "jozz": 23,
      "page": 443,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 52,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا ياويلنا من بعثنا من مرقدنا هذا ما وعد الرحمن وصدق المرسلون"
    },
    {
      "id": 3758,
      "jozz": 23,
      "page": 443,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 53,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن كانت إلا صيحة واحدة فإذا هم جميع لدينا محضرون"
    },
    {
      "id": 3759,
      "jozz": 23,
      "page": 443,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 54,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاليوم لا تظلم نفس شيئا ولا تجزون إلا ما كنتم تعملون"
    },
    {
      "id": 3760,
      "jozz": 23,
      "page": 444,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 55,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن أصحاب الجنة اليوم في شغل فاكهون"
    },
    {
      "id": 3761,
      "jozz": 23,
      "page": 444,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 56,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏‏ ‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هم وأزواجهم في ظلال على الأرائك متكئون"
    },
    {
      "id": 3762,
      "jozz": 23,
      "page": 444,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 57,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لهم فيها فاكهة ولهم ما يدعون"
    },
    {
      "id": 3763,
      "jozz": 23,
      "page": 444,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 58,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "سلام قولا من رب رحيم"
    },
    {
      "id": 3764,
      "jozz": 23,
      "page": 444,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 59,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وامتازوا اليوم أيها المجرمون"
    },
    {
      "id": 3765,
      "jozz": 23,
      "page": 444,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 60,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ألم أعهد إليكم يابني آدم أن لا تعبدوا الشيطان إنه لكم عدو مبين"
    },
    {
      "id": 3766,
      "jozz": 23,
      "page": 444,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 61,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأن اعبدوني هذا صراط مستقيم"
    },
    {
      "id": 3767,
      "jozz": 23,
      "page": 444,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 62,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد أضل منكم جبلا كثيرا أفلم تكونوا تعقلون"
    },
    {
      "id": 3768,
      "jozz": 23,
      "page": 444,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 63,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هذه جهنم التي كنتم توعدون"
    },
    {
      "id": 3769,
      "jozz": 23,
      "page": 444,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 64,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "اصلوها اليوم بما كنتم تكفرون"
    },
    {
      "id": 3770,
      "jozz": 23,
      "page": 444,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 65,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "اليوم نختم على أفواههم وتكلمنا أيديهم وتشهد أرجلهم بما كانوا يكسبون"
    },
    {
      "id": 3771,
      "jozz": 23,
      "page": 444,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 66,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولو نشاء لطمسنا على أعينهم فاستبقوا الصراط فأنى يبصرون"
    },
    {
      "id": 3772,
      "jozz": 23,
      "page": 444,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 67,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولو نشاء لمسخناهم على مكانتهم فما استطاعوا مضيا ولا يرجعون"
    },
    {
      "id": 3773,
      "jozz": 23,
      "page": 444,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 68,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن نعمره ننكسه في الخلق أفلا يعقلون"
    },
    {
      "id": 3774,
      "jozz": 23,
      "page": 444,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 69,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وما علمناه الشعر وما ينبغي له إن هو إلا ذكر وقرآن مبين"
    },
    {
      "id": 3775,
      "jozz": 23,
      "page": 444,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 70,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لينذر من كان حيا ويحق القول على الكافرين"
    },
    {
      "id": 3776,
      "jozz": 23,
      "page": 445,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 71,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أو لم يروا أنا خلقنا لهم مما عملت أيدينا أنعاما فهم لها مالكون"
    },
    {
      "id": 3777,
      "jozz": 23,
      "page": 445,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 72,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وذللناها لهم فمنها ركوبهم ومنها يأكلون"
    },
    {
      "id": 3778,
      "jozz": 23,
      "page": 445,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 73,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولهم فيها منافع ومشارب أفلا يشكرون"
    },
    {
      "id": 3779,
      "jozz": 23,
      "page": 445,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 74,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "واتخذوا من دون الله آلهة لعلهم ينصرون"
    },
    {
      "id": 3780,
      "jozz": 23,
      "page": 445,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 75,
      "aya_text": "‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يستطيعون نصرهم وهم لهم جند محضرون"
    },
    {
      "id": 3781,
      "jozz": 23,
      "page": 445,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 76,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلا يحزنك قولهم إنا نعلم ما يسرون وما يعلنون"
    },
    {
      "id": 3782,
      "jozz": 23,
      "page": 445,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 77,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أو لم ير الإنسان أنا خلقناه من نطفة فإذا هو خصيم مبين"
    },
    {
      "id": 3783,
      "jozz": 23,
      "page": 445,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 78,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وضرب لنا مثلا ونسي خلقه قال من يحيي العظام وهي رميم"
    },
    {
      "id": 3784,
      "jozz": 23,
      "page": 445,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 79,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قل يحييها الذي أنشأها أول مرة وهو بكل خلق عليم"
    },
    {
      "id": 3785,
      "jozz": 23,
      "page": 445,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 80,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذي جعل لكم من الشجر الأخضر نارا فإذا أنتم منه توقدون"
    },
    {
      "id": 3786,
      "jozz": 23,
      "page": 445,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 81,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أو ليس الذي خلق السموات والأرض بقادر على أن يخلق مثلهم بلى وهو الخلاق العليم"
    },
    {
      "id": 3787,
      "jozz": 23,
      "page": 445,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 82,
