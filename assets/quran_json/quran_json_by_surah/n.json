{
  "metadata": {
    "sura_no": 71,
    "sura_name_en": "Nūḥ",
    "sura_name_ar": "نُوح",
    "total_verses": 28,
    "created_at": "2025-10-11T18:45:17.961Z"
  },
  "verses": [
    {
      "id": 5420,
      "jozz": 29,
      "page": 570,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 1,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إنا أرسلنا نوحا إلى قومه أن أنذر قومك من قبل أن يأتيهم عذاب أليم"
    },
    {
      "id": 5421,
      "jozz": 29,
      "page": 570,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "قال ياقوم إني لكم نذير مبين"
    },
    {
      "id": 5422,
      "jozz": 29,
      "page": 570,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 3,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أن اعبدوا الله واتقوه وأطيعون"
    },
    {
      "id": 5423,
      "jozz": 29,
      "page": 570,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 4,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يغفر لكم من ذنوبكم ويؤخركم إلى أجل مسمى إن أجل الله إذا جاء لا يؤخر لو كنتم تعلمون"
    },
    {
      "id": 5424,
      "jozz": 29,
      "page": 570,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 5,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال رب إني دعوت قومي ليلا ونهارا"
    },
    {
      "id": 5425,
      "jozz": 29,
      "page": 570,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 6,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلم يزدهم دعائي إلا فرارا"
    },
    {
      "id": 5426,
      "jozz": 29,
      "page": 570,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 7,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإني كلما دعوتهم لتغفر لهم جعلوا أصابعهم في آذانهم واستغشوا ثيابهم وأصروا واستكبروا استكبارا"
    },
    {
      "id": 5427,
      "jozz": 29,
      "page": 570,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 8,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم إني دعوتهم جهارا"
    },
    {
      "id": 5428,
      "jozz": 29,
      "page": 570,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 9,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم إني أعلنت لهم وأسررت لهم إسرارا"
    },
    {
      "id": 5429,
      "jozz": 29,
      "page": 570,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 10,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فقلت استغفروا ربكم إنه كان غفارا"
    },
    {
      "id": 5430,
      "jozz": 29,
      "page": 571,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يرسل السماء عليكم مدرارا"
    },
    {
      "id": 5431,
      "jozz": 29,
      "page": 571,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويمددكم بأموال وبنين ويجعل لكم جنات ويجعل لكم أنهارا"
    },
    {
      "id": 5432,
      "jozz": 29,
      "page": 571,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 13,
      "aya_text": "‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما لكم لا ترجون لله وقارا"
    },
    {
      "id": 5433,
      "jozz": 29,
      "page": 571,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقد خلقكم أطوارا"
    },
    {
      "id": 5434,
      "jozz": 29,
      "page": 571,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 15,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم تروا كيف خلق الله سبع سموات طباقا"
    },
    {
      "id": 5435,
      "jozz": 29,
      "page": 571,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 16,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعل القمر فيهن نورا وجعل الشمس سراجا"
    },
    {
      "id": 5436,
      "jozz": 29,
      "page": 571,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 17,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والله أنبتكم من الأرض نباتا"
    },
    {
      "id": 5437,
      "jozz": 29,
      "page": 571,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 18,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم يعيدكم فيها ويخرجكم إخراجا"
    },
    {
      "id": 5438,
      "jozz": 29,
      "page": 571,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والله جعل لكم الأرض بساطا"
    },
    {
      "id": 5439,
      "jozz": 29,
      "page": 571,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لتسلكوا منها سبلا فجاجا"
    },
    {
      "id": 5440,
      "jozz": 29,
      "page": 571,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 21,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال نوح رب إنهم عصوني واتبعوا من لم يزده ماله وولده إلا خسارا"
    },
    {
      "id": 5441,
      "jozz": 29,
      "page": 571,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 22,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومكروا مكرا كبارا"
    },
    {
      "id": 5442,
      "jozz": 29,
      "page": 571,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 23,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقالوا لا تذرن آلهتكم ولا تذرن ودا ولا سواعا ولا يغوث ويعوق ونسرا"
    },
    {
      "id": 5443,
      "jozz": 29,
      "page": 571,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 24,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وقد أضلوا كثيرا ولا تزد الظالمين إلا ضلالا"
    },
    {
      "id": 5444,
      "jozz": 29,
      "page": 571,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 25,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "مما خطيئاتهم أغرقوا فأدخلوا نارا فلم يجدوا لهم من دون الله أنصارا"
    },
    {
      "id": 5445,
      "jozz": 29,
      "page": 571,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 26,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقال نوح رب لا تذر على الأرض من الكافرين ديارا"
    },
    {
      "id": 5446,
      "jozz": 29,
      "page": 571,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 27,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنك إن تذرهم يضلوا عبادك ولا يلدوا إلا فاجرا كفارا"
    },
    {
      "id": 5447,
      "jozz": 29,
      "page": 571,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 28,
      "aya_text": "‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "رب اغفر لي ولوالدي ولمن دخل بيتي مؤمنا وللمؤمنين والمؤمنات ولا تزد الظالمين إلا تبارا"
    }
  ]
}