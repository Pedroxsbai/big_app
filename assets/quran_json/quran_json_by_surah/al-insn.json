      "line_end": 5,
      "aya_no": 30,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما تشاءون إلا أن يشاء الله إن الله كان عليما حكيما"
