{
  "metadata": {
    "sura_no": 77,
    "sura_name_en": "Al-Mursalāt",
    "sura_name_ar": "المُرسَلات",
    "total_verses": 50,
    "created_at": "2025-10-11T18:45:17.968Z"
  },
  "verses": [
    {
      "id": 5623,
      "jozz": 29,
      "page": 580,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والمرسلات عرفا"
    },
    {
      "id": 5624,
      "jozz": 29,
      "page": 580,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالعاصفات عصفا"
    },
    {
      "id": 5625,
      "jozz": 29,
      "page": 580,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والناشرات نشرا"
    },
    {
      "id": 5626,
      "jozz": 29,
      "page": 580,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 4,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالفارقات فرقا"
    },
    {
      "id": 5627,
      "jozz": 29,
      "page": 580,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالملقيات ذكرا"
    },
    {
      "id": 5628,
      "jozz": 29,
      "page": 580,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "عذرا أو نذرا"
    },
    {
      "id": 5629,
      "jozz": 29,
      "page": 580,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 7,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنما توعدون لواقع"
    },
    {
      "id": 5630,
      "jozz": 29,
      "page": 580,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 8,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فإذا النجوم طمست"
    },
    {
      "id": 5631,
      "jozz": 29,
      "page": 580,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 9,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا السماء فرجت"
    },
    {
      "id": 5632,
      "jozz": 29,
      "page": 580,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 10,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا الجبال نسفت"
    },
    {
      "id": 5633,
      "jozz": 29,
      "page": 580,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 11,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا الرسل أقتت"
    },
    {
      "id": 5634,
      "jozz": 29,
      "page": 580,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 12,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لأي يوم أجلت"
    },
    {
      "id": 5635,
      "jozz": 29,
      "page": 580,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 13,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ليوم الفصل"
    },
    {
      "id": 5636,
      "jozz": 29,
      "page": 580,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أدراك ما يوم الفصل"
    },
    {
      "id": 5637,
      "jozz": 29,
      "page": 580,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 15,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويل يومئذ للمكذبين"
    },
    {
      "id": 5638,
      "jozz": 29,
      "page": 580,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 16,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم نهلك الأولين"
    },
    {
      "id": 5639,
      "jozz": 29,
      "page": 580,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم نتبعهم الآخرين"
    },
    {
      "id": 5640,
      "jozz": 29,
      "page": 580,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 18,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذلك نفعل بالمجرمين"
    },
    {
      "id": 5641,
      "jozz": 29,
      "page": 580,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويل يومئذ للمكذبين"
    },
    {
      "id": 5642,
      "jozz": 29,
      "page": 581,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 20,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ألم نخلقكم من ماء مهين"
    },
    {
      "id": 5643,
      "jozz": 29,
      "page": 581,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 21,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فجعلناه في قرار مكين"
    },
    {
      "id": 5644,
      "jozz": 29,
      "page": 581,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 22,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلى قدر معلوم"
    },
    {
      "id": 5645,
      "jozz": 29,
      "page": 581,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 23,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فقدرنا فنعم القادرون"
    },
    {
      "id": 5646,
      "jozz": 29,
      "page": 581,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 24,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويل يومئذ للمكذبين"
    },
    {
      "id": 5647,
      "jozz": 29,
      "page": 581,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 25,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم نجعل الأرض كفاتا"
    },
    {
      "id": 5648,
      "jozz": 29,
      "page": 581,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 26,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أحياء ‎وأمواتا"
    },
    {
      "id": 5649,
      "jozz": 29,
      "page": 581,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 27,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلنا فيها رواسي شامخات وأسقيناكم ماء فراتا"
    },
    {
      "id": 5650,
      "jozz": 29,
      "page": 581,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 28,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويل يومئذ للمكذبين"
    },
    {
      "id": 5651,
      "jozz": 29,
      "page": 581,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 29,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "انطلقوا إلى ما كنتم به تكذبون"
    },
    {
      "id": 5652,
      "jozz": 29,
      "page": 581,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 30,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "انطلقوا إلى ظل ذي ثلاث شعب"
    },
    {
      "id": 5653,
      "jozz": 29,
      "page": 581,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 31,
      "aya_text": "‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا ظليل ولا يغني من اللهب"
    },
    {
      "id": 5654,
      "jozz": 29,
      "page": 581,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 32,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنها ترمي بشرر كالقصر"
    },
    {
      "id": 5655,
      "jozz": 29,
      "page": 581,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 33,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "كأنه جمالة صفر"
    },
    {
      "id": 5656,
      "jozz": 29,
      "page": 581,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 34,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويل يومئذ للمكذبين"
    },
    {
      "id": 5657,
      "jozz": 29,
      "page": 581,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 35,
      "aya_text": "‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هذا يوم لا ينطقون"
    },
    {
      "id": 5658,
      "jozz": 29,
      "page": 581,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 36,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا يؤذن لهم فيعتذرون"
    },
    {
      "id": 5659,
      "jozz": 29,
      "page": 581,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 37,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويل يومئذ للمكذبين"
    },
    {
      "id": 5660,
      "jozz": 29,
      "page": 581,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 38,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هذا يوم الفصل جمعناكم والأولين"
    },
    {
      "id": 5661,
      "jozz": 29,
      "page": 581,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 39,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإن كان لكم كيد فكيدون"
    },
    {
      "id": 5662,
      "jozz": 29,
      "page": 581,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 40,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويل يومئذ للمكذبين"
    },
    {
      "id": 5663,
      "jozz": 29,
      "page": 581,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 41,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن المتقين في ظلال وعيون"
    },
    {
      "id": 5664,
      "jozz": 29,
      "page": 581,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 42,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وفواكه مما يشتهون"
    },
    {
      "id": 5665,
      "jozz": 29,
      "page": 581,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 43,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلوا واشربوا هنيئا بما كنتم تعملون"
    },
    {
      "id": 5666,
      "jozz": 29,
      "page": 581,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 44,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
