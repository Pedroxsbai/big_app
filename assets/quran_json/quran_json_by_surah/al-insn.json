{
  "metadata": {
    "sura_no": 76,
    "sura_name_en": "Al-Insān",
    "sura_name_ar": "الإنسَان",
    "total_verses": 31,
    "created_at": "2025-10-11T18:45:17.967Z"
  },
  "verses": [
    {
      "id": 5592,
      "jozz": 29,
      "page": 578,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 1,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هل أتى على الإنسان حين من الدهر لم يكن شيئا مذكورا"
    },
    {
      "id": 5593,
      "jozz": 29,
      "page": 578,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا خلقنا الإنسان من نطفة أمشاج نبتليه فجعلناه سميعا بصيرا"
    },
    {
      "id": 5594,
      "jozz": 29,
      "page": 578,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا هديناه السبيل إما شاكرا وإما كفورا"
    },
    {
      "id": 5595,
      "jozz": 29,
      "page": 578,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا أعتدنا للكافرين سلاسل وأغلالا وسعيرا"
    },
    {
      "id": 5596,
      "jozz": 29,
      "page": 578,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 5,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الأبرار يشربون من كأس كان مزاجها كافورا"
    },
    {
      "id": 5597,
      "jozz": 29,
      "page": 579,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عينا يشرب بها عباد الله يفجرونها تفجيرا"
    },
    {
      "id": 5598,
      "jozz": 29,
      "page": 579,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوفون بالنذر ويخافون يوما كان شره مستطيرا"
    },
    {
      "id": 5599,
      "jozz": 29,
      "page": 579,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 8,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويطعمون الطعام على حبه مسكينا ويتيما وأسيرا"
    },
    {
      "id": 5600,
      "jozz": 29,
      "page": 579,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 9,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنما نطعمكم لوجه الله لا نريد منكم جزاء ولا شكورا"
    },
    {
      "id": 5601,
      "jozz": 29,
      "page": 579,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 10,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا نخاف من ربنا يوما عبوسا قمطريرا"
    },
    {
      "id": 5602,
      "jozz": 29,
      "page": 579,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فوقاهم الله شر ذلك اليوم ولقاهم نضرة وسرورا"
    },
    {
      "id": 5603,
      "jozz": 29,
      "page": 579,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجزاهم بما صبروا جنة وحريرا"
    },
    {
      "id": 5604,
      "jozz": 29,
      "page": 579,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "متكئين فيها على الأرائك لا يرون فيها شمسا ولا زمهريرا"
    },
    {
      "id": 5605,
      "jozz": 29,
      "page": 579,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ودانية عليهم ظلالها وذللت قطوفها تذليلا"
    },
    {
      "id": 5606,
      "jozz": 29,
      "page": 579,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويطاف عليهم بآنية من فضة وأكواب كانت قواريرا"
    },
    {
      "id": 5607,
      "jozz": 29,
      "page": 579,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قواريرا من فضة قدروها تقديرا"
    },
    {
      "id": 5608,
      "jozz": 29,
      "page": 579,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويسقون فيها كأسا كان مزاجها زنجبيلا"
    },
    {
      "id": 5609,
      "jozz": 29,
      "page": 579,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 18,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عينا فيها تسمى سلسبيلا"
    },
    {
      "id": 5610,
      "jozz": 29,
      "page": 579,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويطوف عليهم ولدان مخلدون إذا رأيتهم حسبتهم لؤلؤا منثورا"
    },
    {
      "id": 5611,
      "jozz": 29,
      "page": 579,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 20,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا رأيت ثم رأيت نعيما وملكا كبيرا"
    },
    {
      "id": 5612,
      "jozz": 29,
      "page": 579,
      "line_start": 11,
      "line_end": 13,
      "aya_no": 21,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عاليهم ثياب سندس خضر وإستبرق وحلوا أساور من فضة وسقاهم ربهم شرابا طهورا"
    },
    {
      "id": 5613,
      "jozz": 29,
      "page": 579,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 22,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هذا كان لكم جزاء وكان سعيكم مشكورا"
    },
    {
      "id": 5614,
      "jozz": 29,
      "page": 579,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 23,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا نحن نزلنا عليك القرآن تنزيلا"
    },
    {
      "id": 5615,
      "jozz": 29,
      "page": 579,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 24,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاصبر لحكم ربك ولا تطع منهم آثما أو كفورا"
    },
    {
      "id": 5616,
      "jozz": 29,
      "page": 579,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 25,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "واذكر اسم ربك بكرة وأصيلا"
    },
    {
      "id": 5617,
      "jozz": 29,
      "page": 580,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 26,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن الليل فاسجد له وسبحه ليلا طويلا"
    },
    {
      "id": 5618,
      "jozz": 29,
      "page": 580,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 27,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هؤلاء يحبون العاجلة ويذرون وراءهم يوما ثقيلا"
    },
    {
      "id": 5619,
      "jozz": 29,
      "page": 580,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 28,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "نحن خلقناهم وشددنا أسرهم وإذا شئنا بدلنا أمثالهم تبديلا"
    },
