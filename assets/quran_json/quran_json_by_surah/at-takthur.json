  "verses": [
    {
      "id": 6169,
      "jozz": 30,
      "page": 600,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألهاكم التكاثر"
    },
    {
      "id": 6170,
      "jozz": 30,
      "page": 600,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "حتى زرتم المقابر"
    },
    {
      "id": 6171,
      "jozz": 30,
      "page": 600,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 3,
      "aya_text": "‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا سوف تعلمون"
    },
    {
      "id": 6172,
      "jozz": 30,
      "page": 600,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 4,
      "aya_text": "‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم كلا سوف تعلمون"
    },
    {
      "id": 6173,
      "jozz": 30,
      "page": 600,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 5,
      "aya_text": "‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا لو تعلمون علم اليقين"
    },
    {
      "id": 6174,
      "jozz": 30,
      "page": 600,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لترون الجحيم"
    },
    {
      "id": 6175,
      "jozz": 30,
      "page": 600,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 7,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم لترونها عين اليقين"
    },
    {
      "id": 6176,
      "jozz": 30,
      "page": 600,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 8,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم لتسألن يومئذ عن النعيم"
    }
  ]
}