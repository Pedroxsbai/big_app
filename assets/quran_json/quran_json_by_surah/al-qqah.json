{
  "metadata": {
    "sura_no": 69,
    "sura_name_en": "Al-Ḥāqqah",
    "sura_name_ar": "الحَاقة",
    "total_verses": 52,
    "created_at": "2025-10-11T18:45:17.959Z"
  },
  "verses": [
    {
      "id": 5324,
      "jozz": 29,
      "page": 566,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الحاقة"
    },
    {
      "id": 5325,
      "jozz": 29,
      "page": 566,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما الحاقة"
    },
    {
      "id": 5326,
      "jozz": 29,
      "page": 566,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أدراك ما الحاقة"
    },
    {
      "id": 5327,
      "jozz": 29,
      "page": 566,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 4,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذبت ثمود وعاد بالقارعة"
    },
    {
      "id": 5328,
      "jozz": 29,
      "page": 566,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأما ثمود فأهلكوا بالطاغية"
    },
    {
      "id": 5329,
      "jozz": 29,
      "page": 566,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما عاد فأهلكوا بريح صرصر عاتية"
    },
    {
      "id": 5330,
      "jozz": 29,
      "page": 566,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سخرها عليهم سبع ليال وثمانية أيام حسوما فترى القوم فيها صرعى كأنهم أعجاز نخل خاوية"
    },
    {
      "id": 5331,
      "jozz": 29,
      "page": 566,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فهل ترى لهم من باقية"
    },
    {
      "id": 5332,
      "jozz": 29,
      "page": 567,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 9,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجاء فرعون ومن قبله والمؤتفكات بالخاطئة"
    },
    {
      "id": 5333,
      "jozz": 29,
      "page": 567,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فعصوا رسول ربهم فأخذهم أخذة رابية"
    },
    {
      "id": 5334,
      "jozz": 29,
      "page": 567,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 11,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا لما طغى الماء حملناكم في الجارية"
    },
    {
      "id": 5335,
      "jozz": 29,
      "page": 567,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لنجعلها لكم تذكرة وتعيها أذن واعية"
    },
    {
      "id": 5336,
      "jozz": 29,
      "page": 567,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فإذا نفخ في الصور نفخة واحدة"
    },
    {
      "id": 5337,
      "jozz": 29,
      "page": 567,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 14,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وحملت الأرض والجبال فدكتا دكة واحدة"
    },
    {
      "id": 5338,
      "jozz": 29,
      "page": 567,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فيومئذ وقعت الواقعة"
    },
    {
      "id": 5339,
      "jozz": 29,
      "page": 567,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وانشقت السماء فهي يومئذ واهية"
    },
    {
      "id": 5340,
      "jozz": 29,
      "page": 567,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والملك على أرجائها ويحمل عرش ربك فوقهم يومئذ ثمانية"
    },
    {
      "id": 5341,
      "jozz": 29,
      "page": 567,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 18,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يومئذ تعرضون لا تخفى منكم خافية"
    },
    {
      "id": 5342,
      "jozz": 29,
      "page": 567,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 19,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأما من أوتي كتابه بيمينه فيقول هاؤم اقرءوا كتابيه"
    },
    {
      "id": 5343,
      "jozz": 29,
      "page": 567,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 20,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إني ظننت أني ملاق حسابيه"
    },
    {
      "id": 5344,
      "jozz": 29,
      "page": 567,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 21,
      "aya_text": "‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فهو في عيشة راضية"
    },
    {
      "id": 5345,
      "jozz": 29,
      "page": 567,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 22,
      "aya_text": "‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "في جنة عالية"
    },
    {
      "id": 5346,
      "jozz": 29,
      "page": 567,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 23,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قطوفها دانية"
    },
    {
      "id": 5347,
      "jozz": 29,
      "page": 567,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 24,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلوا واشربوا هنيئا بما أسلفتم في الأيام الخالية"
    },
    {
      "id": 5348,
      "jozz": 29,
      "page": 567,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 25,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما من أوتي كتابه بشماله فيقول ياليتني لم أوت كتابيه"
    },
    {
      "id": 5349,
      "jozz": 29,
      "page": 567,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 26,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولم أدر ما حسابيه"
    },
    {
      "id": 5350,
      "jozz": 29,
      "page": 567,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 27,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يا‎ليتها كانت القاضية"
    },
    {
      "id": 5351,
      "jozz": 29,
      "page": 567,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 28,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ما أغنى عني ماليه"
    },
    {
      "id": 5352,
      "jozz": 29,
      "page": 567,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 29,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هلك عني سلطانيه"
    },
    {
      "id": 5353,
      "jozz": 29,
      "page": 567,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 30,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "خذوه فغلوه"
    },
    {
      "id": 5354,
      "jozz": 29,
      "page": 567,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 31,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم الجحيم صلوه"
    },
    {
      "id": 5355,
      "jozz": 29,
      "page": 567,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 32,
      "aya_text": "‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم في سلسلة ذرعها سبعون ذراعا فاسلكوه"
    },
    {
      "id": 5356,
      "jozz": 29,
      "page": 567,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 33,
      "aya_text": "‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه كان لا يؤمن بالله العظيم"
    },
    {
      "id": 5357,
      "jozz": 29,
      "page": 567,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 34,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا يحض على طعام المسكين"
    },
    {
      "id": 5358,
      "jozz": 29,
      "page": 567,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 35,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فليس له اليوم هاهنا حميم"
    },
    {
      "id": 5359,
      "jozz": 29,
      "page": 568,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 36,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا طعام إلا من غسلين"
    },
    {
      "id": 5360,
      "jozz": 29,
      "page": 568,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 37,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يأكله إلا الخاطئون"
    },
    {
      "id": 5361,
      "jozz": 29,
      "page": 568,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 38,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلا أقسم بما تبصرون"
    },
    {
      "id": 5362,
      "jozz": 29,
      "page": 568,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 39,
      "aya_text": "‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما لا تبصرون"
    },
    {
      "id": 5363,
      "jozz": 29,
      "page": 568,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 40,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه لقول رسول كريم"
    },
    {
      "id": 5364,
      "jozz": 29,
      "page": 568,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 41,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما هو بقول شاعر قليلا ما تؤمنون"
    },
    {
      "id": 5365,
      "jozz": 29,
      "page": 568,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 42,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا بقول كاهن قليلا ما تذكرون"
    },
    {
      "id": 5366,
      "jozz": 29,
      "page": 568,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 43,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "تنزيل من رب العالمين"
    },
    {
      "id": 5367,
      "jozz": 29,
      "page": 568,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 44,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولو تقول علينا بعض الأقاويل"
    },
    {
      "id": 5368,
      "jozz": 29,
      "page": 568,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 45,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لأخذنا منه باليمين"
    },
    {
      "id": 5369,
      "jozz": 29,
      "page": 568,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 46,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم لقطعنا منه الوتين"
    },
    {
      "id": 5370,
      "jozz": 29,
      "page": 568,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 47,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما منكم من أحد عنه حاجزين"
    },
    {
      "id": 5371,
      "jozz": 29,
      "page": 568,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 48,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنه لتذكرة للمتقين"
    },
    {
      "id": 5372,
      "jozz": 29,
      "page": 568,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 49,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنا لنعلم أن منكم مكذبين"
    },
    {
      "id": 5373,
      "jozz": 29,
      "page": 568,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 50,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنه لحسرة على الكافرين"
    },
    {
      "id": 5374,
      "jozz": 29,
      "page": 568,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 51,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنه لحق اليقين"
    },
    {
      "id": 5375,
      "jozz": 29,
      "page": 568,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 52,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فسبح باسم ربك العظيم"
    }
  ]
}