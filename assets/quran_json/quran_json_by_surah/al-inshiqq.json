{
  "metadata": {
    "sura_no": 84,
    "sura_name_en": "Al-Inshiqāq",
    "sura_name_ar": "الانشِقَاق",
    "total_verses": 25,
    "created_at": "2025-10-11T18:45:17.975Z"
  },
  "verses": [
    {
      "id": 5885,
      "jozz": 30,
      "page": 589,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 1,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذا السماء انشقت"
    },
    {
      "id": 5886,
      "jozz": 30,
      "page": 589,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأذنت لربها وحقت"
    },
    {
      "id": 5887,
      "jozz": 30,
      "page": 589,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وإذا الأرض مدت"
    },
    {
      "id": 5888,
      "jozz": 30,
      "page": 589,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 4,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وألقت ما فيها وتخلت"
    },
    {
      "id": 5889,
      "jozz": 30,
      "page": 589,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأذنت لربها وحقت"
    },
    {
      "id": 5890,
      "jozz": 30,
      "page": 589,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأيها الإنسان إنك كادح إلى ربك كدحا فملاقيه"
    },
    {
      "id": 5891,
      "jozz": 30,
      "page": 589,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 7,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأما من أوتي كتابه بيمينه"
    },
    {
      "id": 5892,
      "jozz": 30,
      "page": 589,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 8,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فسوف يحاسب حسابا يسيرا"
    },
    {
      "id": 5893,
      "jozz": 30,
      "page": 589,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وينقلب إلى أهله مسرورا"
    },
    {
      "id": 5894,
      "jozz": 30,
      "page": 589,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 10,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما من أوتي كتابه وراء ظهره"
    },
    {
      "id": 5895,
      "jozz": 30,
      "page": 589,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فسوف يدعو ثبورا"
    },
    {
      "id": 5896,
      "jozz": 30,
      "page": 589,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 12,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويصلى سعيرا"
    },
    {
      "id": 5897,
      "jozz": 30,
      "page": 589,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه كان في أهله مسرورا"
    },
    {
      "id": 5898,
      "jozz": 30,
      "page": 589,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 14,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه ظن أن لن يحور"
    },
    {
      "id": 5899,
      "jozz": 30,
      "page": 589,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 15,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بلى إن ربه كان به بصيرا"
    },
    {
      "id": 5900,
      "jozz": 30,
      "page": 589,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 16,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلا أقسم بالشفق"
    },
    {
      "id": 5901,
      "jozz": 30,
      "page": 589,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 17,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "والليل وما وسق"
    },
    {
      "id": 5902,
      "jozz": 30,
      "page": 589,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 18,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والقمر إذا اتسق"
    },
    {
      "id": 5903,
      "jozz": 30,
      "page": 589,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "لتركبن طبقا عن طبق"
    },
    {
      "id": 5904,
      "jozz": 30,
      "page": 589,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 20,
      "aya_text": "‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما لهم لا يؤمنون"
    },
    {
      "id": 5905,
      "jozz": 30,
      "page": 589,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 21,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏ ‏",
      "aya_text_emlaey": "وإذا قرئ عليهم القرآن لا يسجدون"
    },
    {
      "id": 5906,
      "jozz": 30,
      "page": 589,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 22,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل الذين كفروا يكذبون"
    },
    {
      "id": 5907,
      "jozz": 30,
      "page": 589,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 23,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والله أعلم بما يوعون"
    },
    {
      "id": 5908,
      "jozz": 30,
      "page": 589,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 24,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فبشرهم بعذاب أليم"
    },
    {
      "id": 5909,
      "jozz": 30,
      "page": 590,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 25,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا الذين آمنوا وعملوا الصالحات لهم أجر غير ممنون"
    }
  ]
}