{
  "metadata": {
    "sura_no": 70,
    "sura_name_en": "Al-Ma‘ārij",
    "sura_name_ar": "المَعَارج",
    "total_verses": 44,
    "created_at": "2025-10-11T18:45:17.960Z"
  },
  "verses": [
    {
      "id": 5376,
      "jozz": 29,
      "page": 568,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 1,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "سأل سائل بعذاب واقع"
    },
    {
      "id": 5377,
      "jozz": 29,
      "page": 568,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "للكافرين ليس له دافع"
    },
    {
      "id": 5378,
      "jozz": 29,
      "page": 568,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 3,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "من الله ذي المعارج"
    },
    {
      "id": 5379,
      "jozz": 29,
      "page": 568,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 4,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "تعرج الملائكة والروح إليه في يوم كان مقداره خمسين ألف سنة"
    },
    {
      "id": 5380,
      "jozz": 29,
      "page": 568,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فاصبر صبرا جميلا"
    },
    {
      "id": 5381,
      "jozz": 29,
      "page": 568,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنهم يرونه بعيدا"
    },
    {
      "id": 5382,
      "jozz": 29,
      "page": 568,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونراه قريبا"
    },
    {
      "id": 5383,
      "jozz": 29,
      "page": 568,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم تكون السماء كالمهل"
    },
    {
      "id": 5384,
      "jozz": 29,
      "page": 568,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وتكون الجبال كالعهن"
    },
    {
      "id": 5385,
      "jozz": 29,
      "page": 568,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 10,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا يسأل حميم حميما"
    },
    {
      "id": 5386,
      "jozz": 29,
      "page": 569,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يبصرونهم يود المجرم لو يفتدي من عذاب يومئذ ببنيه"
    },
    {
      "id": 5387,
      "jozz": 29,
      "page": 569,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وصاحبته وأخيه"
    },
    {
      "id": 5388,
      "jozz": 29,
      "page": 569,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 13,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وفصيلته التي تؤويه"
    },
    {
      "id": 5389,
      "jozz": 29,
      "page": 569,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن في الأرض جميعا ثم ينجيه"
    },
    {
      "id": 5390,
      "jozz": 29,
      "page": 569,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 15,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "كلا إنها لظى"
    },
    {
      "id": 5391,
      "jozz": 29,
      "page": 569,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "نزاعة للشوى"
    },
    {
      "id": 5392,
      "jozz": 29,
      "page": 569,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "تدعو من أدبر وتولى"
    },
    {
      "id": 5393,
      "jozz": 29,
      "page": 569,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 18,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وجمع فأوعى"
    },
    {
      "id": 5394,
      "jozz": 29,
      "page": 569,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الإنسان خلق هلوعا"
    },
    {
      "id": 5395,
      "jozz": 29,
      "page": 569,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 20,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذا مسه الشر جزوعا"
    },
    {
      "id": 5396,
      "jozz": 29,
      "page": 569,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 21,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا مسه الخير منوعا"
    },
    {
      "id": 5397,
      "jozz": 29,
      "page": 569,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 22,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا المصلين"
    },
    {
      "id": 5398,
      "jozz": 29,
      "page": 569,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 23,
      "aya_text": "‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين هم على صلاتهم دائمون"
    },
    {
      "id": 5399,
      "jozz": 29,
      "page": 569,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 24,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين في أموالهم حق معلوم"
    },
    {
      "id": 5400,
      "jozz": 29,
      "page": 569,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 25,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "للسائل والمحروم"
    },
    {
      "id": 5401,
      "jozz": 29,
      "page": 569,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 26,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين يصدقون بيوم الدين"
    },
    {
      "id": 5402,
      "jozz": 29,
      "page": 569,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 27,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين هم من عذاب ربهم مشفقون"
    },
    {
      "id": 5403,
      "jozz": 29,
      "page": 569,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 28,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن عذاب ربهم غير مأمون"
    },
    {
      "id": 5404,
      "jozz": 29,
      "page": 569,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 29,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين هم لفروجهم حافظون"
    },
    {
      "id": 5405,
      "jozz": 29,
      "page": 569,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 30,
      "aya_text": "‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا على أزواجهم أو ما ملكت أيمانهم فإنهم غير ملومين"
    },
    {
      "id": 5406,
      "jozz": 29,
      "page": 569,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 31,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فمن ابتغى وراء ذلك فأولئك هم العادون"
    },
    {
      "id": 5407,
      "jozz": 29,
      "page": 569,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 32,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين هم لأماناتهم وعهدهم راعون"
    },
    {
      "id": 5408,
      "jozz": 29,
      "page": 569,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 33,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين هم بشهاداتهم قائمون"
    },
    {
      "id": 5409,
      "jozz": 29,
      "page": 569,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 34,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين هم على صلاتهم يحافظون"
    },
    {
      "id": 5410,
      "jozz": 29,
      "page": 569,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 35,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أولئك في جنات مكرمون"
    },
    {
      "id": 5411,
      "jozz": 29,
      "page": 569,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 36,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فمال الذين كفروا قبلك مهطعين"
    },
    {
      "id": 5412,
      "jozz": 29,
      "page": 569,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 37,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "عن اليمين وعن الشمال عزين"
    },
    {
      "id": 5413,
      "jozz": 29,
      "page": 569,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 38,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أيطمع كل امرئ منهم أن يدخل جنة نعيم"
    },
    {
      "id": 5414,
      "jozz": 29,
      "page": 569,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 39,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا إنا خلقناهم مما يعلمون"
    },
    {
      "id": 5415,
      "jozz": 29,
      "page": 569,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 40,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلا أقسم برب المشارق والمغارب إنا لقادرون"
