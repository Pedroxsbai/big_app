{
  "metadata": {
    "sura_no": 90,
    "sura_name_en": "Al-Balad",
    "sura_name_ar": "البَلَد",
    "total_verses": 20,
    "created_at": "2025-10-11T18:45:17.983Z"
  },
  "verses": [
    {
      "id": 6024,
      "jozz": 30,
      "page": 594,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 1,
      "aya_text": "‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لا أقسم بهذا البلد"
    },
    {
      "id": 6025,
      "jozz": 30,
      "page": 594,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 2,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنت حل بهذا البلد"
    },
    {
      "id": 6026,
      "jozz": 30,
      "page": 594,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "ووالد وما ولد"
    },
    {
      "id": 6027,
      "jozz": 30,
      "page": 594,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏",
      "aya_text_emlaey": "لقد خلقنا الإنسان في كبد"
    },
    {
      "id": 6028,
      "jozz": 30,
      "page": 594,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أيحسب أن لن يقدر عليه أحد"
    },
    {
      "id": 6029,
      "jozz": 30,
      "page": 594,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "يقول أهلكت مالا لبدا"
    },
    {
      "id": 6030,
      "jozz": 30,
      "page": 594,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 7,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أيحسب أن لم يره أحد"
    },
    {
      "id": 6031,
      "jozz": 30,
      "page": 594,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم نجعل له عينين"
    },
    {
      "id": 6032,
      "jozz": 30,
      "page": 594,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولسانا وشفتين"
    },
    {
      "id": 6033,
      "jozz": 30,
      "page": 594,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وهديناه النجدين"
    },
    {
      "id": 6034,
      "jozz": 30,
      "page": 594,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 11,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلا اقتحم العقبة"
    },
    {
      "id": 6035,
      "jozz": 30,
      "page": 594,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 12,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أدراك ما العقبة"
    },
    {
      "id": 6036,
      "jozz": 30,
      "page": 594,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 13,
      "aya_text": "‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فك رقبة"
    },
    {
      "id": 6037,
      "jozz": 30,
      "page": 594,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 14,
      "aya_text": "‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أو إطعام في يوم ذي مسغبة"
    },
    {
      "id": 6038,
      "jozz": 30,
      "page": 594,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يتيما ذا مقربة"
    },
    {
      "id": 6039,
      "jozz": 30,
      "page": 594,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 16,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أو مسكينا ذا متربة"
    },
    {
      "id": 6040,
      "jozz": 30,
      "page": 594,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم كان من الذين آمنوا وتواصوا بالصبر وتواصوا بالمرحمة"
    },
    {
      "id": 6041,
      "jozz": 30,
      "page": 594,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 18,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أولئك أصحاب الميمنة"
    },
    {
      "id": 6042,
      "jozz": 30,
      "page": 595,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين كفروا بآياتنا هم أصحاب المشأمة"
    },
    {
      "id": 6043,
      "jozz": 30,
      "page": 595,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عليهم نار مؤصدة"
    }
  ]
}