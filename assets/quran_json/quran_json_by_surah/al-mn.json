  },
  "verses": [
    {
      "id": 6198,
      "jozz": 30,
      "page": 602,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أرأيت الذي يكذب بالدين"
    },
    {
      "id": 6199,
      "jozz": 30,
      "page": 602,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 2,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فذلك الذي يدع اليتيم"
    },
    {
      "id": 6200,
      "jozz": 30,
      "page": 602,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 3,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا يحض على طعام المسكين"
    },
    {
      "id": 6201,
      "jozz": 30,
      "page": 602,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 4,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فويل للمصلين"
    },
    {
      "id": 6202,
      "jozz": 30,
      "page": 602,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين هم عن صلاتهم ساهون"
    },
    {
      "id": 6203,
      "jozz": 30,
      "page": 602,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين هم يراءون"
    },
    {
      "id": 6204,
      "jozz": 30,
      "page": 602,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويمنعون الماعون"
    }
  ]
}