{
  "metadata": {
    "sura_no": 53,
    "sura_name_en": "An-Najm",
    "sura_name_ar": "النَّجم",
    "total_verses": 62,
    "created_at": "2025-10-11T18:45:17.943Z"
  },
  "verses": [
    {
      "id": 4785,
      "jozz": 27,
      "page": 526,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "والنجم إذا هوى"
    },
    {
      "id": 4786,
      "jozz": 27,
      "page": 526,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ما ضل صاحبكم وما غوى"
    },
    {
      "id": 4787,
      "jozz": 27,
      "page": 526,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما ينطق عن الهوى"
    },
    {
      "id": 4788,
      "jozz": 27,
      "page": 526,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 4,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إن هو إلا وحي يوحى"
    },
    {
      "id": 4789,
      "jozz": 27,
      "page": 526,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "علمه شديد القوى"
    },
    {
      "id": 4790,
      "jozz": 27,
      "page": 526,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 6,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذو مرة فاستوى"
    },
    {
      "id": 4791,
      "jozz": 27,
      "page": 526,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وهو بالأفق الأعلى"
    },
    {
      "id": 4792,
      "jozz": 27,
      "page": 526,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 8,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم دنا فتدلى"
    },
    {
      "id": 4793,
      "jozz": 27,
      "page": 526,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 9,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فكان قاب قوسين أو أدنى"
    },
    {
      "id": 4794,
      "jozz": 27,
      "page": 526,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 10,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فأوحى إلى عبده ما أوحى"
    },
    {
      "id": 4795,
      "jozz": 27,
      "page": 526,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 11,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ما كذب الفؤاد ما رأى"
    },
    {
      "id": 4796,
      "jozz": 27,
      "page": 526,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أفتمارونه على ما يرى"
    },
    {
      "id": 4797,
      "jozz": 27,
      "page": 526,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد رآه نزلة أخرى"
    },
    {
      "id": 4798,
      "jozz": 27,
      "page": 526,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عند سدرة المنتهى"
    },
    {
      "id": 4799,
      "jozz": 27,
      "page": 526,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عندها جنة المأوى"
    },
    {
      "id": 4800,
      "jozz": 27,
      "page": 526,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 16,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إذ يغشى السدرة ما يغشى"
    },
    {
      "id": 4801,
      "jozz": 27,
      "page": 526,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "ما زاغ البصر وما طغى"
    },
    {
      "id": 4802,
      "jozz": 27,
      "page": 526,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 18,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لقد رأى من آيات ربه الكبرى"
    },
    {
      "id": 4803,
      "jozz": 27,
      "page": 526,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفرأيتم اللات والعزى"
    },
    {
      "id": 4804,
      "jozz": 27,
      "page": 526,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومناة الثالثة الأخرى"
    },
    {
      "id": 4805,
      "jozz": 27,
      "page": 526,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 21,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألكم الذكر وله الأنثى"
    },
    {
      "id": 4806,
      "jozz": 27,
      "page": 526,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 22,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "تلك إذا قسمة ضيزى"
    },
    {
      "id": 4807,
      "jozz": 27,
      "page": 526,
      "line_start": 11,
      "line_end": 13,
      "aya_no": 23,
      "aya_text": "‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هي إلا أسماء سميتموها أنتم وآباؤكم ما أنزل الله بها من سلطان إن يتبعون إلا الظن وما تهوى الأنفس ولقد جاءهم من ربهم الهدى"
    },
    {
      "id": 4808,
      "jozz": 27,
      "page": 526,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 24,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أم للإنسان ما تمنى"
    },
    {
      "id": 4809,
      "jozz": 27,
      "page": 526,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 25,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلله الآخرة والأولى"
    },
    {
      "id": 4810,
      "jozz": 27,
      "page": 526,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 26,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وكم من ملك في السموات لا تغني شفاعتهم شيئا إلا من بعد أن يأذن الله لمن يشاء ويرضى"
    },
    {
      "id": 4811,
      "jozz": 27,
      "page": 527,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 27,
      "aya_text": "‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين لا يؤمنون بالآخرة ليسمون الملائكة تسمية الأنثى"
    },
    {
      "id": 4812,
      "jozz": 27,
      "page": 527,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 28,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وما لهم به من علم إن يتبعون إلا الظن وإن الظن لا يغني من الحق شيئا"
    },
    {
      "id": 4813,
      "jozz": 27,
      "page": 527,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 29,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأعرض عن من تولى عن ذكرنا ولم يرد إلا الحياة الدنيا"
    },
    {
      "id": 4814,
      "jozz": 27,
      "page": 527,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 30,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذلك مبلغهم من العلم إن ربك هو أعلم بمن ضل عن سبيله وهو أعلم بمن اهتدى"
    },
    {
      "id": 4815,
      "jozz": 27,
      "page": 527,
      "line_start": 5,
      "line_end": 7,
      "aya_no": 31,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولله ما في السموات وما في الأرض ليجزي الذين أساءوا بما عملوا ويجزي الذين أحسنوا بالحسنى"
    },
    {
      "id": 4816,
      "jozz": 27,
      "page": 527,
      "line_start": 7,
      "line_end": 10,
      "aya_no": 32,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "الذين يجتنبون كبائر الإثم والفواحش إلا اللمم إن ربك واسع المغفرة هو أعلم بكم إذ أنشأكم من الأرض وإذ أنتم أجنة في بطون أمهاتكم فلا تزكوا أنفسكم هو أعلم بمن اتقى"
    },
    {
      "id": 4817,
      "jozz": 27,
      "page": 527,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 33,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أفرأيت الذي تولى"
    },
    {
      "id": 4818,
      "jozz": 27,
      "page": 527,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 34,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأعطى قليلا وأكدى"
    },
    {
      "id": 4819,
      "jozz": 27,
      "page": 527,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 35,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أعنده علم الغيب فهو يرى"
    },
    {
      "id": 4820,
      "jozz": 27,
      "page": 527,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 36,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أم لم ينبأ بما في صحف موسى"
    },
    {
      "id": 4821,
      "jozz": 27,
      "page": 527,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 37,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "وإبراهيم الذي وفى"
    },
    {
      "id": 4822,
      "jozz": 27,
      "page": 527,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 38,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألا تزر وازرة وزر أخرى"
    },
    {
      "id": 4823,
      "jozz": 27,
      "page": 527,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 39,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏",
      "aya_text_emlaey": "وأن ليس للإنسان إلا ما سعى"
    },
    {
      "id": 4824,
      "jozz": 27,
      "page": 527,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 40,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وأن سعيه سوف يرى"
    },
    {
      "id": 4825,
      "jozz": 27,
      "page": 527,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 41,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم يجزاه الجزاء الأوفى"
    },
    {
      "id": 4826,
      "jozz": 27,
      "page": 527,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 42,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأن إلى ربك المنتهى"
    },
    {
      "id": 4827,
      "jozz": 27,
      "page": 527,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 43,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنه هو أضحك وأبكى"
    },
    {
      "id": 4828,
      "jozz": 27,
      "page": 527,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 44,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنه هو أمات وأحيا"
    },
    {
      "id": 4829,
      "jozz": 27,
      "page": 528,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 45,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنه خلق الزوجين الذكر والأنثى"
    },
    {
      "id": 4830,
      "jozz": 27,
      "page": 528,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 46,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "من نطفة إذا تمنى"
    },
    {
      "id": 4831,
      "jozz": 27,
      "page": 528,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 47,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأن عليه النشأة الأخرى"
    },
    {
      "id": 4832,
      "jozz": 27,
      "page": 528,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 48,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنه هو أغنى وأقنى"
    },
    {
      "id": 4833,
      "jozz": 27,
      "page": 528,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 49,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنه هو رب الشعرى"
    },
    {
      "id": 4834,
      "jozz": 27,
      "page": 528,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 50,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنه أهلك عادا الأولى"
    },
    {
      "id": 4835,
      "jozz": 27,
      "page": 528,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 51,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وثمود فما أبقى"
    },
    {
      "id": 4836,
      "jozz": 27,
      "page": 528,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 52,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وقوم نوح من قبل إنهم كانوا هم أظلم وأطغى"
    },
    {
      "id": 4837,
      "jozz": 27,
      "page": 528,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 53,
      "aya_text": "‏‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والمؤتفكة أهوى"
    },
    {
      "id": 4838,
      "jozz": 27,
      "page": 528,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 54,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏ ‏",
      "aya_text_emlaey": "فغشاها ما غشى"
    },
    {
      "id": 4839,
      "jozz": 27,
      "page": 528,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 55,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فبأي آلاء ربك تتمارى"
    },
    {
      "id": 4840,
      "jozz": 27,
      "page": 528,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 56,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "هذا نذير من النذر الأولى"
    },
    {
      "id": 4841,
      "jozz": 27,
      "page": 528,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 57,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أزفت الآزفة"
    },
    {
      "id": 4842,
      "jozz": 27,
      "page": 528,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 58,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ليس لها من دون الله كاشفة"
    },
    {
      "id": 4843,
      "jozz": 27,
      "page": 528,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 59,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفمن هذا الحديث تعجبون"
    },
    {
      "id": 4844,
      "jozz": 27,
      "page": 528,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 60,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وتضحكون ولا تبكون"
    },
    {
      "id": 4845,
      "jozz": 27,
      "page": 528,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 61,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنتم سامدون"
    },
    {
      "id": 4846,
      "jozz": 27,
      "page": 528,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 62,
      "aya_text": "‏ ‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاسجدوا لله واعبدوا"
    }
  ]
}