  "verses": [
    {
      "id": 6099,
      "jozz": 30,
      "page": 597,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والتين والزيتون"
    },
    {
      "id": 6100,
      "jozz": 30,
      "page": 597,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وطور سينين"
    },
    {
      "id": 6101,
      "jozz": 30,
      "page": 597,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 3,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وهذا البلد الأمين"
    },
    {
      "id": 6102,
      "jozz": 30,
      "page": 597,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لقد خلقنا الإنسان في أحسن تقويم"
    },
    {
      "id": 6103,
      "jozz": 30,
      "page": 597,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 5,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم رددناه أسفل سافلين"
    },
    {
      "id": 6104,
      "jozz": 30,
      "page": 597,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 6,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا الذين آمنوا وعملوا الصالحات فلهم أجر غير ممنون"
    },
    {
      "id": 6105,
      "jozz": 30,
      "page": 597,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما يكذبك بعد بالدين"
    },
    {
      "id": 6106,
      "jozz": 30,
      "page": 597,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أليس الله بأحكم الحاكمين"
    }
  ]
}