      "id": 6228,
      "jozz": 30,
      "page": 604,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ومن شر غاسق إذا وقب"
