{
  "metadata": {
    "sura_no": 37,
    "sura_name_en": "Aṣ-Ṣāffāt",
    "sura_name_ar": "الصَّافَات",
    "total_verses": 182,
    "created_at": "2025-10-11T18:45:17.922Z"
  },
  "verses": [
    {
      "id": 3789,
      "jozz": 23,
      "page": 446,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "والصافات صفا"
    },
    {
      "id": 3790,
      "jozz": 23,
      "page": 446,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالزاجرات زجرا"
    },
    {
      "id": 3791,
      "jozz": 23,
      "page": 446,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالتاليات ذكرا"
    },
    {
      "id": 3792,
      "jozz": 23,
      "page": 446,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 4,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن إلهكم لواحد"
    },
    {
      "id": 3793,
      "jozz": 23,
      "page": 446,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 5,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "رب السموات والأرض وما بينهما ورب المشارق"
    },
    {
      "id": 3794,
      "jozz": 23,
      "page": 446,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 6,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا زينا السماء الدنيا بزينة الكواكب"
    },
    {
      "id": 3795,
      "jozz": 23,
      "page": 446,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وحفظا من كل شيطان مارد"
    },
    {
      "id": 3796,
      "jozz": 23,
      "page": 446,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 8,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يسمعون إلى الملإ الأعلى ويقذفون من كل جانب"
    },
    {
      "id": 3797,
      "jozz": 23,
      "page": 446,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "دحورا ولهم عذاب واصب"
    },
    {
      "id": 3798,
      "jozz": 23,
      "page": 446,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 10,
      "aya_text": "‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا من خطف الخطفة فأتبعه شهاب ثاقب"
    },
    {
      "id": 3799,
      "jozz": 23,
      "page": 446,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فاستفتهم أهم أشد خلقا أم من خلقنا إنا خلقناهم من طين لازب"
    },
    {
      "id": 3800,
      "jozz": 23,
      "page": 446,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 12,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل عجبت ويسخرون"
    },
    {
      "id": 3801,
      "jozz": 23,
      "page": 446,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 13,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا ذكروا لا يذكرون"
    },
    {
      "id": 3802,
      "jozz": 23,
      "page": 446,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا رأوا آية يستسخرون"
    },
    {
      "id": 3803,
      "jozz": 23,
      "page": 446,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وقالوا إن هذا إلا سحر مبين"
    },
    {
      "id": 3804,
      "jozz": 23,
      "page": 446,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 16,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أئذا متنا وكنا ترابا وعظاما أئنا لمبعوثون"
    },
    {
      "id": 3805,
      "jozz": 23,
      "page": 446,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أو آباؤنا الأولون"
    },
    {
      "id": 3806,
      "jozz": 23,
      "page": 446,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 18,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل نعم وأنتم داخرون"
    },
    {
      "id": 3807,
      "jozz": 23,
      "page": 446,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإنما هي زجرة واحدة فإذا هم ينظرون"
    },
    {
      "id": 3808,
      "jozz": 23,
      "page": 446,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وقالوا ياويلنا هذا يوم الدين"
    },
    {
      "id": 3809,
      "jozz": 23,
      "page": 446,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 21,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هذا يوم الفصل الذي كنتم به تكذبون"
    },
    {
      "id": 3810,
      "jozz": 23,
      "page": 446,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 22,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "احشروا الذين ظلموا وأزواجهم وما كانوا يعبدون"
    },
    {
      "id": 3811,
      "jozz": 23,
      "page": 446,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 23,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "من دون الله فاهدوهم إلى صراط الجحيم"
    },
    {
      "id": 3812,
      "jozz": 23,
      "page": 446,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 24,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقفوهم إنهم مسئولون"
    },
    {
      "id": 3813,
      "jozz": 23,
      "page": 447,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 25,
      "aya_text": "‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما لكم لا تناصرون"
    },
    {
      "id": 3814,
      "jozz": 23,
      "page": 447,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 26,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل هم اليوم مستسلمون"
    },
    {
      "id": 3815,
      "jozz": 23,
      "page": 447,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 27,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأقبل بعضهم على بعض يتساءلون"
    },
    {
      "id": 3816,
      "jozz": 23,
      "page": 447,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 28,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا إنكم كنتم تأتوننا عن اليمين"
    },
    {
      "id": 3817,
      "jozz": 23,
      "page": 447,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 29,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا بل لم تكونوا مؤمنين"
    },
    {
      "id": 3818,
      "jozz": 23,
      "page": 447,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 30,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وما كان لنا عليكم من سلطان بل كنتم قوما طاغين"
    },
    {
      "id": 3819,
      "jozz": 23,
      "page": 447,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 31,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فحق علينا قول ربنا إنا لذائقون"
    },
    {
      "id": 3820,
      "jozz": 23,
      "page": 447,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 32,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأغويناكم إنا كنا غاوين"
    },
    {
      "id": 3821,
      "jozz": 23,
      "page": 447,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 33,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإنهم يومئذ في العذاب مشتركون"
    },
    {
      "id": 3822,
      "jozz": 23,
      "page": 447,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 34,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا كذلك نفعل بالمجرمين"
    },
    {
      "id": 3823,
      "jozz": 23,
      "page": 447,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 35,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنهم كانوا إذا قيل لهم لا إله إلا الله يستكبرون"
    },
    {
      "id": 3824,
      "jozz": 23,
      "page": 447,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 36,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ويقولون أئنا لتاركوا آلهتنا لشاعر مجنون"
    },
    {
      "id": 3825,
      "jozz": 23,
      "page": 447,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 37,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل جاء بالحق وصدق المرسلين"
    },
    {
      "id": 3826,
      "jozz": 23,
      "page": 447,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 38,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنكم لذائقوا العذاب الأليم"
    },
    {
      "id": 3827,
      "jozz": 23,
      "page": 447,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 39,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما تجزون إلا ما كنتم تعملون"
    },
    {
      "id": 3828,
      "jozz": 23,
      "page": 447,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 40,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا عباد الله المخلصين"
    },
    {
      "id": 3829,
      "jozz": 23,
      "page": 447,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 41,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أولئك لهم رزق معلوم"
    },
    {
      "id": 3830,
      "jozz": 23,
      "page": 447,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 42,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فواكه وهم مكرمون"
    },
    {
      "id": 3831,
      "jozz": 23,
      "page": 447,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 43,
      "aya_text": "‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "في جنات النعيم"
    },
    {
      "id": 3832,
      "jozz": 23,
      "page": 447,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 44,
      "aya_text": "‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "على سرر متقابلين"
    },
    {
      "id": 3833,
      "jozz": 23,
      "page": 447,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 45,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يطاف عليهم بكأس من معين"
    },
    {
      "id": 3834,
      "jozz": 23,
      "page": 447,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 46,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بيضاء لذة للشاربين"
    },
    {
      "id": 3835,
      "jozz": 23,
      "page": 447,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 47,
      "aya_text": "‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا فيها غول ولا هم عنها ينزفون"
    },
    {
      "id": 3836,
      "jozz": 23,
      "page": 447,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 48,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "وعندهم قاصرات الطرف عين"
    },
    {
      "id": 3837,
      "jozz": 23,
      "page": 447,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 49,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كأنهن بيض مكنون"
    },
    {
      "id": 3838,
      "jozz": 23,
      "page": 447,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 50,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأقبل بعضهم على بعض يتساءلون"
    },
    {
      "id": 3839,
      "jozz": 23,
      "page": 447,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 51,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال قائل منهم إني كان لي قرين"
    },
    {
      "id": 3840,
      "jozz": 23,
      "page": 448,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 52,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يقول أئنك لمن المصدقين"
    },
    {
      "id": 3841,
      "jozz": 23,
      "page": 448,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 53,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أئذا متنا وكنا ترابا وعظاما أئنا لمدينون"
    },
    {
      "id": 3842,
      "jozz": 23,
      "page": 448,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 54,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال هل أنتم مطلعون"
    },
    {
      "id": 3843,
      "jozz": 23,
      "page": 448,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 55,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاطلع فرآه في سواء الجحيم"
    },
    {
      "id": 3844,
      "jozz": 23,
      "page": 448,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 56,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال تالله إن كدت لتردين"
    },
    {
      "id": 3845,
      "jozz": 23,
      "page": 448,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 57,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولولا نعمة ربي لكنت من المحضرين"
    },
    {
      "id": 3846,
      "jozz": 23,
      "page": 448,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 58,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفما نحن بميتين"
    },
    {
      "id": 3847,
      "jozz": 23,
      "page": 448,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 59,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا موتتنا الأولى وما نحن بمعذبين"
    },
    {
      "id": 3848,
      "jozz": 23,
      "page": 448,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 60,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هذا لهو الفوز العظيم"
    },
    {
      "id": 3849,
      "jozz": 23,
      "page": 448,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 61,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لمثل هذا فليعمل العاملون"
    },
    {
      "id": 3850,
      "jozz": 23,
      "page": 448,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 62,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أذلك خير نزلا أم شجرة الزقوم"
    },
    {
      "id": 3851,
      "jozz": 23,
      "page": 448,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 63,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا جعلناها فتنة للظالمين"
    },
    {
      "id": 3852,
      "jozz": 23,
      "page": 448,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 64,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنها شجرة تخرج في أصل الجحيم"
    },
    {
      "id": 3853,
      "jozz": 23,
      "page": 448,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 65,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "طلعها كأنه رءوس الشياطين"
    },
    {
      "id": 3854,
      "jozz": 23,
      "page": 448,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 66,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإنهم لآكلون منها فمالئون منها البطون"
    },
    {
      "id": 3855,
      "jozz": 23,
      "page": 448,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 67,
      "aya_text": "‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ثم إن لهم عليها لشوبا من حميم"
    },
    {
      "id": 3856,
      "jozz": 23,
      "page": 448,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 68,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم إن مرجعهم لإلى الجحيم"
    },
    {
      "id": 3857,
      "jozz": 23,
      "page": 448,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 69,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنهم ألفوا آباءهم ضالين"
    },
    {
      "id": 3858,
      "jozz": 23,
      "page": 448,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 70,
      "aya_text": "‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فهم على آثارهم يهرعون"
    },
    {
      "id": 3859,
      "jozz": 23,
      "page": 448,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 71,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد ضل قبلهم أكثر الأولين"
    },
    {
      "id": 3860,
      "jozz": 23,
      "page": 448,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 72,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد أرسلنا فيهم منذرين"
    },
    {
      "id": 3861,
      "jozz": 23,
      "page": 448,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 73,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فانظر كيف كان عاقبة المنذرين"
    },
    {
      "id": 3862,
      "jozz": 23,
      "page": 448,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 74,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا عباد الله المخلصين"
    },
    {
      "id": 3863,
      "jozz": 23,
      "page": 448,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 75,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد نادانا نوح فلنعم المجيبون"
    },
    {
      "id": 3864,
      "jozz": 23,
      "page": 448,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 76,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونجيناه وأهله من الكرب العظيم"
    },
    {
      "id": 3865,
      "jozz": 23,
      "page": 449,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 77,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلنا ذريته هم الباقين"
    },
    {
      "id": 3866,
      "jozz": 23,
      "page": 449,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 78,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وتركنا عليه في الآخرين"
    },
    {
      "id": 3867,
      "jozz": 23,
      "page": 449,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 79,
      "aya_text": "‏‏‏ ‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سلام على نوح في العالمين"
    },
    {
      "id": 3868,
      "jozz": 23,
      "page": 449,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 80,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا كذلك نجزي المحسنين"
    },
    {
      "id": 3869,
      "jozz": 23,
      "page": 449,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 81,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه من عبادنا المؤمنين"
    },
    {
      "id": 3870,
      "jozz": 23,
      "page": 449,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 82,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم أغرقنا الآخرين"
    },
    {
      "id": 3871,
      "jozz": 23,
      "page": 449,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 83,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن من شيعته لإبراهيم"
    },
    {
      "id": 3872,
      "jozz": 23,
      "page": 449,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 84,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ جاء ربه بقلب سليم"
    },
    {
      "id": 3873,
      "jozz": 23,
      "page": 449,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 85,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ قال لأبيه وقومه ماذا تعبدون"
    },
    {
      "id": 3874,
      "jozz": 23,
      "page": 449,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 86,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أئفكا آلهة دون الله تريدون"
    },
    {
      "id": 3875,
      "jozz": 23,
      "page": 449,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 87,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما ظنكم برب العالمين"
    },
    {
      "id": 3876,
      "jozz": 23,
      "page": 449,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 88,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فنظر نظرة في النجوم"
    },
    {
      "id": 3877,
      "jozz": 23,
      "page": 449,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 89,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فقال إني سقيم"
    },
    {
      "id": 3878,
      "jozz": 23,
      "page": 449,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 90,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فتولوا عنه مدبرين"
    },
    {
      "id": 3879,
      "jozz": 23,
      "page": 449,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 91,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فراغ إلى آلهتهم فقال ألا تأكلون"
    },
    {
      "id": 3880,
      "jozz": 23,
      "page": 449,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 92,
      "aya_text": "‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما لكم لا تنطقون"
    },
    {
      "id": 3881,
      "jozz": 23,
      "page": 449,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 93,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فراغ عليهم ضربا باليمين"
    },
    {
      "id": 3882,
      "jozz": 23,
      "page": 449,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 94,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأقبلوا إليه يزفون"
    },
    {
      "id": 3883,
      "jozz": 23,
      "page": 449,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 95,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال أتعبدون ما تنحتون"
    },
    {
      "id": 3884,
      "jozz": 23,
      "page": 449,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 96,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والله خلقكم وما تعملون"
    },
    {
      "id": 3885,
      "jozz": 23,
      "page": 449,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 97,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا ابنوا له بنيانا فألقوه في الجحيم"
    },
    {
      "id": 3886,
      "jozz": 23,
      "page": 449,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 98,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأرادوا به كيدا فجعلناهم الأسفلين"
    },
    {
      "id": 3887,
      "jozz": 23,
      "page": 449,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 99,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقال إني ذاهب إلى ربي سيهدين"
    },
    {
      "id": 3888,
      "jozz": 23,
      "page": 449,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 100,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "رب هب لي من الصالحين"
    },
    {
      "id": 3889,
      "jozz": 23,
      "page": 449,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 101,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فبشرناه بغلام حليم"
    },
    {
      "id": 3890,
      "jozz": 23,
      "page": 449,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 102,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلما بلغ معه السعي قال يابني إني أرى في المنام أني أذبحك فانظر ماذا ترى قال ياأبت افعل ما تؤمر ستجدني إن شاء الله من الصابرين"
    },
    {
      "id": 3891,
      "jozz": 23,
      "page": 450,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 103,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلما أسلما وتله للجبين"
    },
    {
      "id": 3892,
      "jozz": 23,
      "page": 450,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 104,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وناديناه أن ياإبراهيم"
    },
    {
      "id": 3893,
      "jozz": 23,
      "page": 450,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 105,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قد صدقت الرؤيا إنا كذلك نجزي المحسنين"
    },
    {
      "id": 3894,
      "jozz": 23,
      "page": 450,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 106,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هذا لهو البلاء المبين"
    },
    {
      "id": 3895,
      "jozz": 23,
      "page": 450,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 107,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وفديناه بذبح عظيم"
    },
    {
      "id": 3896,
      "jozz": 23,
      "page": 450,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 108,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وتركنا عليه في الآخرين"
    },
    {
      "id": 3897,
      "jozz": 23,
      "page": 450,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 109,
      "aya_text": "‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سلام على إبراهيم"
    },
    {
      "id": 3898,
      "jozz": 23,
      "page": 450,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 110,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذلك نجزي المحسنين"
    },
    {
      "id": 3899,
      "jozz": 23,
      "page": 450,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 111,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه من عبادنا المؤمنين"
    },
    {
      "id": 3900,
      "jozz": 23,
      "page": 450,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 112,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وبشرناه بإسحاق نبيا من الصالحين"
    },
    {
      "id": 3901,
      "jozz": 23,
      "page": 450,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 113,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وباركنا عليه وعلى إسحاق ومن ذريتهما محسن وظالم لنفسه مبين"
    },
    {
      "id": 3902,
      "jozz": 23,
      "page": 450,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 114,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد مننا على موسى وهارون"
    },
    {
      "id": 3903,
      "jozz": 23,
      "page": 450,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 115,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونجيناهما وقومهما من الكرب العظيم"
    },
    {
      "id": 3904,
      "jozz": 23,
      "page": 450,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 116,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونصرناهم فكانوا هم الغالبين"
    },
    {
      "id": 3905,
      "jozz": 23,
      "page": 450,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 117,
      "aya_text": "‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وآتيناهما الكتاب المستبين"
    },
    {
      "id": 3906,
      "jozz": 23,
      "page": 450,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 118,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وهديناهما الصراط المستقيم"
    },
    {
      "id": 3907,
      "jozz": 23,
      "page": 450,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 119,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وتركنا عليهما في الآخرين"
    },
    {
      "id": 3908,
      "jozz": 23,
      "page": 450,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 120,
      "aya_text": "‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سلام على موسى وهارون"
    },
    {
      "id": 3909,
      "jozz": 23,
      "page": 450,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 121,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا كذلك نجزي المحسنين"
    },
    {
      "id": 3910,
      "jozz": 23,
      "page": 450,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 122,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنهما من عبادنا المؤمنين"
    },
    {
      "id": 3911,
      "jozz": 23,
      "page": 450,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 123,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن إلياس لمن المرسلين"
    },
    {
      "id": 3912,
      "jozz": 23,
      "page": 450,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 124,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ قال لقومه ألا تتقون"
    },
    {
      "id": 3913,
      "jozz": 23,
      "page": 450,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 125,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أتدعون بعلا وتذرون أحسن الخالقين"
    },
    {
      "id": 3914,
      "jozz": 23,
      "page": 450,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 126,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الله ربكم ورب آبائكم الأولين"
    },
    {
      "id": 3915,
      "jozz": 23,
      "page": 451,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 127,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فكذبوه فإنهم لمحضرون"
    },
    {
      "id": 3916,
      "jozz": 23,
      "page": 451,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 128,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا عباد الله المخلصين"
    },
    {
      "id": 3917,
      "jozz": 23,
      "page": 451,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 129,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وتركنا عليه في الآخرين"
    },
    {
      "id": 3918,
      "jozz": 23,
      "page": 451,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 130,
      "aya_text": "‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "سلام على إل ياسين"
    },
    {
      "id": 3919,
      "jozz": 23,
      "page": 451,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 131,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا كذلك نجزي المحسنين"
    },
    {
      "id": 3920,
      "jozz": 23,
      "page": 451,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 132,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه من عبادنا المؤمنين"
    },
    {
      "id": 3921,
      "jozz": 23,
      "page": 451,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 133,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن لوطا لمن المرسلين"
    },
    {
      "id": 3922,
      "jozz": 23,
      "page": 451,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 134,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ نجيناه وأهله أجمعين"
    },
    {
      "id": 3923,
      "jozz": 23,
      "page": 451,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 135,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا عجوزا في الغابرين"
    },
    {
      "id": 3924,
      "jozz": 23,
      "page": 451,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 136,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم دمرنا الآخرين"
    },
    {
      "id": 3925,
      "jozz": 23,
      "page": 451,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 137,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنكم لتمرون عليهم مصبحين"
    },
    {
      "id": 3926,
      "jozz": 23,
      "page": 451,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 138,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وبالليل أفلا تعقلون"
    },
    {
      "id": 3927,
      "jozz": 23,
      "page": 451,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 139,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن يونس لمن المرسلين"
    },
    {
      "id": 3928,
      "jozz": 23,
      "page": 451,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 140,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ أبق إلى الفلك المشحون"
    },
    {
      "id": 3929,
      "jozz": 23,
      "page": 451,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 141,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فساهم فكان من المدحضين"
    },
    {
      "id": 3930,
      "jozz": 23,
      "page": 451,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 142,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالتقمه الحوت وهو مليم"
    },
    {
      "id": 3931,
      "jozz": 23,
      "page": 451,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 143,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلولا أنه كان من المسبحين"
    },
    {
      "id": 3932,
      "jozz": 23,
      "page": 451,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 144,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "للبث في بطنه إلى يوم يبعثون"
    },
    {
      "id": 3933,
      "jozz": 23,
      "page": 451,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 145,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فنبذناه بالعراء وهو سقيم"
    },
    {
      "id": 3934,
      "jozz": 23,
      "page": 451,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 146,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنبتنا عليه شجرة من يقطين"
    },
    {
      "id": 3935,
      "jozz": 23,
      "page": 451,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 147,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأرسلناه إلى مائة ألف أو يزيدون"
    },
    {
      "id": 3936,
      "jozz": 23,
      "page": 451,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 148,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏",
      "aya_text_emlaey": "فآمنوا فمتعناهم إلى حين"
    },
    {
      "id": 3937,
      "jozz": 23,
      "page": 451,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 149,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاستفتهم ألربك البنات ولهم البنون"
    },
    {
      "id": 3938,
      "jozz": 23,
      "page": 451,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 150,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم خلقنا الملائكة إناثا وهم شاهدون"
    },
    {
      "id": 3939,
      "jozz": 23,
      "page": 451,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 151,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألا إنهم من إفكهم ليقولون"
    },
    {
      "id": 3940,
      "jozz": 23,
      "page": 451,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 152,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولد الله وإنهم لكاذبون"
    },
    {
      "id": 3941,
      "jozz": 23,
      "page": 451,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 153,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أصطفى البنات على البنين"
    },
    {
      "id": 3942,
      "jozz": 23,
      "page": 452,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 154,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما لكم كيف تحكمون"
    },
    {
      "id": 3943,
      "jozz": 23,
      "page": 452,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 155,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفلا تذكرون"
    },
    {
      "id": 3944,
      "jozz": 23,
      "page": 452,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 156,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أم لكم سلطان مبين"
    },
    {
      "id": 3945,
      "jozz": 23,
      "page": 452,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 157,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأتوا بكتابكم إن كنتم صادقين"
    },
    {
      "id": 3946,
      "jozz": 23,
      "page": 452,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 158,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلوا بينه وبين الجنة نسبا ولقد علمت الجنة إنهم لمحضرون"
    },
    {
      "id": 3947,
      "jozz": 23,
      "page": 452,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 159,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سبحان الله عما يصفون"
    },
    {
      "id": 3948,
      "jozz": 23,
      "page": 452,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 160,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا عباد الله المخلصين"
    },
    {
      "id": 3949,
      "jozz": 23,
      "page": 452,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 161,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإنكم وما تعبدون"
    },
    {
      "id": 3950,
      "jozz": 23,
      "page": 452,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 162,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما أنتم عليه بفاتنين"
    },
    {
      "id": 3951,
      "jozz": 23,
      "page": 452,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 163,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا من هو صال الجحيم"
    },
    {
      "id": 3952,
      "jozz": 23,
      "page": 452,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 164,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما منا إلا له مقام معلوم"
    },
    {
      "id": 3953,
      "jozz": 23,
      "page": 452,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 165,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنا لنحن الصافون"
    },
    {
      "id": 3954,
      "jozz": 23,
      "page": 452,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 166,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنا لنحن المسبحون"
    },
    {
      "id": 3955,
      "jozz": 23,
      "page": 452,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 167,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن كانوا ليقولون"
    },
    {
      "id": 3956,
      "jozz": 23,
      "page": 452,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 168,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لو أن عندنا ذكرا من الأولين"
    },
    {
      "id": 3957,
      "jozz": 23,
      "page": 452,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 169,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لكنا عباد الله المخلصين"
    },
    {
      "id": 3958,
      "jozz": 23,
      "page": 452,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 170,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فكفروا به فسوف يعلمون"
    },
    {
      "id": 3959,
      "jozz": 23,
      "page": 452,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 171,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد سبقت كلمتنا لعبادنا المرسلين"
    },
    {
      "id": 3960,
      "jozz": 23,
      "page": 452,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 172,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنهم لهم المنصورون"
    },
    {
      "id": 3961,
      "jozz": 23,
      "page": 452,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 173,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن جندنا لهم الغالبون"
    },
    {
      "id": 3962,
      "jozz": 23,
      "page": 452,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 174,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏",
      "aya_text_emlaey": "فتول عنهم حتى حين"
    },
    {
      "id": 3963,
      "jozz": 23,
      "page": 452,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 175,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأبصرهم فسوف يبصرون"
    },
    {
      "id": 3964,
      "jozz": 23,
      "page": 452,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 176,
      "aya_text": "‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفبعذابنا يستعجلون"
    },
    {
      "id": 3965,
      "jozz": 23,
      "page": 452,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 177,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإذا نزل بساحتهم فساء صباح المنذرين"
    },
    {
      "id": 3966,
      "jozz": 23,
      "page": 452,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 178,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏",
      "aya_text_emlaey": "وتول عنهم حتى حين"
    },
    {
      "id": 3967,
      "jozz": 23,
      "page": 452,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 179,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأبصر فسوف يبصرون"
    },
    {
      "id": 3968,
      "jozz": 23,
      "page": 452,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 180,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سبحان ربك رب العزة عما يصفون"
    },
    {
      "id": 3969,
      "jozz": 23,
      "page": 452,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 181,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وسلام على المرسلين"
    },
    {
      "id": 3970,
      "jozz": 23,
      "page": 452,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 182,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والحمد لله رب العالمين"
    }
  ]
}