{
  "metadata": {
    "sura_no": 85,
    "sura_name_en": "Al-Burūj",
    "sura_name_ar": "البُرُوج",
    "total_verses": 22,
    "created_at": "2025-10-11T18:45:17.977Z"
  },
  "verses": [
    {
      "id": 5910,
      "jozz": 30,
      "page": 590,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والسماء ذات البروج"
    },
    {
      "id": 5911,
      "jozz": 30,
      "page": 590,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "واليوم الموعود"
    },
    {
      "id": 5912,
      "jozz": 30,
      "page": 590,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وشاهد ومشهود"
    },
    {
      "id": 5913,
      "jozz": 30,
      "page": 590,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قتل أصحاب الأخدود"
    },
    {
      "id": 5914,
      "jozz": 30,
      "page": 590,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "النار ذات الوقود"
    },
    {
      "id": 5915,
      "jozz": 30,
      "page": 590,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 6,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ هم عليها قعود"
    },
    {
      "id": 5916,
      "jozz": 30,
      "page": 590,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وهم على ما يفعلون بالمؤمنين شهود"
    },
    {
      "id": 5917,
      "jozz": 30,
      "page": 590,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما نقموا منهم إلا أن يؤمنوا بالله العزيز الحميد"
    },
    {
      "id": 5918,
      "jozz": 30,
      "page": 590,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 9,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "الذي له ملك السموات والأرض والله على كل شيء شهيد"
    },
    {
      "id": 5919,
      "jozz": 30,
      "page": 590,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 10,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين فتنوا المؤمنين والمؤمنات ثم لم يتوبوا فلهم عذاب جهنم ولهم عذاب الحريق"
    },
    {
      "id": 5920,
      "jozz": 30,
      "page": 590,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 11,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين آمنوا وعملوا الصالحات لهم جنات تجري من تحتها الأنهار ذلك الفوز الكبير"
    },
    {
      "id": 5921,
      "jozz": 30,
      "page": 590,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 12,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن بطش ربك لشديد"
    },
    {
      "id": 5922,
      "jozz": 30,
      "page": 590,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه هو يبدئ ويعيد"
    },
    {
      "id": 5923,
      "jozz": 30,
      "page": 590,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وهو الغفور الودود"
    },
    {
      "id": 5924,
      "jozz": 30,
      "page": 590,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 15,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذو العرش المجيد"
    },
    {
      "id": 5925,
      "jozz": 30,
      "page": 590,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 16,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فعال لما يريد"
    },
    {
      "id": 5926,
      "jozz": 30,
      "page": 590,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هل أتاك حديث الجنود"
    },
    {
      "id": 5927,
      "jozz": 30,
      "page": 590,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 18,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فرعون وثمود"
    },
    {
      "id": 5928,
      "jozz": 30,
      "page": 590,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 19,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل الذين كفروا في تكذيب"
    },
    {
      "id": 5929,
      "jozz": 30,
      "page": 590,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 20,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "والله من ورائهم محيط"
    },
    {
      "id": 5930,
      "jozz": 30,
      "page": 590,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 21,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "بل هو قرآن مجيد"
    },
    {
      "id": 5931,
      "jozz": 30,
      "page": 590,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 22,
      "aya_text": "‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "في لوح محفوظ"
    }
  ]
}