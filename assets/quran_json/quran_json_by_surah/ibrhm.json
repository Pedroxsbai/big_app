      "page": 255,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 1,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الر كتاب أنزلناه إليك لتخرج الناس من الظلمات إلى النور بإذن ربهم إلى صراط العزيز الحميد"
    },
    {
      "id": 1752,
      "jozz": 13,
      "page": 255,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "الله الذي له ما في السموات وما في الأرض وويل للكافرين من عذاب شديد"
    },
    {
      "id": 1753,
      "jozz": 13,
      "page": 255,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 3,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين يستحبون الحياة الدنيا على الآخرة ويصدون عن سبيل الله ويبغونها عوجا أولئك في ضلال بعيد"
    },
    {
      "id": 1754,
      "jozz": 13,
      "page": 255,
      "line_start": 10,
      "line_end": 13,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أرسلنا من رسول إلا بلسان قومه ليبين لهم فيضل الله من يشاء ويهدي من يشاء وهو العزيز الحكيم"
    },
    {
      "id": 1755,
      "jozz": 13,
      "page": 255,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد أرسلنا موسى بآياتنا أن أخرج قومك من الظلمات إلى النور وذكرهم بأيام الله إن في ذلك لآيات لكل صبار شكور"
    },
    {
      "id": 1756,
      "jozz": 13,
      "page": 256,
      "line_start": 1,
      "line_end": 4,
      "aya_no": 6,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذ قال موسى لقومه اذكروا نعمة الله عليكم إذ أنجاكم من آل فرعون يسومونكم سوء العذاب ويذبحون أبناءكم ويستحيون نساءكم وفي ذلكم بلاء من ربكم عظيم"
    },
    {
      "id": 1757,
      "jozz": 13,
      "page": 256,
      "line_start": 4,
      "line_end": 6,
      "aya_no": 7,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذ تأذن ربكم لئن شكرتم لأزيدنكم ولئن كفرتم إن عذابي لشديد"
    },
    {
      "id": 1758,
      "jozz": 13,
      "page": 256,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 8,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وقال موسى إن تكفروا أنتم ومن في الأرض جميعا فإن الله لغني حميد"
    },
    {
      "id": 1759,
      "jozz": 13,
      "page": 256,
      "line_start": 7,
      "line_end": 11,
      "aya_no": 9,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم يأتكم نبأ الذين من قبلكم قوم نوح وعاد وثمود والذين من بعدهم لا يعلمهم إلا الله جاءتهم رسلهم بالبينات فردوا أيديهم في أفواههم وقالوا إنا كفرنا بما أرسلتم به وإنا لفي شك مما تدعوننا إليه مريب"
    },
    {
      "id": 1760,
      "jozz": 13,
      "page": 256,
      "line_start": 12,
      "line_end": 15,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "قالت رسلهم أفي الله شك فاطر السموات والأرض يدعوكم ليغفر لكم من ذنوبكم ويؤخركم إلى أجل مسمى قالوا إن أنتم إلا بشر مثلنا تريدون أن تصدونا عما كان يعبد آباؤنا فأتونا بسلطان مبين"
    },
    {
      "id": 1761,
      "jozz": 13,
      "page": 257,
      "line_start": 1,
      "line_end": 3,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالت لهم رسلهم إن نحن إلا بشر مثلكم ولكن الله يمن على من يشاء من عباده وما كان لنا أن نأتيكم بسلطان إلا بإذن الله وعلى الله فليتوكل المؤمنون"
    },
    {
      "id": 1762,
      "jozz": 13,
      "page": 257,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 12,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما لنا ألا نتوكل على الله وقد هدانا سبلنا ولنصبرن على ما آذيتمونا وعلى الله فليتوكل المتوكلون"
    },
    {
      "id": 1763,
      "jozz": 13,
      "page": 257,
      "line_start": 6,
      "line_end": 8,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقال الذين كفروا لرسلهم لنخرجنكم من أرضنا أو لتعودن في ملتنا فأوحى إليهم ربهم لنهلكن الظالمين"
    },
    {
      "id": 1764,
      "jozz": 13,
      "page": 257,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولنسكننكم الأرض من بعدهم ذلك لمن خاف مقامي وخاف وعيد"
    },
    {
      "id": 1765,
      "jozz": 13,
      "page": 257,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "واستفتحوا وخاب كل جبار عنيد"
    },
    {
      "id": 1766,
      "jozz": 13,
      "page": 257,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 16,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "من ورائه جهنم ويسقى من ماء صديد"
    },
    {
      "id": 1767,
      "jozz": 13,
      "page": 257,
      "line_start": 11,
      "line_end": 13,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يتجرعه ولا يكاد يسيغه ويأتيه الموت من كل مكان وما هو بميت ومن ورائه عذاب غليظ"
    },
    {
      "id": 1768,
      "jozz": 13,
      "page": 257,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 18,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "مثل الذين كفروا بربهم أعمالهم كرماد اشتدت به الريح في يوم عاصف لا يقدرون مما كسبوا على شيء ذلك هو الضلال البعيد"
    },
    {
      "id": 1769,
      "jozz": 13,
      "page": 258,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم تر أن الله خلق السموات والأرض بالحق إن يشأ يذهبكم ويأت بخلق جديد"
    },
    {
      "id": 1770,
      "jozz": 13,
      "page": 258,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 20,
      "aya_text": "‏‏‏ ‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما ذلك على الله بعزيز"
    },
    {
      "id": 1771,
      "jozz": 13,
      "page": 258,
      "line_start": 3,
      "line_end": 6,
      "aya_no": 21,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وبرزوا لله جميعا فقال الضعفاء للذين استكبروا إنا كنا لكم تبعا فهل أنتم مغنون عنا من عذاب الله من شيء قالوا لو هدانا الله لهديناكم سواء علينا أجزعنا أم صبرنا ما لنا من محيص"
    },
    {
      "id": 1772,
      "jozz": 13,
      "page": 258,
      "line_start": 6,
      "line_end": 12,
      "aya_no": 22,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وقال الشيطان لما قضي الأمر إن الله وعدكم وعد الحق ووعدتكم فأخلفتكم وما كان لي عليكم من سلطان إلا أن دعوتكم فاستجبتم لي فلا تلوموني ولوموا أنفسكم ما أنا بمصرخكم وما أنتم بمصرخي إني كفرت بما أشركتمون من قبل إن الظالمين لهم عذاب أليم"
    },
    {
      "id": 1773,
      "jozz": 13,
      "page": 258,
      "line_start": 12,
      "line_end": 14,
      "aya_no": 23,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وأدخل الذين آمنوا وعملوا الصالحات جنات تجري من تحتها الأنهار خالدين فيها بإذن ربهم تحيتهم فيها سلام"
    },
    {
      "id": 1774,
      "jozz": 13,
      "page": 258,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 24,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم تر كيف ضرب الله مثلا كلمة طيبة كشجرة طيبة أصلها ثابت وفرعها في السماء"
    },
    {
      "id": 1775,
      "jozz": 13,
      "page": 259,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 25,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "تؤتي أكلها كل حين بإذن ربها ويضرب الله الأمثال للناس لعلهم يتذكرون"
    },
    {
      "id": 1776,
      "jozz": 13,
      "page": 259,
      "line_start": 2,
      "line_end": 4,
      "aya_no": 26,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ومثل كلمة خبيثة كشجرة خبيثة اجتثت من فوق الأرض ما لها من قرار"
    },
    {
      "id": 1777,
      "jozz": 13,
      "page": 259,
      "line_start": 4,
      "line_end": 6,
      "aya_no": 27,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يثبت الله الذين آمنوا بالقول الثابت في الحياة الدنيا وفي الآخرة ويضل الله الظالمين ويفعل الله ما يشاء"
    },
    {
      "id": 1778,
      "jozz": 13,
      "page": 259,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 28,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم تر إلى الذين بدلوا نعمة الله كفرا وأحلوا قومهم دار البوار"
    },
    {
      "id": 1779,
      "jozz": 13,
      "page": 259,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 29,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "جهنم يصلونها وبئس القرار"
    },
    {
      "id": 1780,
      "jozz": 13,
      "page": 259,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 30,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلوا لله أندادا ليضلوا عن سبيله قل تمتعوا فإن مصيركم إلى النار"
    },
    {
      "id": 1781,
      "jozz": 13,
      "page": 259,
      "line_start": 9,
      "line_end": 11,
      "aya_no": 31,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "قل لعبادي الذين آمنوا يقيموا الصلاة وينفقوا مما رزقناهم سرا وعلانية من قبل أن يأتي يوم لا بيع فيه ولا خلال"
    },
    {
      "id": 1782,
      "jozz": 13,
      "page": 259,
      "line_start": 11,
      "line_end": 14,
      "aya_no": 32,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الله الذي خلق السموات والأرض وأنزل من السماء ماء فأخرج به من الثمرات رزقا لكم وسخر لكم الفلك لتجري في البحر بأمره وسخر لكم الأنهار"
    },
    {
      "id": 1783,
      "jozz": 13,
      "page": 259,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 33,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وسخر لكم الشمس والقمر دائبين وسخر لكم الليل والنهار"
    },
    {
      "id": 1784,
      "jozz": 13,
      "page": 260,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 34,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وآتاكم من كل ما سألتموه وإن تعدوا نعمة الله لا تحصوها إن الإنسان لظلوم كفار"
    },
    {
      "id": 1785,
      "jozz": 13,
      "page": 260,
      "line_start": 2,
      "line_end": 4,
      "aya_no": 35,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذ قال إبراهيم رب اجعل هذا البلد آمنا واجنبني وبني أن نعبد الأصنام"
    },
    {
      "id": 1786,
      "jozz": 13,
      "page": 260,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 36,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "رب إنهن أضللن كثيرا من الناس فمن تبعني فإنه مني ومن عصاني فإنك غفور رحيم"
    },
    {
      "id": 1787,
      "jozz": 13,
      "page": 260,
      "line_start": 5,
      "line_end": 8,
      "aya_no": 37,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ربنا إني أسكنت من ذريتي بواد غير ذي زرع عند بيتك المحرم ربنا ليقيموا الصلاة فاجعل أفئدة من الناس تهوي إليهم وارزقهم من الثمرات لعلهم يشكرون"
    },
    {
      "id": 1788,
      "jozz": 13,
      "page": 260,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 38,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ربنا إنك تعلم ما نخفي وما نعلن وما يخفى على الله من شيء في الأرض ولا في السماء"
    },
    {
      "id": 1789,
      "jozz": 13,
      "page": 260,
      "line_start": 10,
      "line_end": 12,
      "aya_no": 39,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "الحمد لله الذي وهب لي على الكبر إسماعيل وإسحاق إن ربي لسميع الدعاء"
    },
    {
      "id": 1790,
      "jozz": 13,
      "page": 260,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 40,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "رب اجعلني مقيم الصلاة ومن ذريتي ربنا وتقبل دعاء"
    },
    {
      "id": 1791,
      "jozz": 13,
      "page": 260,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 41,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ربنا اغفر لي ولوالدي وللمؤمنين يوم يقوم الحساب"
    },
    {
      "id": 1792,
      "jozz": 13,
      "page": 260,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 42,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا تحسبن الله غافلا عما يعمل الظالمون إنما يؤخرهم ليوم تشخص فيه الأبصار"
    },
    {
      "id": 1793,
      "jozz": 13,
      "page": 261,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 43,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "مهطعين مقنعي رءوسهم لا يرتد إليهم طرفهم وأفئدتهم هواء"
    },
    {
      "id": 1794,
      "jozz": 13,
      "page": 261,
      "line_start": 2,
      "line_end": 5,
      "aya_no": 44,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنذر الناس يوم يأتيهم العذاب فيقول الذين ظلموا ربنا أخرنا إلى أجل قريب نجب دعوتك ونتبع الرسل أو لم تكونوا أقسمتم من قبل ما لكم من زوال"
    },
    {
      "id": 1795,
      "jozz": 13,
      "page": 261,
      "line_start": 5,
      "line_end": 7,
      "aya_no": 45,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وسكنتم في مساكن الذين ظلموا أنفسهم وتبين لكم كيف فعلنا بهم وضربنا لكم الأمثال"
    },
    {
      "id": 1796,
      "jozz": 13,
      "page": 261,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 46,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقد مكروا مكرهم وعند الله مكرهم وإن كان مكرهم لتزول منه الجبال"
    },
    {
      "id": 1797,
      "jozz": 13,
      "page": 261,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 47,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلا تحسبن الله مخلف وعده رسله إن الله عزيز ذو انتقام"
    },
    {
      "id": 1798,
      "jozz": 13,
      "page": 261,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 48,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم تبدل الأرض غير الأرض والسموات وبرزوا لله الواحد القهار"
    },
    {
      "id": 1799,
      "jozz": 13,
      "page": 261,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 49,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وترى المجرمين يومئذ مقرنين في الأصفاد"
    },
    {
      "id": 1800,
      "jozz": 13,
      "page": 261,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 50,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "سرابيلهم من قطران وتغشى وجوههم النار"
    },
    {
      "id": 1801,
      "jozz": 13,
      "page": 261,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 51,
      "aya_text": "‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ليجزي الله كل نفس ما كسبت إن الله سريع الحساب"
    },
    {
      "id": 1802,
      "jozz": 13,
      "page": 261,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 52,
