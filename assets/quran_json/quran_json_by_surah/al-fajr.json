{
  "metadata": {
    "sura_no": 89,
    "sura_name_en": "Al-Fajr",
    "sura_name_ar": "الفَجر",
    "total_verses": 30,
    "created_at": "2025-10-11T18:45:17.982Z"
  },
  "verses": [
    {
      "id": 5994,
      "jozz": 30,
      "page": 593,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والفجر"
    },
    {
      "id": 5995,
      "jozz": 30,
      "page": 593,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 2,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وليال عشر"
    },
    {
      "id": 5996,
      "jozz": 30,
      "page": 593,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والشفع والوتر"
    },
    {
      "id": 5997,
      "jozz": 30,
      "page": 593,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 4,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "والليل إذا يسر"
    },
    {
      "id": 5998,
      "jozz": 30,
      "page": 593,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 5,
      "aya_text": "‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "هل في ذلك قسم لذي حجر"
    },
    {
      "id": 5999,
      "jozz": 30,
      "page": 593,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 6,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم تر كيف فعل ربك بعاد"
    },
    {
      "id": 6000,
      "jozz": 30,
      "page": 593,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إرم ذات العماد"
    },
    {
      "id": 6001,
      "jozz": 30,
      "page": 593,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "التي لم يخلق مثلها في البلاد"
    },
    {
      "id": 6002,
      "jozz": 30,
      "page": 593,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وثمود الذين جابوا الصخر بالواد"
    },
    {
      "id": 6003,
      "jozz": 30,
      "page": 593,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وفرعون ذي الأوتاد"
    },
    {
      "id": 6004,
      "jozz": 30,
      "page": 593,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين طغوا في البلاد"
    },
    {
      "id": 6005,
      "jozz": 30,
      "page": 593,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأكثروا فيها الفساد"
    },
    {
      "id": 6006,
      "jozz": 30,
      "page": 593,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 13,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فصب عليهم ربك سوط عذاب"
    },
    {
      "id": 6007,
      "jozz": 30,
      "page": 593,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 14,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن ربك لبالمرصاد"
    },
    {
      "id": 6008,
      "jozz": 30,
      "page": 593,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 15,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأما الإنسان إذا ما ابتلاه ربه فأكرمه ونعمه فيقول ربي أكرمن"
    },
    {
      "id": 6009,
      "jozz": 30,
      "page": 593,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 16,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وأما إذا ما ابتلاه فقدر عليه رزقه فيقول ربي أهانن"
    },
    {
      "id": 6010,
      "jozz": 30,
      "page": 593,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا بل لا تكرمون اليتيم"
    },
    {
      "id": 6011,
      "jozz": 30,
      "page": 593,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 18,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا تحاضون على طعام المسكين"
    },
    {
      "id": 6012,
      "jozz": 30,
      "page": 593,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وتأكلون التراث أكلا لما"
    },
    {
      "id": 6013,
      "jozz": 30,
      "page": 593,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "وتحبون المال حبا جما"
    },
    {
      "id": 6014,
      "jozz": 30,
      "page": 593,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 21,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏",
      "aya_text_emlaey": "كلا إذا دكت الأرض دكا دكا"
    },
    {
      "id": 6015,
      "jozz": 30,
      "page": 593,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 22,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وجاء ربك والملك صفا صفا"
    },
    {
      "id": 6016,
      "jozz": 30,
      "page": 594,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 23,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجيء يومئذ بجهنم يومئذ يتذكر الإنسان وأنى له الذكرى"
    },
    {
      "id": 6017,
      "jozz": 30,
      "page": 594,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 24,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يقول ياليتني قدمت لحياتي"
    },
    {
      "id": 6018,
      "jozz": 30,
      "page": 594,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 25,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فيومئذ لا يعذب عذابه أحد"
    },
    {
      "id": 6019,
      "jozz": 30,
      "page": 594,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 26,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ولا يوثق وثاقه أحد"
    },
    {
      "id": 6020,
      "jozz": 30,
      "page": 594,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 27,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأيتها النفس المطمئنة"
    },
    {
      "id": 6021,
      "jozz": 30,
      "page": 594,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 28,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ارجعي إلى ربك راضية مرضية"
    },
    {
      "id": 6022,
      "jozz": 30,
      "page": 594,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 29,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فادخلي في عبادي"
    },
    {
      "id": 6023,
      "jozz": 30,
      "page": 594,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 30,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وادخلي جنتي"
    }
  ]
}