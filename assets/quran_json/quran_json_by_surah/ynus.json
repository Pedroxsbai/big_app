      "aya_no": 15,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا تتلى عليهم آياتنا بينات قال الذين لا يرجون لقاءنا ائت بقرآن غير هذا أو بدله قل ما يكون لي أن أبدله من تلقاء نفسي إن أتبع إلا ما يوحى إلي إني أخاف إن عصيت ربي عذاب يوم عظيم"
    },
    {
      "id": 1380,
      "jozz": 11,
      "page": 210,
      "line_start": 4,
      "line_end": 6,
      "aya_no": 16,
      "aya_text": "‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل لو شاء الله ما تلوته عليكم ولا أدراكم به فقد لبثت فيكم عمرا من قبله أفلا تعقلون"
    },
    {
      "id": 1381,
      "jozz": 11,
      "page": 210,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 17,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فمن أظلم ممن افترى على الله كذبا أو كذب بآياته إنه لا يفلح المجرمون"
    },
    {
      "id": 1382,
      "jozz": 11,
      "page": 210,
      "line_start": 8,
      "line_end": 11,
      "aya_no": 18,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويعبدون من دون الله ما لا يضرهم ولا ينفعهم ويقولون هؤلاء شفعاؤنا عند الله قل أتنبئون الله بما لا يعلم في السموات ولا في الأرض سبحانه وتعالى عما يشركون"
    },
    {
      "id": 1383,
      "jozz": 11,
      "page": 210,
      "line_start": 11,
      "line_end": 13,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما كان الناس إلا أمة واحدة فاختلفوا ولولا كلمة سبقت من ربك لقضي بينهم فيما فيه يختلفون"
    },
    {
      "id": 1384,
      "jozz": 11,
      "page": 210,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويقولون لولا أنزل عليه آية من ربه فقل إنما الغيب لله فانتظروا إني معكم من المنتظرين"
    },
    {
      "id": 1385,
      "jozz": 11,
      "page": 211,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 21,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا أذقنا الناس رحمة من بعد ضراء مستهم إذا لهم مكر في آياتنا قل الله أسرع مكرا إن رسلنا يكتبون ما تمكرون"
    },
    {
      "id": 1386,
      "jozz": 11,
      "page": 211,
      "line_start": 3,
      "line_end": 7,
      "aya_no": 22,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هو الذي يسيركم في البر والبحر حتى إذا كنتم في الفلك وجرين بهم بريح طيبة وفرحوا بها جاءتها ريح عاصف وجاءهم الموج من كل مكان وظنوا أنهم أحيط بهم دعوا الله مخلصين له الدين لئن أنجيتنا من هذه لنكونن من الشاكرين"
    },
    {
      "id": 1387,
      "jozz": 11,
      "page": 211,
      "line_start": 7,
      "line_end": 9,
      "aya_no": 23,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلما أنجاهم إذا هم يبغون في الأرض بغير الحق ياأيها الناس إنما بغيكم على أنفسكم متاع الحياة الدنيا ثم إلينا مرجعكم فننبئكم بما كنتم تعملون"
    },
    {
      "id": 1388,
      "jozz": 11,
      "page": 211,
      "line_start": 10,
      "line_end": 14,
      "aya_no": 24,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنما مثل الحياة الدنيا كماء أنزلناه من السماء فاختلط به نبات الأرض مما يأكل الناس والأنعام حتى إذا أخذت الأرض زخرفها وازينت وظن أهلها أنهم قادرون عليها أتاها أمرنا ليلا أو نهارا فجعلناها حصيدا كأن لم تغن بالأمس كذلك نفصل الآيات لقوم يتفكرون"
    },
    {
      "id": 1389,
      "jozz": 11,
      "page": 211,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 25,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والله يدعو إلى دار السلام ويهدي من يشاء إلى صراط مستقيم"
    },
    {
      "id": 1390,
      "jozz": 11,
      "page": 212,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 26,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "للذين أحسنوا الحسنى وزيادة ولا يرهق وجوههم قتر ولا ذلة أولئك أصحاب الجنة هم فيها خالدون"
    },
    {
      "id": 1391,
      "jozz": 11,
      "page": 212,
      "line_start": 2,
      "line_end": 5,
      "aya_no": 27,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والذين كسبوا السيئات جزاء سيئة بمثلها وترهقهم ذلة ما لهم من الله من عاصم كأنما أغشيت وجوههم قطعا من الليل مظلما أولئك أصحاب النار هم فيها خالدون"
    },
    {
      "id": 1392,
      "jozz": 11,
      "page": 212,
      "line_start": 5,
      "line_end": 7,
      "aya_no": 28,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويوم نحشرهم جميعا ثم نقول للذين أشركوا مكانكم أنتم وشركاؤكم فزيلنا بينهم وقال شركاؤهم ما كنتم إيانا تعبدون"
    },
    {
      "id": 1393,
      "jozz": 11,
      "page": 212,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 29,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فكفى بالله شهيدا بيننا وبينكم إن كنا عن عبادتكم لغافلين"
    },
    {
      "id": 1394,
      "jozz": 11,
      "page": 212,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 30,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هنالك تبلو كل نفس ما أسلفت وردوا إلى الله مولاهم الحق وضل عنهم ما كانوا يفترون"
    },
    {
      "id": 1395,
      "jozz": 11,
      "page": 212,
      "line_start": 10,
      "line_end": 13,
      "aya_no": 31,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل من يرزقكم من السماء والأرض أمن يملك السمع والأبصار ومن يخرج الحي من الميت ويخرج الميت من الحي ومن يدبر الأمر فسيقولون الله فقل أفلا تتقون"
    },
    {
      "id": 1396,
      "jozz": 11,
      "page": 212,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 32,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فذلكم الله ربكم الحق فماذا بعد الحق إلا الضلال فأنى تصرفون"
    },
    {
      "id": 1397,
      "jozz": 11,
      "page": 212,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 33,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذلك حقت كلمت ربك على الذين فسقوا أنهم لا يؤمنون"
    },
    {
      "id": 1398,
      "jozz": 11,
      "page": 213,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 34,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل هل من شركائكم من يبدأ الخلق ثم يعيده قل الله يبدأ الخلق ثم يعيده فأنى تؤفكون"
    },
    {
      "id": 1399,
      "jozz": 11,
      "page": 213,
      "line_start": 2,
      "line_end": 4,
      "aya_no": 35,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل هل من شركائكم من يهدي إلى الحق قل الله يهدي للحق أفمن يهدي إلى الحق أحق أن يتبع أمن لا يهدي إلا أن يهدى فما لكم كيف تحكمون"
    },
    {
      "id": 1400,
      "jozz": 11,
      "page": 213,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 36,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما يتبع أكثرهم إلا ظنا إن الظن لا يغني من الحق شيئا إن الله عليم بما يفعلون"
    },
    {
      "id": 1401,
      "jozz": 11,
      "page": 213,
      "line_start": 6,
      "line_end": 8,
      "aya_no": 37,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما كان هذا القرآن أن يفترى من دون الله ولكن تصديق الذي بين يديه وتفصيل الكتاب لا ريب فيه من رب العالمين"
    },
    {
      "id": 1402,
      "jozz": 11,
      "page": 213,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 38,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أم يقولون افتراه قل فأتوا بسورة مثله وادعوا من استطعتم من دون الله إن كنتم صادقين"
    },
    {
      "id": 1403,
      "jozz": 11,
      "page": 213,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 39,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل كذبوا بما لم يحيطوا بعلمه ولما يأتهم تأويله كذلك كذب الذين من قبلهم فانظر كيف كان عاقبة الظالمين"
    },
    {
      "id": 1404,
      "jozz": 11,
      "page": 213,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 40,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومنهم من يؤمن به ومنهم من لا يؤمن به وربك أعلم بالمفسدين"
    },
    {
      "id": 1405,
      "jozz": 11,
      "page": 213,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 41,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن كذبوك فقل لي عملي ولكم عملكم أنتم بريئون مما أعمل وأنا بريء مما تعملون"
    },
    {
      "id": 1406,
      "jozz": 11,
      "page": 213,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 42,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومنهم من يستمعون إليك أفأنت تسمع الصم ولو كانوا لا يعقلون"
    },
    {
      "id": 1407,
      "jozz": 11,
      "page": 214,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 43,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومنهم من ينظر إليك أفأنت تهدي العمي ولو كانوا لا يبصرون"
    },
    {
      "id": 1408,
      "jozz": 11,
      "page": 214,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 44,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الله لا يظلم الناس شيئا ولكن الناس أنفسهم يظلمون"
    },
    {
      "id": 1409,
      "jozz": 11,
      "page": 214,
      "line_start": 3,
      "line_end": 5,
      "aya_no": 45,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويوم يحشرهم كأن لم يلبثوا إلا ساعة من النهار يتعارفون بينهم قد خسر الذين كذبوا بلقاء الله وما كانوا مهتدين"
    },
    {
      "id": 1410,
      "jozz": 11,
      "page": 214,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 46,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإما نرينك بعض الذي نعدهم أو نتوفينك فإلينا مرجعهم ثم الله شهيد على ما يفعلون"
    },
    {
      "id": 1411,
      "jozz": 11,
      "page": 214,
      "line_start": 6,
      "line_end": 8,
      "aya_no": 47,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولكل أمة رسول فإذا جاء رسولهم قضي بينهم بالقسط وهم لا يظلمون"
    },
    {
      "id": 1412,
      "jozz": 11,
      "page": 214,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 48,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ويقولون متى هذا الوعد إن كنتم صادقين"
    },
    {
      "id": 1413,
      "jozz": 11,
      "page": 214,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 49,
      "aya_text": "‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل لا أملك لنفسي ضرا ولا نفعا إلا ما شاء الله لكل أمة أجل إذا جاء أجلهم فلا يستأخرون ساعة ولا يستقدمون"
    },
    {
      "id": 1414,
      "jozz": 11,
      "page": 214,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 50,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل أرأيتم إن أتاكم عذابه بياتا أو نهارا ماذا يستعجل منه المجرمون"
    },
    {
      "id": 1415,
      "jozz": 11,
      "page": 214,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 51,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أثم إذا ما وقع آمنتم به آلآن وقد كنتم به تستعجلون"
    },
    {
      "id": 1416,
      "jozz": 11,
      "page": 214,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 52,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم قيل للذين ظلموا ذوقوا عذاب الخلد هل تجزون إلا بما كنتم تكسبون"
    },
    {
      "id": 1417,
      "jozz": 11,
      "page": 214,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 53,
      "aya_text": "‏‏‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويستنبئونك أحق هو قل إي وربي إنه لحق وما أنتم بمعجزين"
    },
    {
      "id": 1418,
      "jozz": 11,
      "page": 215,
      "line_start": 1,
      "line_end": 3,
      "aya_no": 54,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولو أن لكل نفس ظلمت ما في الأرض لافتدت به وأسروا الندامة لما رأوا العذاب وقضي بينهم بالقسط وهم لا يظلمون"
    },
    {
      "id": 1419,
      "jozz": 11,
      "page": 215,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 55,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألا إن لله ما في السموات والأرض ألا إن وعد الله حق ولكن أكثرهم لا يعلمون"
    },
    {
      "id": 1420,
      "jozz": 11,
      "page": 215,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 56,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هو يحيي ويميت وإليه ترجعون"
    },
    {
      "id": 1421,
      "jozz": 11,
      "page": 215,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 57,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ياأيها الناس قد جاءتكم موعظة من ربكم وشفاء لما في الصدور وهدى ورحمة للمؤمنين"
    },
    {
      "id": 1422,
      "jozz": 11,
      "page": 215,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 58,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل بفضل الله وبرحمته فبذلك فليفرحوا هو خير مما يجمعون"
    },
    {
      "id": 1423,
      "jozz": 11,
      "page": 215,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 59,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل أرأيتم ما أنزل الله لكم من رزق فجعلتم منه حراما وحلالا قل آلله أذن لكم أم على الله تفترون"
    },
    {
      "id": 1424,
      "jozz": 11,
      "page": 215,
      "line_start": 10,
      "line_end": 12,
      "aya_no": 60,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما ظن الذين يفترون على الله الكذب يوم القيامة إن الله لذو فضل على الناس ولكن أكثرهم لا يشكرون"
    },
    {
      "id": 1425,
      "jozz": 11,
      "page": 215,
      "line_start": 12,
      "line_end": 15,
      "aya_no": 61,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وما تكون في شأن وما تتلو منه من قرآن ولا تعملون من عمل إلا كنا عليكم شهودا إذ تفيضون فيه وما يعزب عن ربك من مثقال ذرة في الأرض ولا في السماء ولا أصغر من ذلك ولا أكبر إلا في كتاب مبين"
    },
    {
      "id": 1426,
      "jozz": 11,
      "page": 216,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 62,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألا إن أولياء الله لا خوف عليهم ولا هم يحزنون"
    },
    {
      "id": 1427,
      "jozz": 11,
      "page": 216,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 63,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين آمنوا وكانوا يتقون"
    },
    {
      "id": 1428,
      "jozz": 11,
      "page": 216,
      "line_start": 2,
      "line_end": 4,
      "aya_no": 64,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لهم البشرى في الحياة الدنيا وفي الآخرة لا تبديل لكلمات الله ذلك هو الفوز العظيم"
    },
    {
      "id": 1429,
      "jozz": 11,
      "page": 216,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 65,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا يحزنك قولهم إن العزة لله جميعا هو السميع العليم"
    },
    {
      "id": 1430,
      "jozz": 11,
      "page": 216,
      "line_start": 5,
      "line_end": 8,
      "aya_no": 66,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألا إن لله من في السموات ومن في الأرض وما يتبع الذين يدعون من دون الله شركاء إن يتبعون إلا الظن وإن هم إلا يخرصون"
    },
    {
      "id": 1431,
      "jozz": 11,
      "page": 216,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 67,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "هو الذي جعل لكم الليل لتسكنوا فيه والنهار مبصرا إن في ذلك لآيات لقوم يسمعون"
    },
    {
      "id": 1432,
      "jozz": 11,
      "page": 216,
      "line_start": 10,
      "line_end": 13,
      "aya_no": 68,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا اتخذ الله ولدا سبحانه هو الغني له ما في السموات وما في الأرض إن عندكم من سلطان بهذا أتقولون على الله ما لا تعلمون"
    },
    {
      "id": 1433,
      "jozz": 11,
      "page": 216,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 69,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل إن الذين يفترون على الله الكذب لا يفلحون"
    },
    {
      "id": 1434,
      "jozz": 11,
      "page": 216,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 70,
      "aya_text": "‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "متاع في الدنيا ثم إلينا مرجعهم ثم نذيقهم العذاب الشديد بما كانوا يكفرون"
    },
    {
      "id": 1435,
      "jozz": 11,
      "page": 217,
      "line_start": 1,
      "line_end": 4,
      "aya_no": 71,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "واتل عليهم نبأ نوح إذ قال لقومه ياقوم إن كان كبر عليكم مقامي وتذكيري بآيات الله فعلى الله توكلت فأجمعوا أمركم وشركاءكم ثم لا يكن أمركم عليكم غمة ثم اقضوا إلي ولا تنظرون"
    },
    {
      "id": 1436,
      "jozz": 11,
      "page": 217,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 72,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإن توليتم فما سألتكم من أجر إن أجري إلا على الله وأمرت أن أكون من المسلمين"
    },
    {
      "id": 1437,
      "jozz": 11,
      "page": 217,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 73,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فكذبوه فنجيناه ومن معه في الفلك وجعلناهم خلائف وأغرقنا الذين كذبوا بآياتنا فانظر كيف كان عاقبة المنذرين"
    },
    {
      "id": 1438,
      "jozz": 11,
      "page": 217,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 74,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم بعثنا من بعده رسلا إلى قومهم فجاءوهم بالبينات فما كانوا ليؤمنوا بما كذبوا به من قبل كذلك نطبع على قلوب المعتدين"
    },
    {
      "id": 1439,
      "jozz": 11,
      "page": 217,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 75,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم بعثنا من بعدهم موسى وهارون إلى فرعون وملئه بآياتنا فاستكبروا وكانوا قوما مجرمين"
    },
    {
      "id": 1440,
      "jozz": 11,
      "page": 217,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 76,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فلما جاءهم الحق من عندنا قالوا إن هذا لسحر مبين"
    },
    {
      "id": 1441,
      "jozz": 11,
      "page": 217,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 77,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال موسى أتقولون للحق لما جاءكم أسحر هذا ولا يفلح الساحرون"
    },
    {
      "id": 1442,
      "jozz": 11,
      "page": 217,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 78,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا أجئتنا لتلفتنا عما وجدنا عليه آباءنا وتكون لكما الكبرياء في الأرض وما نحن لكما بمؤمنين"
    },
    {
      "id": 1443,
      "jozz": 11,
      "page": 218,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 79,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وقال فرعون ائتوني بكل ساحر عليم"
    },
    {
      "id": 1444,
      "jozz": 11,
      "page": 218,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 80,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلما جاء السحرة قال لهم موسى ألقوا ما أنتم ملقون"
    },
    {
      "id": 1445,
      "jozz": 11,
      "page": 218,
      "line_start": 2,
      "line_end": 4,
      "aya_no": 81,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلما ألقوا قال موسى ما جئتم به السحر إن الله سيبطله إن الله لا يصلح عمل المفسدين"
    },
    {
      "id": 1446,
      "jozz": 11,
      "page": 218,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 82,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ويحق الله الحق بكلماته ولو كره المجرمون"
    },
    {
      "id": 1447,
      "jozz": 11,
      "page": 218,
      "line_start": 5,
      "line_end": 7,
      "aya_no": 83,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما آمن لموسى إلا ذرية من قومه على خوف من فرعون وملئهم أن يفتنهم وإن فرعون لعال في الأرض وإنه لمن المسرفين"
    },
    {
      "id": 1448,
      "jozz": 11,
      "page": 218,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 84,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقال موسى ياقوم إن كنتم آمنتم بالله فعليه توكلوا إن كنتم مسلمين"
    },
    {
      "id": 1449,
      "jozz": 11,
      "page": 218,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 85,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فقالوا على الله توكلنا ربنا لا تجعلنا فتنة للقوم الظالمين"
    },
    {
      "id": 1450,
      "jozz": 11,
      "page": 218,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 86,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونجنا برحمتك من القوم الكافرين"
    },
    {
      "id": 1451,
      "jozz": 11,
      "page": 218,
      "line_start": 10,
      "line_end": 12,
      "aya_no": 87,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأوحينا إلى موسى وأخيه أن تبوآ لقومكما بمصر بيوتا واجعلوا بيوتكم قبلة وأقيموا الصلاة وبشر المؤمنين"
    },
    {
      "id": 1452,
      "jozz": 11,
      "page": 218,
      "line_start": 12,
      "line_end": 15,
      "aya_no": 88,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وقال موسى ربنا إنك آتيت فرعون وملأه زينة وأموالا في الحياة الدنيا ربنا ليضلوا عن سبيلك ربنا اطمس على أموالهم واشدد على قلوبهم فلا يؤمنوا حتى يروا العذاب الأليم"
    },
    {
      "id": 1453,
      "jozz": 11,
      "page": 219,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 89,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال قد أجيبت دعوتكما فاستقيما ولا تتبعان سبيل الذين لا يعلمون"
    },
    {
      "id": 1454,
      "jozz": 11,
      "page": 219,
      "line_start": 2,
      "line_end": 5,
      "aya_no": 90,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجاوزنا ببني إسرائيل البحر فأتبعهم فرعون وجنوده بغيا وعدوا حتى إذا أدركه الغرق قال آمنت أنه لا إله إلا الذي آمنت به بنو إسرائيل وأنا من المسلمين"
    },
    {
      "id": 1455,
      "jozz": 11,
      "page": 219,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 91,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "آلآن وقد عصيت قبل وكنت من المفسدين"
    },
    {
      "id": 1456,
      "jozz": 11,
      "page": 219,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 92,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاليوم ننجيك ببدنك لتكون لمن خلفك آية وإن كثيرا من الناس عن آياتنا لغافلون"
    },
    {
      "id": 1457,
      "jozz": 11,
      "page": 219,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 93,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد بوأنا بني إسرائيل مبوأ صدق ورزقناهم من الطيبات فما اختلفوا حتى جاءهم العلم إن ربك يقضي بينهم يوم القيامة فيما كانوا فيه يختلفون"
    },
    {
      "id": 1458,
      "jozz": 11,
      "page": 219,
      "line_start": 10,
      "line_end": 12,
      "aya_no": 94,
      "aya_text": "‏‏‏ ‏‏‏ ‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإن كنت في شك مما أنزلنا إليك فاسأل الذين يقرؤون الكتاب من قبلك لقد جاءك الحق من ربك فلا تكونن من الممترين"
    },
    {
      "id": 1459,
      "jozz": 11,
      "page": 219,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 95,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا تكونن من الذين كذبوا بآيات الله فتكون من الخاسرين"
    },
    {
      "id": 1460,
      "jozz": 11,
      "page": 219,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 96,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين حقت عليهم كلمت ربك لا يؤمنون"
    },
    {
      "id": 1461,
      "jozz": 11,
      "page": 219,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 97,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولو جاءتهم كل آية حتى يروا العذاب الأليم"
    },
    {
      "id": 1462,
      "jozz": 11,
      "page": 220,
      "line_start": 1,
      "line_end": 3,
      "aya_no": 98,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏",
      "aya_text_emlaey": "فلولا كانت قرية آمنت فنفعها إيمانها إلا قوم يونس لما آمنوا كشفنا عنهم عذاب الخزي في الحياة الدنيا ومتعناهم إلى حين"
    },
    {
      "id": 1463,
      "jozz": 11,
      "page": 220,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 99,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولو شاء ربك لآمن من في الأرض كلهم جميعا أفأنت تكره الناس حتى يكونوا مؤمنين"
    },
    {
      "id": 1464,
      "jozz": 11,
      "page": 220,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 100,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما كان لنفس أن تؤمن إلا بإذن الله ويجعل الرجس على الذين لا يعقلون"
    },
    {
      "id": 1465,
      "jozz": 11,
      "page": 220,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 101,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل انظروا ماذا في السموات والأرض وما تغني الآيات والنذر عن قوم لا يؤمنون"
    },
    {
      "id": 1466,
      "jozz": 11,
      "page": 220,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 102,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فهل ينتظرون إلا مثل أيام الذين خلوا من قبلهم قل فانتظروا إني معكم من المنتظرين"
    },
    {
      "id": 1467,
      "jozz": 11,
      "page": 220,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 103,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم ننجي رسلنا والذين آمنوا كذلك حقا علينا ننج المؤمنين"
    },
    {
      "id": 1468,
      "jozz": 11,
      "page": 220,
      "line_start": 11,
      "line_end": 13,
      "aya_no": 104,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل ياأيها الناس إن كنتم في شك من ديني فلا أعبد الذين تعبدون من دون الله ولكن أعبد الله الذي يتوفاكم وأمرت أن أكون من المؤمنين"
    },
    {
      "id": 1469,
      "jozz": 11,
      "page": 220,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 105,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأن أقم وجهك للدين حنيفا ولا تكونن من المشركين"
    },
    {
      "id": 1470,
      "jozz": 11,
      "page": 220,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 106,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولا تدع من دون الله ما لا ينفعك ولا يضرك فإن فعلت فإنك إذا من الظالمين"
    },
    {
      "id": 1471,
      "jozz": 11,
      "page": 221,
      "line_start": 1,
      "line_end": 3,
      "aya_no": 107,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن يمسسك الله بضر فلا كاشف له إلا هو وإن يردك بخير فلا راد لفضله يصيب به من يشاء من عباده وهو الغفور الرحيم"
    },
    {
      "id": 1472,
      "jozz": 11,
      "page": 221,
      "line_start": 3,
      "line_end": 5,
      "aya_no": 108,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل ياأيها الناس قد جاءكم الحق من ربكم فمن اهتدى فإنما يهتدي لنفسه ومن ضل فإنما يضل عليها وما أنا عليكم بوكيل"
    },
    {
      "id": 1473,
      "jozz": 11,
      "page": 221,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 109,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "واتبع ما يوحى إليك واصبر حتى يحكم الله وهو خير الحاكمين"
    }
  ]
}