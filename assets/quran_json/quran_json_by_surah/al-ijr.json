{
  "metadata": {
    "sura_no": 15,
    "sura_name_en": "Al-Ḥijr",
    "sura_name_ar": "الحِجر",
    "total_verses": 99,
    "created_at": "2025-10-11T18:45:17.890Z"
  },
  "verses": [
    {
      "id": 1803,
      "jozz": 14,
      "page": 262,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "الر تلك آيات الكتاب وقرآن مبين"
    },
    {
      "id": 1804,
      "jozz": 14,
      "page": 262,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 2,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ربما يود الذين كفروا لو كانوا مسلمين"
    },
    {
      "id": 1805,
      "jozz": 14,
      "page": 262,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 3,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ذرهم يأكلوا ويتمتعوا ويلههم الأمل فسوف يعلمون"
    },
    {
      "id": 1806,
      "jozz": 14,
      "page": 262,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أهلكنا من قرية إلا ولها كتاب معلوم"
    },
    {
      "id": 1807,
      "jozz": 14,
      "page": 262,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 5,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما تسبق من أمة أجلها وما يستأخرون"
    },
    {
      "id": 1808,
      "jozz": 14,
      "page": 262,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقالوا ياأيها الذي نزل عليه الذكر إنك لمجنون"
    },
    {
      "id": 1809,
      "jozz": 14,
      "page": 262,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 7,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لو ما تأتينا بالملائكة إن كنت من الصادقين"
    },
    {
      "id": 1810,
      "jozz": 14,
      "page": 262,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 8,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما ننزل الملائكة إلا بالحق وما كانوا إذا منظرين"
    },
    {
      "id": 1811,
      "jozz": 14,
      "page": 262,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 9,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا نحن نزلنا الذكر وإنا له لحافظون"
    },
    {
      "id": 1812,
      "jozz": 14,
      "page": 262,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 10,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد أرسلنا من قبلك في شيع الأولين"
    },
    {
      "id": 1813,
      "jozz": 14,
      "page": 262,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 11,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما يأتيهم من رسول إلا كانوا به يستهزئون"
    },
    {
      "id": 1814,
      "jozz": 14,
      "page": 262,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 12,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذلك نسلكه في قلوب المجرمين"
    },
    {
      "id": 1815,
      "jozz": 14,
      "page": 262,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 13,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يؤمنون به وقد خلت سنة الأولين"
    },
    {
      "id": 1816,
      "jozz": 14,
      "page": 262,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولو فتحنا عليهم بابا من السماء فظلوا فيه يعرجون"
    },
    {
      "id": 1817,
      "jozz": 14,
      "page": 262,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لقالوا إنما سكرت أبصارنا بل نحن قوم مسحورون"
    },
    {
      "id": 1818,
      "jozz": 14,
      "page": 263,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 16,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد جعلنا في السماء بروجا وزيناها للناظرين"
    },
    {
      "id": 1819,
      "jozz": 14,
      "page": 263,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وحفظناها من كل شيطان رجيم"
    },
    {
      "id": 1820,
      "jozz": 14,
      "page": 263,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 18,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إلا من استرق السمع فأتبعه شهاب مبين"
    },
    {
      "id": 1821,
      "jozz": 14,
      "page": 263,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والأرض مددناها وألقينا فيها رواسي وأنبتنا فيها من كل شيء موزون"
    },
    {
      "id": 1822,
      "jozz": 14,
      "page": 263,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلنا لكم فيها معايش ومن لستم له برازقين"
    },
    {
      "id": 1823,
      "jozz": 14,
      "page": 263,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 21,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن من شيء إلا عندنا خزائنه وما ننزله إلا بقدر معلوم"
    },
    {
      "id": 1824,
      "jozz": 14,
      "page": 263,
      "line_start": 6,
      "line_end": 8,
      "aya_no": 22,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأرسلنا الرياح لواقح فأنزلنا من السماء ماء فأسقيناكموه وما أنتم له بخازنين"
    },
    {
      "id": 1825,
      "jozz": 14,
      "page": 263,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 23,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنا لنحن نحيي ونميت ونحن الوارثون"
    },
    {
      "id": 1826,
      "jozz": 14,
      "page": 263,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 24,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد علمنا المستقدمين منكم ولقد علمنا المستأخرين"
    },
    {
      "id": 1827,
      "jozz": 14,
      "page": 263,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 25,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن ربك هو يحشرهم إنه حكيم عليم"
    },
    {
      "id": 1828,
      "jozz": 14,
      "page": 263,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 26,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد خلقنا الإنسان من صلصال من حمإ مسنون"
    },
    {
      "id": 1829,
      "jozz": 14,
      "page": 263,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 27,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والجان خلقناه من قبل من نار السموم"
    },
    {
      "id": 1830,
      "jozz": 14,
      "page": 263,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 28,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذ قال ربك للملائكة إني خالق بشرا من صلصال من حمإ مسنون"
    },
    {
      "id": 1831,
      "jozz": 14,
      "page": 263,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 29,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإذا سويته ونفخت فيه من روحي فقعوا له ساجدين"
    },
    {
      "id": 1832,
      "jozz": 14,
      "page": 263,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 30,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فسجد الملائكة كلهم أجمعون"
    },
    {
      "id": 1833,
      "jozz": 14,
      "page": 263,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 31,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا إبليس أبى أن يكون مع الساجدين"
    },
    {
      "id": 1834,
      "jozz": 14,
      "page": 264,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 32,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال ياإبليس ما لك ألا تكون مع الساجدين"
    },
    {
      "id": 1835,
      "jozz": 14,
      "page": 264,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 33,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال لم أكن لأسجد لبشر خلقته من صلصال من حمإ مسنون"
    },
    {
      "id": 1836,
      "jozz": 14,
      "page": 264,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 34,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال فاخرج منها فإنك رجيم"
    },
    {
      "id": 1837,
      "jozz": 14,
      "page": 264,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 35,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن عليك اللعنة إلى يوم الدين"
    },
    {
      "id": 1838,
      "jozz": 14,
      "page": 264,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 36,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال رب فأنظرني إلى يوم يبعثون"
    },
    {
      "id": 1839,
      "jozz": 14,
      "page": 264,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 37,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال فإنك من المنظرين"
    },
    {
      "id": 1840,
      "jozz": 14,
      "page": 264,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 38,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلى يوم الوقت المعلوم"
    },
    {
      "id": 1841,
      "jozz": 14,
      "page": 264,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 39,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال رب بما أغويتني لأزينن لهم في الأرض ولأغوينهم أجمعين"
    },
    {
      "id": 1842,
      "jozz": 14,
      "page": 264,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 40,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا عبادك منهم المخلصين"
    },
    {
      "id": 1843,
      "jozz": 14,
      "page": 264,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 41,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال هذا صراط علي مستقيم"
    },
    {
      "id": 1844,
      "jozz": 14,
      "page": 264,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 42,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن عبادي ليس لك عليهم سلطان إلا من اتبعك من الغاوين"
    },
    {
      "id": 1845,
      "jozz": 14,
      "page": 264,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 43,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن جهنم لموعدهم أجمعين"
    },
    {
      "id": 1846,
      "jozz": 14,
      "page": 264,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 44,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لها سبعة أبواب لكل باب منهم جزء مقسوم"
    },
    {
      "id": 1847,
      "jozz": 14,
      "page": 264,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 45,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن المتقين في جنات وعيون"
    },
    {
      "id": 1848,
      "jozz": 14,
      "page": 264,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 46,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ادخلوها بسلام آمنين"
    },
    {
      "id": 1849,
      "jozz": 14,
      "page": 264,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 47,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونزعنا ما في صدورهم من غل إخوانا على سرر متقابلين"
    },
    {
      "id": 1850,
      "jozz": 14,
      "page": 264,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 48,
      "aya_text": "‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يمسهم فيها نصب وما هم منها بمخرجين"
    },
    {
      "id": 1851,
      "jozz": 14,
      "page": 264,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 49,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "نبئ عبادي أني أنا الغفور الرحيم"
    },
    {
      "id": 1852,
      "jozz": 14,
      "page": 264,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 50,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأن عذابي هو العذاب الأليم"
    },
    {
      "id": 1853,
      "jozz": 14,
      "page": 264,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 51,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونبئهم عن ضيف إبراهيم"
    },
    {
      "id": 1854,
      "jozz": 14,
      "page": 265,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 52,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ دخلوا عليه فقالوا سلاما قال إنا منكم وجلون"
    },
    {
      "id": 1855,
      "jozz": 14,
      "page": 265,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 53,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا لا توجل إنا نبشرك بغلام عليم"
    },
    {
      "id": 1856,
      "jozz": 14,
      "page": 265,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 54,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال أبشرتموني على أن مسني الكبر فبم تبشرون"
    },
    {
      "id": 1857,
      "jozz": 14,
      "page": 265,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 55,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا بشرناك بالحق فلا تكن من القانطين"
    },
    {
      "id": 1858,
      "jozz": 14,
      "page": 265,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 56,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال ومن يقنط من رحمة ربه إلا الضالون"
    },
    {
      "id": 1859,
      "jozz": 14,
      "page": 265,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 57,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال فما خطبكم أيها المرسلون"
    },
    {
      "id": 1860,
      "jozz": 14,
      "page": 265,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 58,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا إنا أرسلنا إلى قوم مجرمين"
    },
    {
      "id": 1861,
      "jozz": 14,
      "page": 265,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 59,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا آل لوط إنا لمنجوهم أجمعين"
    },
    {
      "id": 1862,
      "jozz": 14,
      "page": 265,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 60,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا امرأته قدرنا إنها لمن الغابرين"
    },
    {
      "id": 1863,
      "jozz": 14,
      "page": 265,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 61,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلما جاء آل لوط المرسلون"
    },
    {
      "id": 1864,
      "jozz": 14,
      "page": 265,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 62,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال إنكم قوم منكرون"
    },
    {
      "id": 1865,
      "jozz": 14,
      "page": 265,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 63,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا بل جئناك بما كانوا فيه يمترون"
    },
    {
      "id": 1866,
      "jozz": 14,
      "page": 265,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 64,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأتيناك بالحق وإنا لصادقون"
    },
    {
      "id": 1867,
      "jozz": 14,
      "page": 265,
      "line_start": 10,
      "line_end": 12,
      "aya_no": 65,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأسر بأهلك بقطع من الليل واتبع أدبارهم ولا يلتفت منكم أحد وامضوا حيث تؤمرون"
    },
    {
      "id": 1868,
      "jozz": 14,
      "page": 265,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 66,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقضينا إليه ذلك الأمر أن دابر هؤلاء مقطوع مصبحين"
    },
    {
      "id": 1869,
      "jozz": 14,
      "page": 265,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 67,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجاء أهل المدينة يستبشرون"
    },
    {
      "id": 1870,
      "jozz": 14,
      "page": 265,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 68,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال إن هؤلاء ضيفي فلا تفضحون"
    },
    {
      "id": 1871,
      "jozz": 14,
      "page": 265,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 69,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "واتقوا الله ولا تخزون"
    },
    {
      "id": 1872,
      "jozz": 14,
      "page": 265,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 70,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا أو لم ننهك عن العالمين"
    },
    {
      "id": 1873,
      "jozz": 14,
      "page": 266,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 71,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال هؤلاء بناتي إن كنتم فاعلين"
    },
    {
      "id": 1874,
      "jozz": 14,
      "page": 266,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 72,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لعمرك إنهم لفي سكرتهم يعمهون"
    },
    {
      "id": 1875,
      "jozz": 14,
      "page": 266,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 73,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأخذتهم الصيحة مشرقين"
    },
    {
      "id": 1876,
      "jozz": 14,
      "page": 266,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 74,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فجعلنا عاليها سافلها وأمطرنا عليهم حجارة من سجيل"
    },
    {
      "id": 1877,
      "jozz": 14,
      "page": 266,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 75,
      "aya_text": "‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن في ذلك لآيات للمتوسمين"
    },
    {
      "id": 1878,
      "jozz": 14,
      "page": 266,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 76,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنها لبسبيل مقيم"
    },
    {
      "id": 1879,
      "jozz": 14,
      "page": 266,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 77,
      "aya_text": "‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن في ذلك لآية للمؤمنين"
    },
    {
      "id": 1880,
      "jozz": 14,
      "page": 266,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 78,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإن كان أصحاب الأيكة لظالمين"
    },
    {
      "id": 1881,
      "jozz": 14,
      "page": 266,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 79,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فانتقمنا منهم وإنهما لبإمام مبين"
    },
    {
      "id": 1882,
      "jozz": 14,
      "page": 266,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 80,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد كذب أصحاب الحجر المرسلين"
    },
    {
      "id": 1883,
      "jozz": 14,
      "page": 266,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 81,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وآتيناهم آياتنا فكانوا عنها معرضين"
    },
    {
      "id": 1884,
      "jozz": 14,
      "page": 266,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 82,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكانوا ينحتون من الجبال بيوتا آمنين"
    },
    {
      "id": 1885,
      "jozz": 14,
      "page": 266,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 83,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأخذتهم الصيحة مصبحين"
    },
    {
      "id": 1886,
      "jozz": 14,
      "page": 266,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 84,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما أغنى عنهم ما كانوا يكسبون"
    },
    {
      "id": 1887,
      "jozz": 14,
      "page": 266,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 85,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما خلقنا السموات والأرض وما بينهما إلا بالحق وإن الساعة لآتية فاصفح الصفح الجميل"
    },
    {
      "id": 1888,
      "jozz": 14,
      "page": 266,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 86,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن ربك هو الخلاق العليم"
    },
    {
      "id": 1889,
      "jozz": 14,
      "page": 266,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 87,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد آتيناك سبعا من المثاني والقرآن العظيم"
    },
    {
      "id": 1890,
      "jozz": 14,
      "page": 266,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 88,
      "aya_text": "‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا تمدن عينيك إلى ما متعنا به أزواجا منهم ولا تحزن عليهم واخفض جناحك للمؤمنين"
    },
    {
      "id": 1891,
      "jozz": 14,
      "page": 266,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 89,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقل إني أنا النذير المبين"
    },
    {
      "id": 1892,
      "jozz": 14,
      "page": 266,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 90,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كما أنزلنا على المقتسمين"
    },
    {
      "id": 1893,
      "jozz": 14,
      "page": 267,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 91,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "الذين جعلوا القرآن عضين"
    },
    {
      "id": 1894,
      "jozz": 14,
      "page": 267,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 92,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فوربك لنسألنهم أجمعين"
    },
    {
      "id": 1895,
      "jozz": 14,
      "page": 267,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 93,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عما كانوا يعملون"
    },
    {
      "id": 1896,
      "jozz": 14,
      "page": 267,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 94,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاصدع بما تؤمر وأعرض عن المشركين"
    },
    {
      "id": 1897,
      "jozz": 14,
      "page": 267,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 95,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا كفيناك المستهزئين"
    },
    {
      "id": 1898,
      "jozz": 14,
      "page": 267,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 96,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
