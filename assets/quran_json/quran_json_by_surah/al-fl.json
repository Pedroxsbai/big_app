  "verses": [
    {
      "id": 6189,
      "jozz": 30,
      "page": 601,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 1,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم تر كيف فعل ربك بأصحاب الفيل"
    },
    {
      "id": 6190,
      "jozz": 30,
      "page": 601,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم يجعل كيدهم في تضليل"
    },
    {
      "id": 6191,
      "jozz": 30,
      "page": 601,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأرسل عليهم طيرا أبابيل"
    },
    {
      "id": 6192,
      "jozz": 30,
      "page": 601,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 4,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ترميهم بحجارة من سجيل"
    },
    {
      "id": 6193,
      "jozz": 30,
      "page": 601,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فجعلهم كعصف مأكول"
    }
  ]
}