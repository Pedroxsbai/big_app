{
  "metadata": {
    "sura_no": 78,
    "sura_name_en": "An-Naba’",
    "sura_name_ar": "النَّبَإ",
    "total_verses": 40,
    "created_at": "2025-10-11T18:45:17.969Z"
  },
  "verses": [
    {
      "id": 5673,
      "jozz": 30,
      "page": 582,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عم يتساءلون"
    },
    {
      "id": 5674,
      "jozz": 30,
      "page": 582,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عن النبإ العظيم"
    },
    {
      "id": 5675,
      "jozz": 30,
      "page": 582,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذي هم فيه مختلفون"
    },
    {
      "id": 5676,
      "jozz": 30,
      "page": 582,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 4,
      "aya_text": "‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا سيعلمون"
    },
    {
      "id": 5677,
      "jozz": 30,
      "page": 582,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 5,
      "aya_text": "‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم كلا سيعلمون"
    },
    {
      "id": 5678,
      "jozz": 30,
      "page": 582,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 6,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألم نجعل الأرض مهادا"
    },
    {
      "id": 5679,
      "jozz": 30,
      "page": 582,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والجبال أوتادا"
    },
    {
      "id": 5680,
      "jozz": 30,
      "page": 582,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 8,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وخلقناكم أزواجا"
    },
    {
      "id": 5681,
      "jozz": 30,
      "page": 582,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلنا نومكم سباتا"
    },
    {
      "id": 5682,
      "jozz": 30,
      "page": 582,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلنا الليل لباسا"
    },
    {
      "id": 5683,
      "jozz": 30,
      "page": 582,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلنا النهار معاشا"
    },
    {
      "id": 5684,
      "jozz": 30,
      "page": 582,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وبنينا فوقكم سبعا شدادا"
    },
    {
      "id": 5685,
      "jozz": 30,
      "page": 582,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 13,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلنا سراجا وهاجا"
    },
    {
      "id": 5686,
      "jozz": 30,
      "page": 582,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنزلنا من المعصرات ماء ثجاجا"
    },
    {
      "id": 5687,
      "jozz": 30,
      "page": 582,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 15,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لنخرج به حبا ونباتا"
    },
    {
      "id": 5688,
      "jozz": 30,
      "page": 582,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 16,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجنات ألفافا"
    },
    {
      "id": 5689,
      "jozz": 30,
      "page": 582,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن يوم الفصل كان ميقاتا"
    },
    {
      "id": 5690,
      "jozz": 30,
      "page": 582,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 18,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم ينفخ في الصور فتأتون أفواجا"
    },
    {
      "id": 5691,
      "jozz": 30,
      "page": 582,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وفتحت السماء فكانت أبوابا"
    },
    {
      "id": 5692,
      "jozz": 30,
      "page": 582,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وسيرت الجبال فكانت سرابا"
    },
    {
      "id": 5693,
      "jozz": 30,
      "page": 582,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 21,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن جهنم كانت مرصادا"
    },
    {
      "id": 5694,
      "jozz": 30,
      "page": 582,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 22,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "للطاغين مآبا"
    },
    {
      "id": 5695,
      "jozz": 30,
      "page": 582,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 23,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لابثين فيها أحقابا"
    },
    {
      "id": 5696,
      "jozz": 30,
      "page": 582,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 24,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يذوقون فيها بردا ولا شرابا"
    },
    {
      "id": 5697,
      "jozz": 30,
      "page": 582,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 25,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا حميما وغساقا"
    },
    {
      "id": 5698,
      "jozz": 30,
      "page": 582,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 26,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "جزاء وفاقا"
    },
    {
      "id": 5699,
      "jozz": 30,
      "page": 582,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 27,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنهم كانوا لا يرجون حسابا"
    },
    {
      "id": 5700,
      "jozz": 30,
      "page": 582,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 28,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكذبوا بآياتنا كذابا"
    },
    {
      "id": 5701,
      "jozz": 30,
      "page": 582,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 29,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وكل شيء أحصيناه كتابا"
    },
    {
      "id": 5702,
      "jozz": 30,
      "page": 582,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 30,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فذوقوا فلن نزيدكم إلا عذابا"
    },
    {
      "id": 5703,
      "jozz": 30,
      "page": 583,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 31,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن للمتقين مفازا"
    },
    {
      "id": 5704,
      "jozz": 30,
      "page": 583,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 32,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "حدائق وأعنابا"
    },
    {
      "id": 5705,
      "jozz": 30,
      "page": 583,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 33,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكواعب أترابا"
    },
    {
      "id": 5706,
      "jozz": 30,
      "page": 583,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 34,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكأسا دهاقا"
    },
    {
      "id": 5707,
      "jozz": 30,
      "page": 583,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 35,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يسمعون فيها لغوا ولا كذابا"
    },
    {
      "id": 5708,
      "jozz": 30,
      "page": 583,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 36,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "جزاء من ربك عطاء حسابا"
    },
    {
      "id": 5709,
      "jozz": 30,
      "page": 583,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 37,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "رب السموات والأرض وما بينهما الرحمن لا يملكون منه خطابا"
    },
    {
      "id": 5710,
      "jozz": 30,
      "page": 583,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 38,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم يقوم الروح والملائكة صفا لا يتكلمون إلا من أذن له الرحمن وقال صوابا"
    },
    {
      "id": 5711,
      "jozz": 30,
      "page": 583,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 39,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ذلك اليوم الحق فمن شاء اتخذ إلى ربه مآبا"
    },
    {
      "id": 5712,
      "jozz": 30,
      "page": 583,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 40,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
