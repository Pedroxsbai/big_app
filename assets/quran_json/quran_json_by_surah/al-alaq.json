{
  "metadata": {
    "sura_no": 96,
    "sura_name_en": "Al-‘Alaq",
    "sura_name_ar": "العَلَق",
    "total_verses": 19,
    "created_at": "2025-10-11T18:45:17.990Z"
  },
  "verses": [
    {
      "id": 6107,
      "jozz": 30,
      "page": 597,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 1,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "اقرأ باسم ربك الذي خلق"
    },
    {
      "id": 6108,
      "jozz": 30,
      "page": 597,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "خلق الإنسان من علق"
    },
    {
      "id": 6109,
      "jozz": 30,
      "page": 597,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 3,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "اقرأ وربك الأكرم"
    },
    {
      "id": 6110,
      "jozz": 30,
      "page": 597,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذي علم بالقلم"
    },
    {
      "id": 6111,
      "jozz": 30,
      "page": 597,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 5,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "علم الإنسان ما لم يعلم"
    },
    {
      "id": 6112,
      "jozz": 30,
      "page": 597,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 6,
      "aya_text": "‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "كلا إن الإنسان ليطغى"
    },
    {
      "id": 6113,
      "jozz": 30,
      "page": 597,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 7,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أن رآه استغنى"
    },
    {
      "id": 6114,
      "jozz": 30,
      "page": 597,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 8,
      "aya_text": "‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن إلى ربك الرجعى"
    },
    {
      "id": 6115,
      "jozz": 30,
      "page": 597,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "أرأيت الذي ينهى"
    },
    {
      "id": 6116,
      "jozz": 30,
      "page": 597,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 10,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "عبدا إذا صلى"
    },
    {
      "id": 6117,
      "jozz": 30,
      "page": 597,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أرأيت إن كان على الهدى"
    },
    {
      "id": 6118,
      "jozz": 30,
      "page": 597,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 12,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أو أمر بالتقوى"
    },
    {
      "id": 6119,
      "jozz": 30,
      "page": 598,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 13,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أرأيت إن كذب وتولى"
    },
    {
      "id": 6120,
      "jozz": 30,
      "page": 598,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ألم يعلم بأن الله يرى"
    },
    {
      "id": 6121,
      "jozz": 30,
      "page": 598,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 15,
      "aya_text": "‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا لئن لم ينته لنسفعا بالناصية"
    },
    {
      "id": 6122,
      "jozz": 30,
      "page": 598,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ناصية كاذبة خاطئة"
    },
    {
      "id": 6123,
      "jozz": 30,
      "page": 598,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فليدع ناديه"
    },
    {
      "id": 6124,
      "jozz": 30,
      "page": 598,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 18,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سندع الزبانية"
    },
    {
      "id": 6125,
      "jozz": 30,
      "page": 598,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 19,
      "aya_text": "‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كلا لا تطعه واسجد واقترب"
    }
  ]
}