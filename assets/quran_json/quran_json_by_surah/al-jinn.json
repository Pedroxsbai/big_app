{
  "metadata": {
    "sura_no": 72,
    "sura_name_en": "Al-Jinn",
    "sura_name_ar": "الجِن",
    "total_verses": 28,
    "created_at": "2025-10-11T18:45:17.962Z"
  },
  "verses": [
    {
      "id": 5448,
      "jozz": 29,
      "page": 572,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 1,
      "aya_text": "‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قل أوحي إلي أنه استمع نفر من الجن فقالوا إنا سمعنا قرآنا عجبا"
    },
    {
      "id": 5449,
      "jozz": 29,
      "page": 572,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 2,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يهدي إلى الرشد فآمنا به ولن نشرك بربنا أحدا"
    },
    {
      "id": 5450,
      "jozz": 29,
      "page": 572,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وأنه تعالى جد ربنا ما اتخذ صاحبة ولا ولدا"
    },
    {
      "id": 5451,
      "jozz": 29,
      "page": 572,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 4,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنه كان يقول سفيهنا على الله شططا"
    },
    {
      "id": 5452,
      "jozz": 29,
      "page": 572,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنا ظننا أن لن تقول الإنس والجن على الله كذبا"
    },
    {
      "id": 5453,
      "jozz": 29,
      "page": 572,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 6,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنه كان رجال من الإنس يعوذون برجال من الجن فزادوهم رهقا"
    },
    {
      "id": 5454,
      "jozz": 29,
      "page": 572,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنهم ظنوا كما ظننتم أن لن يبعث الله أحدا"
    },
    {
      "id": 5455,
      "jozz": 29,
      "page": 572,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 8,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنا لمسنا السماء فوجدناها ملئت حرسا شديدا وشهبا"
    },
    {
      "id": 5456,
      "jozz": 29,
      "page": 572,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 9,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنا كنا نقعد منها مقاعد للسمع فمن يستمع الآن يجد له شهابا رصدا"
    },
    {
      "id": 5457,
      "jozz": 29,
      "page": 572,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 10,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنا لا ندري أشر أريد بمن في الأرض أم أراد بهم ربهم رشدا"
    },
    {
      "id": 5458,
      "jozz": 29,
      "page": 572,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 11,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنا منا الصالحون ومنا دون ذلك كنا طرائق قددا"
    },
    {
      "id": 5459,
      "jozz": 29,
      "page": 572,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 12,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنا ظننا أن لن نعجز الله في الأرض ولن نعجزه هربا"
    },
    {
      "id": 5460,
      "jozz": 29,
      "page": 572,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنا لما سمعنا الهدى آمنا به فمن يؤمن بربه فلا يخاف بخسا ولا رهقا"
    },
    {
      "id": 5461,
      "jozz": 29,
      "page": 573,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 14,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنا منا المسلمون ومنا القاسطون فمن أسلم فأولئك تحروا رشدا"
    },
    {
      "id": 5462,
      "jozz": 29,
      "page": 573,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 15,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما القاسطون فكانوا لجهنم حطبا"
    },
    {
      "id": 5463,
      "jozz": 29,
      "page": 573,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 16,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وألو استقاموا على الطريقة لأسقيناهم ماء غدقا"
    },
    {
      "id": 5464,
      "jozz": 29,
      "page": 573,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 17,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لنفتنهم فيه ومن يعرض عن ذكر ربه يسلكه عذابا صعدا"
    },
    {
      "id": 5465,
      "jozz": 29,
      "page": 573,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 18,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأن المساجد لله فلا تدعوا مع الله أحدا"
    },
    {
      "id": 5466,
      "jozz": 29,
      "page": 573,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وأنه لما قام عبد الله يدعوه كادوا يكونون عليه لبدا"
    },
    {
      "id": 5467,
      "jozz": 29,
      "page": 573,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 20,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قل إنما أدعو ربي ولا أشرك به أحدا"
    },
    {
      "id": 5468,
      "jozz": 29,
      "page": 573,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 21,
      "aya_text": "‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قل إني لا أملك لكم ضرا ولا رشدا"
    },
    {
      "id": 5469,
      "jozz": 29,
      "page": 573,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 22,
      "aya_text": "‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل إني لن يجيرني من الله أحد ولن أجد من دونه ملتحدا"
    },
    {
      "id": 5470,
      "jozz": 29,
      "page": 573,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 23,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا بلاغا من الله ورسالاته ومن يعص الله ورسوله فإن له نار جهنم خالدين فيها أبدا"
    },
    {
      "id": 5471,
      "jozz": 29,
      "page": 573,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 24,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "حتى إذا رأوا ما يوعدون فسيعلمون من أضعف ناصرا وأقل عددا"
    },
    {
      "id": 5472,
      "jozz": 29,
      "page": 573,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 25,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قل إن أدري أقريب ما توعدون أم يجعل له ربي أمدا"
    },
    {
      "id": 5473,
      "jozz": 29,
      "page": 573,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 26,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "عالم الغيب فلا يظهر على غيبه أحدا"
    },
    {
      "id": 5474,
