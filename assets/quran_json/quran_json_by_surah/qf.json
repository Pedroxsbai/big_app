{
  "metadata": {
    "sura_no": 50,
    "sura_name_en": "Qāf",
    "sura_name_ar": "قٓ",
    "total_verses": 45,
    "created_at": "2025-10-11T18:45:17.940Z"
  },
  "verses": [
    {
      "id": 4631,
      "jozz": 26,
      "page": 518,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ق والقرآن المجيد"
    },
    {
      "id": 4632,
      "jozz": 26,
      "page": 518,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "بل عجبوا أن جاءهم منذر منهم فقال الكافرون هذا شيء عجيب"
    },
    {
      "id": 4633,
      "jozz": 26,
      "page": 518,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 3,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أئذا متنا وكنا ترابا ذلك رجع بعيد"
    },
    {
      "id": 4634,
      "jozz": 26,
      "page": 518,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 4,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قد علمنا ما تنقص الأرض منهم وعندنا كتاب حفيظ"
    },
    {
      "id": 4635,
      "jozz": 26,
      "page": 518,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 5,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "بل كذبوا بالحق لما جاءهم فهم في أمر مريج"
    },
    {
      "id": 4636,
      "jozz": 26,
      "page": 518,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفلم ينظروا إلى السماء فوقهم كيف بنيناها وزيناها وما لها من فروج"
    },
    {
      "id": 4637,
      "jozz": 26,
      "page": 518,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والأرض مددناها وألقينا فيها رواسي وأنبتنا فيها من كل زوج بهيج"
    },
    {
      "id": 4638,
      "jozz": 26,
      "page": 518,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 8,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "تبصرة وذكرى لكل عبد منيب"
    },
    {
      "id": 4639,
      "jozz": 26,
      "page": 518,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونزلنا من السماء ماء مباركا فأنبتنا به جنات وحب الحصيد"
    },
    {
      "id": 4640,
      "jozz": 26,
      "page": 518,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والنخل باسقات لها طلع نضيد"
    },
    {
      "id": 4641,
      "jozz": 26,
      "page": 518,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "رزقا للعباد وأحيينا به بلدة ميتا كذلك الخروج"
    },
    {
      "id": 4642,
      "jozz": 26,
      "page": 518,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 12,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كذبت قبلهم قوم نوح وأصحاب الرس وثمود"
    },
    {
      "id": 4643,
      "jozz": 26,
      "page": 518,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 13,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وعاد وفرعون وإخوان لوط"
    },
    {
      "id": 4644,
      "jozz": 26,
      "page": 518,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأصحاب الأيكة وقوم تبع كل كذب الرسل فحق وعيد"
    },
    {
      "id": 4645,
      "jozz": 26,
      "page": 518,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 15,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "أفعيينا بالخلق الأول بل هم في لبس من خلق جديد"
    },
    {
      "id": 4646,
      "jozz": 26,
      "page": 519,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 16,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد خلقنا الإنسان ونعلم ما توسوس به نفسه ونحن أقرب إليه من حبل الوريد"
    },
    {
      "id": 4647,
      "jozz": 26,
      "page": 519,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ يتلقى المتلقيان عن اليمين وعن الشمال قعيد"
    },
    {
      "id": 4648,
      "jozz": 26,
      "page": 519,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 18,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ما يلفظ من قول إلا لديه رقيب عتيد"
    },
    {
      "id": 4649,
      "jozz": 26,
      "page": 519,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 19,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وجاءت سكرة الموت بالحق ذلك ما كنت منه تحيد"
    },
    {
      "id": 4650,
      "jozz": 26,
      "page": 519,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 20,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونفخ في الصور ذلك يوم الوعيد"
    },
    {
      "id": 4651,
      "jozz": 26,
      "page": 519,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 21,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجاءت كل نفس معها سائق وشهيد"
    },
    {
      "id": 4652,
      "jozz": 26,
      "page": 519,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 22,
      "aya_text": "‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لقد كنت في غفلة من هذا فكشفنا عنك غطاءك فبصرك اليوم حديد"
    },
    {
      "id": 4653,
      "jozz": 26,
      "page": 519,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 23,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وقال قرينه هذا ما لدي عتيد"
    },
    {
      "id": 4654,
      "jozz": 26,
      "page": 519,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 24,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ألقيا في جهنم كل كفار عنيد"
    },
    {
      "id": 4655,
      "jozz": 26,
      "page": 519,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 25,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "مناع للخير معتد مريب"
    },
    {
      "id": 4656,
      "jozz": 26,
      "page": 519,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 26,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذي جعل مع الله إلها آخر فألقياه في العذاب الشديد"
    },
    {
      "id": 4657,
      "jozz": 26,
      "page": 519,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 27,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قال قرينه ربنا ما أطغيته ولكن كان في ضلال بعيد"
    },
    {
      "id": 4658,
      "jozz": 26,
      "page": 519,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 28,
      "aya_text": "‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال لا تختصموا لدي وقد قدمت إليكم بالوعيد"
    },
    {
      "id": 4659,
      "jozz": 26,
      "page": 519,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 29,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما يبدل القول لدي وما أنا بظلام للعبيد"
    },
    {
      "id": 4660,
      "jozz": 26,
      "page": 519,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 30,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم نقول لجهنم هل امتلأت وتقول هل من مزيد"
    },
    {
      "id": 4661,
      "jozz": 26,
      "page": 519,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 31,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأزلفت الجنة للمتقين غير بعيد"
    },
    {
      "id": 4662,
      "jozz": 26,
      "page": 519,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 32,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "هذا ما توعدون لكل أواب حفيظ"
    },
    {
      "id": 4663,
      "jozz": 26,
      "page": 519,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 33,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "من خشي الرحمن بالغيب وجاء بقلب منيب"
    },
    {
      "id": 4664,
      "jozz": 26,
      "page": 519,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 34,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ادخلوها بسلام ذلك يوم الخلود"
    },
    {
      "id": 4665,
      "jozz": 26,
      "page": 519,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 35,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لهم ما يشاءون فيها ولدينا مزيد"
    },
    {
      "id": 4666,
      "jozz": 26,
      "page": 520,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 36,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وكم أهلكنا قبلهم من قرن هم أشد منهم بطشا فنقبوا في البلاد هل من محيص"
    },
    {
      "id": 4667,
      "jozz": 26,
      "page": 520,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 37,
      "aya_text": "‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن في ذلك لذكرى لمن كان له قلب أو ألقى السمع وهو شهيد"
    },
    {
      "id": 4668,
      "jozz": 26,
      "page": 520,
      "line_start": 3,
      "line_end": 5,
      "aya_no": 38,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد خلقنا السموات والأرض وما بينهما في ستة أيام وما مسنا من لغوب"
    },
    {
      "id": 4669,
      "jozz": 26,
      "page": 520,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 39,
      "aya_text": "‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاصبر على ما يقولون وسبح بحمد ربك قبل طلوع الشمس وقبل الغروب"
    },
    {
      "id": 4670,
      "jozz": 26,
      "page": 520,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 40,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن الليل فسبحه وأدبار السجود"
    },
    {
      "id": 4671,
      "jozz": 26,
      "page": 520,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 41,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "واستمع يوم يناد المناد من مكان قريب"
    },
    {
      "id": 4672,
      "jozz": 26,
      "page": 520,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 42,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم يسمعون الصيحة بالحق ذلك يوم الخروج"
    },
    {
      "id": 4673,
      "jozz": 26,
      "page": 520,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 43,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا نحن نحيي ونميت وإلينا المصير"
    },
    {
      "id": 4674,
      "jozz": 26,
      "page": 520,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 44,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم تشقق الأرض عنهم سراعا ذلك حشر علينا يسير"
    },
    {
      "id": 4675,
      "jozz": 26,
      "page": 520,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 45,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "نحن أعلم بما يقولون وما أنت عليهم بجبار فذكر بالقرآن من يخاف وعيد"
    }
  ]
}