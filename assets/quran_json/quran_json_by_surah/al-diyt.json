      "line_start": 14,
      "line_end": 14,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "والعاديات ضبحا"
    },
    {
      "id": 6148,
      "jozz": 30,
      "page": 599,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 2,
      "aya_text": "‏‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالموريات قدحا"
    },
    {
      "id": 6149,
      "jozz": 30,
      "page": 599,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فالمغيرات صبحا"
    },
    {
      "id": 6150,
      "jozz": 30,
      "page": 599,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 4,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فأثرن به نقعا"
    },
    {
      "id": 6151,
      "jozz": 30,
      "page": 599,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فوسطن به جمعا"
    },
    {
      "id": 6152,
      "jozz": 30,
      "page": 600,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 6,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الإنسان لربه لكنود"
    },
    {
      "id": 6153,
      "jozz": 30,
      "page": 600,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 7,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنه على ذلك لشهيد"
    },
    {
      "id": 6154,
      "jozz": 30,
      "page": 600,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 8,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنه لحب الخير لشديد"
    },
    {
      "id": 6155,
      "jozz": 30,
      "page": 600,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 9,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفلا يعلم إذا بعثر ما في القبور"
    },
    {
      "id": 6156,
      "jozz": 30,
      "page": 600,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 10,
      "aya_text": "‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وحصل ما في الصدور"
    },
    {
      "id": 6157,
      "jozz": 30,
      "page": 600,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 11,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن ربهم بهم يومئذ لخبير"
    }
  ]
}