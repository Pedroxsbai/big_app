{
  "metadata": {
    "sura_no": 21,
    "sura_name_en": "Al-Anbiyā’",
    "sura_name_ar": "الأنبيَاء",
    "total_verses": 112,
    "created_at": "2025-10-11T18:45:17.900Z"
  },
  "verses": [
    {
      "id": 2484,
      "jozz": 17,
      "page": 322,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "اقترب للناس حسابهم وهم في غفلة معرضون"
    },
    {
      "id": 2485,
      "jozz": 17,
      "page": 322,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما يأتيهم من ذكر من ربهم محدث إلا استمعوه وهم يلعبون"
    },
    {
      "id": 2486,
      "jozz": 17,
      "page": 322,
      "line_start": 5,
      "line_end": 7,
      "aya_no": 3,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لاهية قلوبهم وأسروا النجوى الذين ظلموا هل هذا إلا بشر مثلكم أفتأتون السحر وأنتم تبصرون"
    },
    {
      "id": 2487,
      "jozz": 17,
      "page": 322,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال ربي يعلم القول في السماء والأرض وهو السميع العليم"
    },
    {
      "id": 2488,
      "jozz": 17,
      "page": 322,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 5,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل قالوا أضغاث أحلام بل افتراه بل هو شاعر فليأتنا بآية كما أرسل الأولون"
    },
    {
      "id": 2489,
      "jozz": 17,
      "page": 322,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 6,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ما آمنت قبلهم من قرية أهلكناها أفهم يؤمنون"
    },
    {
      "id": 2490,
      "jozz": 17,
      "page": 322,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أرسلنا قبلك إلا رجالا نوحي إليهم فاسألوا أهل الذكر إن كنتم لا تعلمون"
    },
    {
      "id": 2491,
      "jozz": 17,
      "page": 322,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 8,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وما جعلناهم جسدا لا يأكلون الطعام وما كانوا خالدين"
    },
    {
      "id": 2492,
      "jozz": 17,
      "page": 322,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 9,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم صدقناهم الوعد فأنجيناهم ومن نشاء وأهلكنا المسرفين"
    },
    {
      "id": 2493,
      "jozz": 17,
      "page": 322,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 10,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لقد أنزلنا إليكم كتابا فيه ذكركم أفلا تعقلون"
    },
    {
      "id": 2494,
      "jozz": 17,
      "page": 323,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 11,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكم قصمنا من قرية كانت ظالمة وأنشأنا بعدها قوما آخرين"
    },
    {
      "id": 2495,
      "jozz": 17,
      "page": 323,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 12,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلما أحسوا بأسنا إذا هم منها يركضون"
    },
    {
      "id": 2496,
      "jozz": 17,
      "page": 323,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 13,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا تركضوا وارجعوا إلى ما أترفتم فيه ومساكنكم لعلكم تسألون"
    },
    {
      "id": 2497,
      "jozz": 17,
      "page": 323,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا ياويلنا إنا كنا ظالمين"
    },
    {
      "id": 2498,
      "jozz": 17,
      "page": 323,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 15,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فما زالت تلك دعواهم حتى جعلناهم حصيدا خامدين"
    },
    {
      "id": 2499,
      "jozz": 17,
      "page": 323,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 16,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وما خلقنا السماء والأرض وما بينهما لاعبين"
    },
    {
      "id": 2500,
      "jozz": 17,
      "page": 323,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 17,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لو أردنا أن نتخذ لهوا لاتخذناه من لدنا إن كنا فاعلين"
    },
    {
      "id": 2501,
      "jozz": 17,
      "page": 323,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 18,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل نقذف بالحق على الباطل فيدمغه فإذا هو زاهق ولكم الويل مما تصفون"
    },
    {
      "id": 2502,
      "jozz": 17,
      "page": 323,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 19,
      "aya_text": "‏‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وله من في السموات والأرض ومن عنده لا يستكبرون عن عبادته ولا يستحسرون"
    },
    {
      "id": 2503,
      "jozz": 17,
      "page": 323,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يسبحون الليل والنهار لا يفترون"
    },
    {
      "id": 2504,
      "jozz": 17,
      "page": 323,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 21,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم اتخذوا آلهة من الأرض هم ينشرون"
    },
    {
      "id": 2505,
      "jozz": 17,
      "page": 323,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 22,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لو كان فيهما آلهة إلا الله لفسدتا فسبحان الله رب العرش عما يصفون"
    },
    {
      "id": 2506,
      "jozz": 17,
      "page": 323,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 23,
      "aya_text": "‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يسأل عما يفعل وهم يسألون"
    },
    {
      "id": 2507,
      "jozz": 17,
      "page": 323,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 24,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم اتخذوا من دونه آلهة قل هاتوا برهانكم هذا ذكر من معي وذكر من قبلي بل أكثرهم لا يعلمون الحق فهم معرضون"
    },
    {
      "id": 2508,
      "jozz": 17,
      "page": 324,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 25,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أرسلنا من قبلك من رسول إلا نوحي إليه أنه لا إله إلا أنا فاعبدون"
    },
    {
      "id": 2509,
      "jozz": 17,
      "page": 324,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 26,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقالوا اتخذ الرحمن ولدا سبحانه بل عباد مكرمون"
    },
    {
      "id": 2510,
      "jozz": 17,
      "page": 324,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 27,
      "aya_text": "‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يسبقونه بالقول وهم بأمره يعملون"
    },
    {
      "id": 2511,
      "jozz": 17,
      "page": 324,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 28,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يعلم ما بين أيديهم وما خلفهم ولا يشفعون إلا لمن ارتضى وهم من خشيته مشفقون"
    },
    {
      "id": 2512,
      "jozz": 17,
      "page": 324,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 29,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن يقل منهم إني إله من دونه فذلك نجزيه جهنم كذلك نجزي الظالمين"
    },
    {
      "id": 2513,
      "jozz": 17,
      "page": 324,
      "line_start": 7,
      "line_end": 9,
      "aya_no": 30,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أو لم ير الذين كفروا أن السموات والأرض كانتا رتقا ففتقناهما وجعلنا من الماء كل شيء حي أفلا يؤمنون"
    },
    {
      "id": 2514,
      "jozz": 17,
      "page": 324,
      "line_start": 9,
      "line_end": 11,
      "aya_no": 31,
      "aya_text": "‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلنا في الأرض رواسي أن تميد بهم وجعلنا فيها فجاجا سبلا لعلهم يهتدون"
    },
    {
      "id": 2515,
      "jozz": 17,
      "page": 324,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 32,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلنا السماء سقفا محفوظا وهم عن آياتها معرضون"
    },
    {
      "id": 2516,
      "jozz": 17,
      "page": 324,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 33,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وهو الذي خلق الليل والنهار والشمس والقمر كل في فلك يسبحون"
    },
    {
      "id": 2517,
      "jozz": 17,
      "page": 324,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 34,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما جعلنا لبشر من قبلك الخلد أفإن مت فهم الخالدون"
    },
    {
      "id": 2518,
      "jozz": 17,
      "page": 324,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 35,
      "aya_text": "‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كل نفس ذائقة الموت ونبلوكم بالشر والخير فتنة وإلينا ترجعون"
    },
    {
      "id": 2519,
      "jozz": 17,
      "page": 325,
      "line_start": 1,
      "line_end": 3,
      "aya_no": 36,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإذا رآك الذين كفروا إن يتخذونك إلا هزوا أهذا الذي يذكر آلهتكم وهم بذكر الرحمن هم كافرون"
    },
    {
      "id": 2520,
      "jozz": 17,
      "page": 325,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 37,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "خلق الإنسان من عجل سأريكم آياتي فلا تستعجلون"
    },
    {
      "id": 2521,
      "jozz": 17,
      "page": 325,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 38,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ويقولون متى هذا الوعد إن كنتم صادقين"
    },
    {
      "id": 2522,
      "jozz": 17,
      "page": 325,
      "line_start": 5,
      "line_end": 7,
      "aya_no": 39,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لو يعلم الذين كفروا حين لا يكفون عن وجوههم النار ولا عن ظهورهم ولا هم ينصرون"
    },
    {
      "id": 2523,
      "jozz": 17,
      "page": 325,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 40,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل تأتيهم بغتة فتبهتهم فلا يستطيعون ردها ولا هم ينظرون"
    },
    {
      "id": 2524,
      "jozz": 17,
      "page": 325,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 41,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد استهزئ برسل من قبلك فحاق بالذين سخروا منهم ما كانوا به يستهزئون"
    },
    {
      "id": 2525,
      "jozz": 17,
      "page": 325,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 42,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل من يكلؤكم بالليل والنهار من الرحمن بل هم عن ذكر ربهم معرضون"
    },
    {
      "id": 2526,
      "jozz": 17,
      "page": 325,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 43,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أم لهم آلهة تمنعهم من دوننا لا يستطيعون نصر أنفسهم ولا هم منا يصحبون"
    },
    {
      "id": 2527,
      "jozz": 17,
      "page": 325,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 44,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل متعنا هؤلاء وآباءهم حتى طال عليهم العمر أفلا يرون أنا نأتي الأرض ننقصها من أطرافها أفهم الغالبون"
    },
    {
      "id": 2528,
      "jozz": 17,
      "page": 326,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 45,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل إنما أنذركم بالوحي ولا يسمع الصم الدعاء إذا ما ينذرون"
    },
    {
      "id": 2529,
      "jozz": 17,
      "page": 326,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 46,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولئن مستهم نفحة من عذاب ربك ليقولن ياويلنا إنا كنا ظالمين"
    },
    {
      "id": 2530,
      "jozz": 17,
      "page": 326,
      "line_start": 3,
      "line_end": 5,
      "aya_no": 47,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ونضع الموازين القسط ليوم القيامة فلا تظلم نفس شيئا وإن كان مثقال حبة من خردل أتينا بها وكفى بنا حاسبين"
    },
    {
      "id": 2531,
      "jozz": 17,
      "page": 326,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 48,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد آتينا موسى وهارون الفرقان وضياء وذكرا للمتقين"
    },
    {
      "id": 2532,
      "jozz": 17,
      "page": 326,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 49,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "الذين يخشون ربهم بالغيب وهم من الساعة مشفقون"
    },
    {
      "id": 2533,
      "jozz": 17,
      "page": 326,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 50,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وهذا ذكر مبارك أنزلناه أفأنتم له منكرون"
    },
    {
      "id": 2534,
      "jozz": 17,
      "page": 326,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 51,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد آتينا إبراهيم رشده من قبل وكنا به عالمين"
    },
    {
      "id": 2535,
      "jozz": 17,
      "page": 326,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 52,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذ قال لأبيه وقومه ما هذه التماثيل التي أنتم لها عاكفون"
    },
    {
      "id": 2536,
      "jozz": 17,
      "page": 326,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 53,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا وجدنا آباءنا لها عابدين"
    },
    {
      "id": 2537,
      "jozz": 17,
      "page": 326,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 54,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "قال لقد كنتم أنتم وآباؤكم في ضلال مبين"
    },
    {
      "id": 2538,
      "jozz": 17,
      "page": 326,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 55,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا أجئتنا بالحق أم أنت من اللاعبين"
    },
    {
      "id": 2539,
      "jozz": 17,
      "page": 326,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 56,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال بل ربكم رب السموات والأرض الذي فطرهن وأنا على ذلكم من الشاهدين"
    },
    {
      "id": 2540,
      "jozz": 17,
      "page": 326,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 57,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وتالله لأكيدن أصنامكم بعد أن تولوا مدبرين"
    },
    {
      "id": 2541,
      "jozz": 17,
      "page": 327,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 58,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فجعلهم جذاذا إلا كبيرا لهم لعلهم إليه يرجعون"
    },
    {
      "id": 2542,
      "jozz": 17,
      "page": 327,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 59,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا من فعل هذا بآلهتنا إنه لمن الظالمين"
    },
    {
      "id": 2543,
      "jozz": 17,
      "page": 327,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 60,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا سمعنا فتى يذكرهم يقال له إبراهيم"
    },
    {
      "id": 2544,
      "jozz": 17,
      "page": 327,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 61,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا فأتوا به على أعين الناس لعلهم يشهدون"
    },
    {
      "id": 2545,
      "jozz": 17,
      "page": 327,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 62,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا أأنت فعلت هذا بآلهتنا ياإبراهيم"
    },
    {
      "id": 2546,
      "jozz": 17,
      "page": 327,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 63,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال بل فعله كبيرهم هذا فاسألوهم إن كانوا ينطقون"
    },
    {
      "id": 2547,
      "jozz": 17,
      "page": 327,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 64,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فرجعوا إلى أنفسهم فقالوا إنكم أنتم الظالمون"
    },
    {
      "id": 2548,
      "jozz": 17,
      "page": 327,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 65,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم نكسوا على رءوسهم لقد علمت ما هؤلاء ينطقون"
    },
    {
      "id": 2549,
      "jozz": 17,
      "page": 327,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 66,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال أفتعبدون من دون الله ما لا ينفعكم شيئا ولا يضركم"
    },
    {
      "id": 2550,
      "jozz": 17,
      "page": 327,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 67,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أف لكم ولما تعبدون من دون الله أفلا تعقلون"
    },
    {
      "id": 2551,
      "jozz": 17,
      "page": 327,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 68,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "قالوا حرقوه وانصروا آلهتكم إن كنتم فاعلين"
    },
    {
      "id": 2552,
      "jozz": 17,
      "page": 327,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 69,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قلنا يانار كوني بردا وسلاما على إبراهيم"
    },
    {
      "id": 2553,
      "jozz": 17,
      "page": 327,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 70,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأرادوا به كيدا فجعلناهم الأخسرين"
    },
    {
      "id": 2554,
      "jozz": 17,
      "page": 327,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 71,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونجيناه ولوطا إلى الأرض التي باركنا فيها للعالمين"
    },
    {
      "id": 2555,
      "jozz": 17,
      "page": 327,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 72,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ووهبنا له إسحاق ويعقوب نافلة وكلا جعلنا صالحين"
    },
    {
      "id": 2556,
      "jozz": 17,
      "page": 328,
      "line_start": 1,
      "line_end": 3,
      "aya_no": 73,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وجعلناهم أئمة يهدون بأمرنا وأوحينا إليهم فعل الخيرات وإقام الصلاة وإيتاء الزكاة وكانوا لنا عابدين"
    },
    {
      "id": 2557,
      "jozz": 17,
      "page": 328,
      "line_start": 3,
      "line_end": 5,
      "aya_no": 74,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولوطا آتيناه حكما وعلما ونجيناه من القرية التي كانت تعمل الخبائث إنهم كانوا قوم سوء فاسقين"
    },
    {
      "id": 2558,
      "jozz": 17,
      "page": 328,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 75,
      "aya_text": "‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأدخلناه في رحمتنا إنه من الصالحين"
    },
    {
      "id": 2559,
      "jozz": 17,
      "page": 328,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 76,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونوحا إذ نادى من قبل فاستجبنا له فنجيناه وأهله من الكرب العظيم"
    },
    {
      "id": 2560,
      "jozz": 17,
      "page": 328,
      "line_start": 7,
      "line_end": 9,
      "aya_no": 77,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ونصرناه من القوم الذين كذبوا بآياتنا إنهم كانوا قوم سوء فأغرقناهم أجمعين"
    },
    {
      "id": 2561,
      "jozz": 17,
      "page": 328,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 78,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وداود وسليمان إذ يحكمان في الحرث إذ نفشت فيه غنم القوم وكنا لحكمهم شاهدين"
    },
    {
      "id": 2562,
      "jozz": 17,
      "page": 328,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 79,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ففهمناها سليمان وكلا آتينا حكما وعلما وسخرنا مع داود الجبال يسبحن والطير وكنا فاعلين"
    },
    {
      "id": 2563,
      "jozz": 17,
      "page": 328,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 80,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وعلمناه صنعة لبوس لكم لتحصنكم من بأسكم فهل أنتم شاكرون"
    },
    {
      "id": 2564,
      "jozz": 17,
      "page": 328,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 81,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ولسليمان الريح عاصفة تجري بأمره إلى الأرض التي باركنا فيها وكنا بكل شيء عالمين"
    },
    {
      "id": 2565,
      "jozz": 17,
      "page": 329,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 82,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ومن الشياطين من يغوصون له ويعملون عملا دون ذلك وكنا لهم حافظين"
    },
    {
      "id": 2566,
      "jozz": 17,
      "page": 329,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 83,
      "aya_text": "‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأيوب إذ نادى ربه أني مسني الضر وأنت أرحم الراحمين"
    },
    {
      "id": 2567,
      "jozz": 17,
      "page": 329,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 84,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاستجبنا له فكشفنا ما به من ضر وآتيناه أهله ومثلهم معهم رحمة من عندنا وذكرى للعابدين"
    },
    {
      "id": 2568,
      "jozz": 17,
      "page": 329,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 85,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وإسماعيل وإدريس وذا الكفل كل من الصابرين"
    },
    {
      "id": 2569,
      "jozz": 17,
      "page": 329,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 86,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأدخلناهم في رحمتنا إنهم من الصالحين"
    },
    {
      "id": 2570,
      "jozz": 17,
      "page": 329,
      "line_start": 8,
      "line_end": 10,
      "aya_no": 87,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وذا النون إذ ذهب مغاضبا فظن أن لن نقدر عليه فنادى في الظلمات أن لا إله إلا أنت سبحانك إني كنت من الظالمين"
    },
    {
      "id": 2571,
      "jozz": 17,
      "page": 329,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 88,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فاستجبنا له ونجيناه من الغم وكذلك ننجي المؤمنين"
    },
    {
      "id": 2572,
      "jozz": 17,
      "page": 329,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 89,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وزكريا إذ نادى ربه رب لا تذرني فردا وأنت خير الوارثين"
    },
    {
      "id": 2573,
      "jozz": 17,
      "page": 329,
      "line_start": 13,
      "line_end": 15,
      "aya_no": 90,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فاستجبنا له ووهبنا له يحيى وأصلحنا له زوجه إنهم كانوا يسارعون في الخيرات ويدعوننا رغبا ورهبا وكانوا لنا خاشعين"
    },
    {
      "id": 2574,
      "jozz": 17,
      "page": 330,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 91,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والتي أحصنت فرجها فنفخنا فيها من روحنا وجعلناها وابنها آية للعالمين"
    },
    {
      "id": 2575,
      "jozz": 17,
      "page": 330,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 92,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هذه أمتكم أمة واحدة وأنا ربكم فاعبدون"
    },
    {
      "id": 2576,
      "jozz": 17,
      "page": 330,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 93,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وتقطعوا أمرهم بينهم كل إلينا راجعون"
    },
    {
      "id": 2577,
      "jozz": 17,
      "page": 330,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 94,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فمن يعمل من الصالحات وهو مؤمن فلا كفران لسعيه وإنا له كاتبون"
    },
    {
      "id": 2578,
      "jozz": 17,
      "page": 330,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 95,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وحرام على قرية أهلكناها أنهم لا يرجعون"
    },
    {
      "id": 2579,
      "jozz": 17,
      "page": 330,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 96,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏ ‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "حتى إذا فتحت يأجوج ومأجوج وهم من كل حدب ينسلون"
    },
    {
      "id": 2580,
      "jozz": 17,
      "page": 330,
      "line_start": 9,
      "line_end": 11,
      "aya_no": 97,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "واقترب الوعد الحق فإذا هي شاخصة أبصار الذين كفروا ياويلنا قد كنا في غفلة من هذا بل كنا ظالمين"
    },
    {
      "id": 2581,
      "jozz": 17,
      "page": 330,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 98,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنكم وما تعبدون من دون الله حصب جهنم أنتم لها واردون"
    },
    {
      "id": 2582,
      "jozz": 17,
      "page": 330,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 99,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لو كان هؤلاء آلهة ما وردوها وكل فيها خالدون"
    },
    {
      "id": 2583,
      "jozz": 17,
      "page": 330,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 100,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لهم فيها زفير وهم فيها لا يسمعون"
    },
    {
      "id": 2584,
      "jozz": 17,
      "page": 330,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 101,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن الذين سبقت لهم منا الحسنى أولئك عنها مبعدون"
    },
    {
      "id": 2585,
      "jozz": 17,
      "page": 331,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 102,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يسمعون حسيسها وهم في ما اشتهت أنفسهم خالدون"
    },
    {
      "id": 2586,
      "jozz": 17,
      "page": 331,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 103,
      "aya_text": "‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يحزنهم الفزع الأكبر وتتلقاهم الملائكة هذا يومكم الذي كنتم توعدون"
    },
    {
      "id": 2587,
      "jozz": 17,
      "page": 331,
      "line_start": 4,
      "line_end": 6,
      "aya_no": 104,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم نطوي السماء كطي السجل للكتب كما بدأنا أول خلق نعيده وعدا علينا إنا كنا فاعلين"
    },
    {
      "id": 2588,
      "jozz": 17,
      "page": 331,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 105,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد كتبنا في الزبور من بعد الذكر أن الأرض يرثها عبادي الصالحون"
    },
    {
      "id": 2589,
      "jozz": 17,
      "page": 331,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 106,
      "aya_text": "‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إن في هذا لبلاغا لقوم عابدين"
    },
    {
      "id": 2590,
      "jozz": 17,
      "page": 331,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 107,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أرسلناك إلا رحمة للعالمين"
    },
    {
      "id": 2591,
      "jozz": 17,
      "page": 331,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 108,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل إنما يوحى إلي أنما إلهكم إله واحد فهل أنتم مسلمون"
    },
    {
      "id": 2592,
      "jozz": 17,
      "page": 331,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 109,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فإن تولوا فقل آذنتكم على سواء وإن أدري أقريب أم بعيد ما توعدون"
    },
    {
      "id": 2593,
      "jozz": 17,
      "page": 331,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 110,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه يعلم الجهر من القول ويعلم ما تكتمون"
    },
    {
      "id": 2594,
      "jozz": 17,
      "page": 331,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 111,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏‏ ‏",
      "aya_text_emlaey": "وإن أدري لعله فتنة لكم ومتاع إلى حين"
    },
    {
      "id": 2595,
      "jozz": 17,
      "page": 331,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 112,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قال رب احكم ‎ بالحق وربنا الرحمن المستعان على ما تصفون"
    }
  ]
}