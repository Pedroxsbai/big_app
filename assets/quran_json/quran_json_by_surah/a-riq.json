{
  "metadata": {
    "sura_no": 86,
    "sura_name_en": "Aṭ-Ṭāriq",
    "sura_name_ar": "الطَّارق",
    "total_verses": 17,
    "created_at": "2025-10-11T18:45:17.978Z"
  },
  "verses": [
    {
      "id": 5932,
      "jozz": 30,
      "page": 591,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 1,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والسماء والطارق"
    },
    {
      "id": 5933,
      "jozz": 30,
      "page": 591,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أدراك ما الطارق"
    },
    {
      "id": 5934,
      "jozz": 30,
      "page": 591,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 3,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "النجم الثاقب"
    },
    {
      "id": 5935,
      "jozz": 30,
      "page": 591,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 4,
      "aya_text": "‏‏ ‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن كل نفس لما عليها حافظ"
    },
    {
      "id": 5936,
      "jozz": 30,
      "page": 591,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 5,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فلينظر الإنسان مم خلق"
    },
    {
      "id": 5937,
      "jozz": 30,
      "page": 591,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 6,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "خلق من ماء دافق"
    },
    {
      "id": 5938,
      "jozz": 30,
      "page": 591,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 7,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يخرج من بين الصلب والترائب"
    },
    {
      "id": 5939,
      "jozz": 30,
      "page": 591,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 8,
      "aya_text": "‏‏‏‏ ‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه على رجعه لقادر"
    },
    {
      "id": 5940,
      "jozz": 30,
      "page": 591,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 9,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يوم تبلى السرائر"
    },
    {
      "id": 5941,
      "jozz": 30,
      "page": 591,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 10,
      "aya_text": "‏‏‏ ‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فما له من قوة ولا ناصر"
    },
    {
      "id": 5942,
      "jozz": 30,
      "page": 591,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والسماء ذات الرجع"
    },
    {
      "id": 5943,
      "jozz": 30,
      "page": 591,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 12,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والأرض ذات الصدع"
    },
    {
      "id": 5944,
      "jozz": 30,
      "page": 591,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 13,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إنه لقول فصل"
    },
    {
      "id": 5945,
      "jozz": 30,
      "page": 591,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 14,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما هو بالهزل"
    },
    {
      "id": 5946,
      "jozz": 30,
      "page": 591,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 15,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنهم يكيدون كيدا"
    },
    {
      "id": 5947,
      "jozz": 30,
      "page": 591,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 16,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأكيد كيدا"
    },
    {
      "id": 5948,
      "jozz": 30,
      "page": 591,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 17,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فمهل الكافرين أمهلهم رويدا"
    }
  ]
}