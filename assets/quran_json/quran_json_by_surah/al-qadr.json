      "page": 598,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 1,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا أنزلناه في ليلة القدر"
    },
    {
      "id": 6127,
      "jozz": 30,
      "page": 598,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 2,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وما أدراك ما ليلة القدر"
    },
    {
      "id": 6128,
      "jozz": 30,
      "page": 598,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 3,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "ليلة القدر خير من ألف شهر"
    },
    {
      "id": 6129,
      "jozz": 30,
      "page": 598,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 4,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏ ‏ ‏‏‏ ‏",
      "aya_text_emlaey": "تنزل الملائكة والروح فيها بإذن ربهم من كل أمر"
    },
    {
      "id": 6130,
      "jozz": 30,
      "page": 598,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 5,
      "aya_text": "‏‏‏ ‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "سلام هي حتى مطلع الفجر"
    }
  ]
