{
  "metadata": {
    "sura_no": 56,
    "sura_name_en": "Al-Wāqi‘ah",
    "sura_name_ar": "الوَاقِعة",
    "total_verses": 96,
    "created_at": "2025-10-11T18:45:17.947Z"
  },
  "verses": [
    {
      "id": 4980,
      "jozz": 27,
      "page": 534,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 1,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إذا وقعت الواقعة"
    },
    {
      "id": 4981,
      "jozz": 27,
      "page": 534,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 2,
      "aya_text": "‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ليس لوقعتها كاذبة"
    },
    {
      "id": 4982,
      "jozz": 27,
      "page": 534,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 3,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "خافضة رافعة"
    },
    {
      "id": 4983,
      "jozz": 27,
      "page": 534,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 4,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "إذا رجت الأرض رجا"
    },
    {
      "id": 4984,
      "jozz": 27,
      "page": 534,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 5,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "وبست الجبال بسا"
    },
    {
      "id": 4985,
      "jozz": 27,
      "page": 534,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 6,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فكانت هباء منبثا"
    },
    {
      "id": 4986,
      "jozz": 27,
      "page": 534,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 7,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وكنتم أزواجا ثلاثة"
    },
    {
      "id": 4987,
      "jozz": 27,
      "page": 534,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 8,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأصحاب الميمنة ما أصحاب الميمنة"
    },
    {
      "id": 4988,
      "jozz": 27,
      "page": 534,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 9,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأصحاب المشأمة ما أصحاب المشأمة"
    },
    {
      "id": 4989,
      "jozz": 27,
      "page": 534,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 10,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "والسابقون السابقون"
    },
    {
      "id": 4990,
      "jozz": 27,
      "page": 534,
      "line_start": 13,
      "line_end": 13,
      "aya_no": 11,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أولئك المقربون"
    },
    {
      "id": 4991,
      "jozz": 27,
      "page": 534,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 12,
      "aya_text": "‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "في جنات النعيم"
    },
    {
      "id": 4992,
      "jozz": 27,
      "page": 534,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 13,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثلة من الأولين"
    },
    {
      "id": 4993,
      "jozz": 27,
      "page": 534,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 14,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وقليل من الآخرين"
    },
    {
      "id": 4994,
      "jozz": 27,
      "page": 534,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 15,
      "aya_text": "‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "على سرر موضونة"
    },
    {
      "id": 4995,
      "jozz": 27,
      "page": 534,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 16,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "متكئين عليها متقابلين"
    },
    {
      "id": 4996,
      "jozz": 27,
      "page": 535,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 17,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "يطوف عليهم ولدان مخلدون"
    },
    {
      "id": 4997,
      "jozz": 27,
      "page": 535,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 18,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "بأكواب وأباريق وكأس من معين"
    },
    {
      "id": 4998,
      "jozz": 27,
      "page": 535,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 19,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يصدعون عنها ولا ينزفون"
    },
    {
      "id": 4999,
      "jozz": 27,
      "page": 535,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 20,
      "aya_text": "‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وفاكهة مما يتخيرون"
    },
    {
      "id": 5000,
      "jozz": 27,
      "page": 535,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 21,
      "aya_text": "‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولحم طير مما يشتهون"
    },
    {
      "id": 5001,
      "jozz": 27,
      "page": 535,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 22,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏",
      "aya_text_emlaey": "وحور عين"
    },
    {
      "id": 5002,
      "jozz": 27,
      "page": 535,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 23,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "كأمثال اللؤلؤ المكنون"
    },
    {
      "id": 5003,
      "jozz": 27,
      "page": 535,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 24,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "جزاء بما كانوا يعملون"
    },
    {
      "id": 5004,
      "jozz": 27,
      "page": 535,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 25,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يسمعون فيها لغوا ولا تأثيما"
    },
    {
      "id": 5005,
      "jozz": 27,
      "page": 535,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 26,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إلا قيلا سلاما سلاما"
    },
    {
      "id": 5006,
      "jozz": 27,
      "page": 535,
      "line_start": 5,
      "line_end": 6,
      "aya_no": 27,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأصحاب اليمين ما أصحاب اليمين"
    },
    {
      "id": 5007,
      "jozz": 27,
      "page": 535,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 28,
      "aya_text": "‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "في سدر مخضود"
    },
    {
      "id": 5008,
      "jozz": 27,
      "page": 535,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 29,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وطلح منضود"
    },
    {
      "id": 5009,
      "jozz": 27,
      "page": 535,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 30,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وظل ممدود"
    },
    {
      "id": 5010,
      "jozz": 27,
      "page": 535,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 31,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وماء مسكوب"
    },
    {
      "id": 5011,
      "jozz": 27,
      "page": 535,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 32,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وفاكهة كثيرة"
    },
    {
      "id": 5012,
      "jozz": 27,
      "page": 535,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 33,
      "aya_text": "‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا مقطوعة ولا ممنوعة"
    },
    {
      "id": 5013,
      "jozz": 27,
      "page": 535,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 34,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وفرش مرفوعة"
    },
    {
      "id": 5014,
      "jozz": 27,
      "page": 535,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 35,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا أنشأناهن إنشاء"
    },
    {
      "id": 5015,
      "jozz": 27,
      "page": 535,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 36,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فجعلناهن أبكارا"
    },
    {
      "id": 5016,
      "jozz": 27,
      "page": 535,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 37,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "عربا أترابا"
    },
    {
      "id": 5017,
      "jozz": 27,
      "page": 535,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 38,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لأصحاب اليمين"
    },
    {
      "id": 5018,
      "jozz": 27,
      "page": 535,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 39,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثلة من الأولين"
    },
    {
      "id": 5019,
      "jozz": 27,
      "page": 535,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 40,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وثلة من الآخرين"
    },
    {
      "id": 5020,
      "jozz": 27,
      "page": 535,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 41,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأصحاب الشمال ما أصحاب الشمال"
    },
    {
      "id": 5021,
      "jozz": 27,
      "page": 535,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 42,
      "aya_text": "‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "في سموم وحميم"
    },
    {
      "id": 5022,
      "jozz": 27,
      "page": 535,
      "line_start": 11,
      "line_end": 11,
      "aya_no": 43,
      "aya_text": "‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وظل من يحموم"
    },
    {
      "id": 5023,
      "jozz": 27,
      "page": 535,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 44,
      "aya_text": "‏ ‏‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لا بارد ولا كريم"
    },
    {
      "id": 5024,
      "jozz": 27,
      "page": 535,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 45,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنهم كانوا قبل ذلك مترفين"
    },
    {
      "id": 5025,
      "jozz": 27,
      "page": 535,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 46,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكانوا يصرون على الحنث العظيم"
    },
    {
      "id": 5026,
      "jozz": 27,
      "page": 535,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 47,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وكانوا يقولون أئذا متنا وكنا ترابا وعظاما أئنا لمبعوثون"
    },
    {
      "id": 5027,
      "jozz": 27,
      "page": 535,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 48,
      "aya_text": "‏‏‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أو آباؤنا الأولون"
    },
    {
      "id": 5028,
      "jozz": 27,
      "page": 535,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 49,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "قل إن الأولين والآخرين"
    },
    {
      "id": 5029,
      "jozz": 27,
      "page": 535,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 50,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لمجموعون إلى ميقات يوم معلوم"
    },
    {
      "id": 5030,
      "jozz": 27,
      "page": 536,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 51,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ثم إنكم أيها الضالون المكذبون"
    },
    {
      "id": 5031,
      "jozz": 27,
      "page": 536,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 52,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "لآكلون من شجر من زقوم"
    },
    {
      "id": 5032,
      "jozz": 27,
      "page": 536,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 53,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فمالئون منها البطون"
    },
    {
      "id": 5033,
      "jozz": 27,
      "page": 536,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 54,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فشاربون عليه من الحميم"
    },
    {
      "id": 5034,
      "jozz": 27,
      "page": 536,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 55,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فشاربون شرب الهيم"
    },
    {
      "id": 5035,
      "jozz": 27,
      "page": 536,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 56,
      "aya_text": "‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "هذا نزلهم يوم الدين"
    },
    {
      "id": 5036,
      "jozz": 27,
      "page": 536,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 57,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "نحن خلقناكم فلولا تصدقون"
    },
    {
      "id": 5037,
      "jozz": 27,
      "page": 536,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 58,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفرأيتم ما تمنون"
    },
    {
      "id": 5038,
      "jozz": 27,
      "page": 536,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 59,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أأنتم تخلقونه أم نحن الخالقون"
    },
    {
      "id": 5039,
      "jozz": 27,
      "page": 536,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 60,
      "aya_text": "‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "نحن قدرنا بينكم الموت وما نحن بمسبوقين"
    },
    {
      "id": 5040,
      "jozz": 27,
      "page": 536,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 61,
      "aya_text": "‏ ‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏ ‏‏ ‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "على أن نبدل أمثالكم وننشئكم في ما لا تعلمون"
    },
    {
      "id": 5041,
      "jozz": 27,
      "page": 536,
      "line_start": 6,
      "line_end": 7,
      "aya_no": 62,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ولقد علمتم النشأة الأولى فلولا تذكرون"
    },
    {
      "id": 5042,
      "jozz": 27,
      "page": 536,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 63,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفرأيتم ما تحرثون"
    },
    {
      "id": 5043,
      "jozz": 27,
      "page": 536,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 64,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أأنتم تزرعونه أم نحن الزارعون"
    },
    {
      "id": 5044,
      "jozz": 27,
      "page": 536,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 65,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لو نشاء لجعلناه حطاما فظلتم تفكهون"
    },
    {
      "id": 5045,
      "jozz": 27,
      "page": 536,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 66,
      "aya_text": "‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "إنا لمغرمون"
    },
    {
      "id": 5046,
      "jozz": 27,
      "page": 536,
      "line_start": 9,
      "line_end": 10,
      "aya_no": 67,
      "aya_text": "‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "بل نحن محرومون"
    },
    {
      "id": 5047,
      "jozz": 27,
      "page": 536,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 68,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفرأيتم الماء الذي تشربون"
    },
    {
      "id": 5048,
      "jozz": 27,
      "page": 536,
      "line_start": 10,
      "line_end": 11,
      "aya_no": 69,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أأنتم أنزلتموه من المزن أم نحن المنزلون"
    },
    {
      "id": 5049,
      "jozz": 27,
      "page": 536,
      "line_start": 11,
      "line_end": 12,
      "aya_no": 70,
      "aya_text": "‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لو نشاء جعلناه أجاجا فلولا تشكرون"
    },
    {
      "id": 5050,
      "jozz": 27,
      "page": 536,
      "line_start": 12,
      "line_end": 12,
      "aya_no": 71,
      "aya_text": "‏‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفرأيتم النار التي تورون"
    },
    {
      "id": 5051,
      "jozz": 27,
      "page": 536,
      "line_start": 12,
      "line_end": 13,
      "aya_no": 72,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أأنتم أنشأتم شجرتها أم نحن المنشئون"
    },
    {
      "id": 5052,
      "jozz": 27,
      "page": 536,
      "line_start": 13,
      "line_end": 14,
      "aya_no": 73,
      "aya_text": "‏‏ ‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "نحن جعلناها تذكرة ومتاعا للمقوين"
    },
    {
      "id": 5053,
      "jozz": 27,
      "page": 536,
      "line_start": 14,
      "line_end": 14,
      "aya_no": 74,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فسبح باسم ربك العظيم"
    },
    {
      "id": 5054,
      "jozz": 27,
      "page": 536,
      "line_start": 14,
      "line_end": 15,
      "aya_no": 75,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلا أقسم بمواقع النجوم"
    },
    {
      "id": 5055,
      "jozz": 27,
      "page": 536,
      "line_start": 15,
      "line_end": 15,
      "aya_no": 76,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وإنه لقسم لو تعلمون عظيم"
    },
    {
      "id": 5056,
      "jozz": 27,
      "page": 537,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 77,
      "aya_text": "‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إنه لقرآن كريم"
    },
    {
      "id": 5057,
      "jozz": 27,
      "page": 537,
      "line_start": 1,
      "line_end": 1,
      "aya_no": 78,
      "aya_text": "‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "في كتاب مكنون"
    },
    {
      "id": 5058,
      "jozz": 27,
      "page": 537,
      "line_start": 1,
      "line_end": 2,
      "aya_no": 79,
      "aya_text": "‏ ‏‏‏‏‏ ‏‏ ‏‏‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "لا يمسه إلا المطهرون"
    },
    {
      "id": 5059,
      "jozz": 27,
      "page": 537,
      "line_start": 2,
      "line_end": 2,
      "aya_no": 80,
      "aya_text": "‏‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "تنزيل من رب العالمين"
    },
    {
      "id": 5060,
      "jozz": 27,
      "page": 537,
      "line_start": 2,
      "line_end": 3,
      "aya_no": 81,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "أفبهذا الحديث أنتم مدهنون"
    },
    {
      "id": 5061,
      "jozz": 27,
      "page": 537,
      "line_start": 3,
      "line_end": 3,
      "aya_no": 82,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وتجعلون رزقكم أنكم تكذبون"
    },
    {
      "id": 5062,
      "jozz": 27,
      "page": 537,
      "line_start": 3,
      "line_end": 4,
      "aya_no": 83,
      "aya_text": "‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلولا إذا بلغت الحلقوم"
    },
    {
      "id": 5063,
      "jozz": 27,
      "page": 537,
      "line_start": 4,
      "line_end": 4,
      "aya_no": 84,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأنتم حينئذ تنظرون"
    },
    {
      "id": 5064,
      "jozz": 27,
      "page": 537,
      "line_start": 4,
      "line_end": 5,
      "aya_no": 85,
      "aya_text": "‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "ونحن أقرب إليه منكم ولكن لا تبصرون"
    },
    {
      "id": 5065,
      "jozz": 27,
      "page": 537,
      "line_start": 5,
      "line_end": 5,
      "aya_no": 86,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فلولا إن كنتم غير مدينين"
    },
    {
      "id": 5066,
      "jozz": 27,
      "page": 537,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 87,
      "aya_text": "‏‏‏‏‏‏‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "ترجعونها إن كنتم صادقين"
    },
    {
      "id": 5067,
      "jozz": 27,
      "page": 537,
      "line_start": 6,
      "line_end": 6,
      "aya_no": 88,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فأما إن كان من المقربين"
    },
    {
      "id": 5068,
      "jozz": 27,
      "page": 537,
      "line_start": 7,
      "line_end": 7,
      "aya_no": 89,
      "aya_text": "‏‏‏‏‏ ‏‏‏‏‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فروح وريحان وجنة نعيم"
    },
    {
      "id": 5069,
      "jozz": 27,
      "page": 537,
      "line_start": 7,
      "line_end": 8,
      "aya_no": 90,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما إن كان من أصحاب اليمين"
    },
    {
      "id": 5070,
      "jozz": 27,
      "page": 537,
      "line_start": 8,
      "line_end": 8,
      "aya_no": 91,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "فسلام لك من أصحاب اليمين"
    },
    {
      "id": 5071,
      "jozz": 27,
      "page": 537,
      "line_start": 8,
      "line_end": 9,
      "aya_no": 92,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏ ‏‏ ‏‏‏‏‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "وأما إن كان من المكذبين الضالين"
    },
    {
      "id": 5072,
      "jozz": 27,
      "page": 537,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 93,
      "aya_text": "‏‏‏‏ ‏‏ ‏‏‏ ‏",
      "aya_text_emlaey": "فنزل من حميم"
    },
    {
      "id": 5073,
      "jozz": 27,
      "page": 537,
      "line_start": 9,
      "line_end": 9,
      "aya_no": 94,
      "aya_text": "‏‏‏‏‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "وتصلية جحيم"
    },
    {
      "id": 5074,
      "jozz": 27,
      "page": 537,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 95,
      "aya_text": "‏‏ ‏‏‏ ‏‏‏ ‏‏ ‏‏‏‏ ‏",
      "aya_text_emlaey": "إن هذا لهو حق اليقين"
    },
    {
      "id": 5075,
      "jozz": 27,
      "page": 537,
      "line_start": 10,
      "line_end": 10,
      "aya_no": 96,
      "aya_text": "‏‏‏‏ ‏‏‏‏ ‏‏‏ ‏‏‏‏‏‏ ‏",
      "aya_text_emlaey": "فسبح باسم ربك العظيم"
    }
